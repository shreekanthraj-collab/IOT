// ================== SOFT START FUNCTIONS ==================
void initSoftStart() {
  ledcSetup(PWM_CHANNEL, PWM_FREQUENCY, PWM_RESOLUTION);
  ledcAttachPin(SOFT_START_PIN, PWM_CHANNEL);
  ledcWrite(PWM_CHANNEL, 0); // Start at 0%
  Serial.println("🔧 SOFT START INITIALIZED");
}

void startSoftStartRamp() {
  if (!softStartRamping) {
    softStartActive = true;
    softStartRamping = true;
    softStartStopPending = false;
    softStartTimer = millis();
    Serial.println("⚡ SOFT START RAMP BEGINNING");
  }
}

void stopSoftStartRamp() {
  if (softStartActive) {
    softStartStopPending = true;
    softStartStopTimer = millis();
    Serial.println("⏹️  SOFT START STOP INITIATED (2s delay)");
  }
}

void handleSoftStart() {
  // Handle stop delay (2 seconds after K3 stops)
  if (softStartStopPending) {
    if (millis() - softStartStopTimer >= SOFT_START_STOP_DELAY) {
      ledcWrite(PWM_CHANNEL, 0); // Ramp down to 0
      softStartActive = false;
      softStartRamping = false;
      softStartStopPending = false;
      Serial.println("✅ SOFT START STOPPED (2s delay complete)");
    }
    return;
  }

  // Handle ramp-up (3 seconds to reach 100%)
  if (softStartRamping && softStartActive) {
    unsigned long elapsed = millis() - softStartTimer;
    
    if (elapsed >= SOFT_START_DELAY) {
      // Ramp-up complete, hold at 100%
      ledcWrite(PWM_CHANNEL, 255); // 100% PWM
      softStartRamping = false;
      Serial.println("✅ SOFT START RAMP COMPLETE (100% PWM)");
    } else {
      // Calculate PWM value (0-255) based on elapsed time
      uint8_t pwmValue = (uint8_t)((elapsed * 255) / SOFT_START_DELAY);
      ledcWrite(PWM_CHANNEL, pwmValue);
      // Serial.print("⚡ PWM: "); Serial.println(pwmValue);
    }
  }
}

