// ================== MODEM SLEEP MANAGEMENT ==================
enum ModemState { MODEM_ACTIVE, MODEM_SLEEP };
ModemState modemState = MODEM_ACTIVE;

// ================== SOFT START CONFIGURATION ==================
#define PWM_PIN           25      // BC847B base through 1k resistor
#define PWM_FREQ          5000    // 5kHz PWM frequency
#define PWM_RES           8       // 8-bit resolution (0-255)

#define SOFT_START_ENABLED true
#define SOFT_START_STEP   3       // PWM increment per cycle (0-255)
#define SOFT_START_DELAY  30      // milliseconds between steps
#define BYPASS_DELAY      1000    // milliseconds before main relay ON

// Soft start state variables
struct SoftStartState {
  bool active = false;
  unsigned long lastStepTime = 0;
  uint16_t currentPWM = 0;
  State targetDirection = IDLE;
} softStart;

// ================== RELAY PINS ==================
#define K1_RELAY  27      // Forward relay
#define K2_RELAY  14      // Reverse relay
#define K3_RELAY  26      // Main bypass relay

// ================== NON-BLOCKING SOFT START ==================
void initiateSoftStart(State dir) {
  softStart.active = true;
  softStart.lastStepTime = millis();
  softStart.currentPWM = 0;
  softStart.targetDirection = dir;
  
  Serial.println("🚀 SOFT START INITIATED");
  Serial.print("📊 Direction: ");
  Serial.println(dir == FORWARD_RUN ? "FORWARD" : "REVERSE");
}

// Call this frequently in loop() to handle soft start progression
bool handleSoftStart() {
  if (!softStart.active) return false;
  
  unsigned long now = millis();
  
  // Check if it's time for next PWM step
  if (now - softStart.lastStepTime >= SOFT_START_DELAY) {
    softStart.lastStepTime = now;
    softStart.currentPWM += SOFT_START_STEP;
    
    // Ramp complete - turn on main bypass relay
    if (softStart.currentPWM >= 255) {
      ledcWrite(PWM_PIN, 255);
      digitalWrite(K3_RELAY, HIGH);  // Main relay ON
      
      motorState = softStart.targetDirection;
      softStart.active = false;
      
      Serial.println("✅ SOFT START COMPLETE → FULL POWER");
      Serial.println("🔌 Main Relay ON");
      
      return false;
    }
    
    // Update PWM
    ledcWrite(PWM_PIN, softStart.currentPWM);
    
    Serial.print("📈 PWM: ");
    Serial.print(softStart.currentPWM);
    Serial.print(" / 255 (");
    Serial.print((softStart.currentPWM * 100) / 255);
    Serial.println("%)");
  }
  
  return true;  // Still ramping
}

// Non-blocking soft stop - gradually reduce PWM
bool handleSoftStop() {
  if (!softStart.active) return false;
  
  unsigned long now = millis();
  
  if (now - softStart.lastStepTime >= SOFT_START_DELAY) {
    softStart.lastStepTime = now;
    
    if (softStart.currentPWM > SOFT_START_STEP) {
      softStart.currentPWM -= SOFT_START_STEP;
      ledcWrite(PWM_PIN, softStart.currentPWM);
      
      Serial.print("📉 PWM: ");
      Serial.print(softStart.currentPWM);
      Serial.println(" (stopping)");
    } else {
      // Stop complete
      digitalWrite(K1_RELAY, LOW);
      digitalWrite(K2_RELAY, LOW);
      ledcWrite(PWM_PIN, 0);
      
      softStart.active = false;
      motorState = IDLE;
      
      Serial.println("🛑 MOTOR STOPPED");
      return false;
    }
  }
  
  return true;
}

// ================== SLEEP WITH MODEM POWER CONTROL ==================
void putModemToSleep() {
  Serial.println("😴 MODEM SLEEP");
  
  // Disconnect MQTT gracefully
  if (mqtt.connected()) {
    mqtt.disconnect();
    Serial.println("📡 MQTT DISCONNECTED");
  }
  
  // Send modem to sleep
  SerialAT.println("AT+QSCLK=1");
  delay(1000);
  
  // Clear any pending responses
  while (SerialAT.available()) {
    SerialAT.read();
  }
  
  modemState = MODEM_SLEEP;
}

void wakeModem() {
  Serial.println("🟢 MODEM WAKE");
  
  // Send AT command to wake
  SerialAT.println("AT");
  delay(500);
  
  // Read response
  while (SerialAT.available()) {
    Serial.write(SerialAT.read());
  }
  
  modemState = MODEM_ACTIVE;
  
  // Give modem time to stabilize
  delay(2000);
  
  // Reconnect to MQTT
  Serial.println("🔄 RECONNECTING MQTT");
}

// ================== NON-BLOCKING SLEEP ==================
unsigned long sleepStartTime = 0;
unsigned long sleepDuration = 60000;  // 60 seconds default

void initiateSleep() {
  Serial.println("💾 INITIATING SLEEP");
  savePosition();
  putModemToSleep();
  sleepStartTime = millis();
  sleepMode = true;
  fwState = FW_SLEEP;
}

bool handleNonBlockingSleep() {
  // Check for wake conditions
  
  // 1. Check serial input
  if (Serial.available()) {
    Serial.println("🟢 SERIAL WAKE");
    wakeModem();
    return true;
  }
  
  // 2. Check limit switch
  if (digitalRead(LIMIT_SWITCH_PIN) == LOW) {
    Serial.println("🟢 LIMIT SWITCH WAKE");
    wakeModem();
    return true;
  }
  
  // 3. Check MQTT message (modem still receives in light sleep)
  if (mqtt.connected() && Serial.available()) {
    Serial.println("🟢 MQTT WAKE");
    wakeModem();
    return true;
  }
  
  // 4. Check sleep duration exceeded
  if (millis() - sleepStartTime > sleepDuration) {
    Serial.println("⏰ SLEEP TIMEOUT");
    wakeModem();
    return true;
  }
  
  return false;
}

// ================== MOTOR CONTROL WITH SOFT START ==================
void stopMotor() {
  if (!motorRunning) {
    Serial.println("Motor Already Stopped");
    return;
  }
  
  if (SOFT_START_ENABLED) {
    // Start soft stop process
    Serial.println("🛑 SOFT STOP INITIATED");
    softStart.active = true;
    softStart.lastStepTime = millis();
    // currentPWM already set from running state
  } else {
    // Hard stop
    digitalWrite(K3_RELAY, LOW);
    delay(100);
    digitalWrite(K1_RELAY, LOW);
    digitalWrite(K2_RELAY, LOW);
    ledcWrite(PWM_PIN, 0);
    motorState = IDLE;
    motorRunning = false;
    Serial.println("🛑 MOTOR STOPPED");
  }
}

void startMotor(State dir) {
  float v = getVoltage();
  
  if (vState == LOCKED) {
    Serial.println("🔒 BATTERY LOCKED");
    return;
  }
  
  if (lockFault) {
    Serial.println("🔒 CURRENT LOCKED");
    return;
  }
  
  if (totalTurns <= 1.0 && v < RESET_V) {
    Serial.println("🛑 START BLOCKED (LOW BATTERY)");
    return;
  }
  
  if (motorRunning) {
    Serial.println("Already Running");
    return;
  }
  
  // ========== DIRECTION SETUP ==========
  if (dir == FORWARD_RUN) {
    Serial.println("FORWARD START");
    digitalWrite(K2_RELAY, LOW);
    delay(100);
    digitalWrite(K1_RELAY, HIGH);
  } else {
    Serial.println("REVERSE START");
    digitalWrite(K1_RELAY, LOW);
    delay(100);
    digitalWrite(K2_RELAY, HIGH);
  }
  
  delay(100);
  digitalWrite(K3_RELAY, LOW);  // Ensure bypass is OFF before soft start
  
  // ========== SOFT START ==========
  if (SOFT_START_ENABLED) {
    initiateSoftStart(dir);
  } else {
    // Direct full power
    digitalWrite(K3_RELAY, HIGH);
    ledcWrite(PWM_PIN, 255);
    motorState = dir;
  }
  
  motorRunning = true;
  lastDirection = dir;
}

// ================== UPDATED LOOP WITH SOFT START ==================
void loop() {
  switch (fwState) {
    
    case FW_INIT:
      Serial.println("🚀 FW INIT → ACTIVE");
      fwState = FW_ACTIVE;
      break;

    case FW_ACTIVE:
      
      // Check idle condition
      if (motorState == IDLE && !isRetryActive()) {
        if (!idleTracking) {
          idleTracking = true;
          idleStart = millis();
        }
        
        // After 5 seconds of idle, enter sleep
        if (!sleepMode && millis() - idleStart > 5000) {
          Serial.println("💾 PRE-SLEEP SAVE");
          initiateSleep();
          break;
        }
      } else {
        idleTracking = false;
      }

      // Handle MQTT and LTE
      connectMQTT();
      mqtt.loop();
      
      // ========== HANDLE SOFT START/STOP (CALL EVERY LOOP!) ==========
      if (softStart.active) {
        if (motorRunning && motorState != IDLE) {
          handleSoftStart();  // Ramping up
        } else {
          handleSoftStop();   // Ramping down
        }
      }
      
      // Handle commands (both serial and MQTT)
      if (Serial.available()) {
        String input = Serial.readStringUntil('\n');
        input.trim();

        if (input.startsWith("{")) {
          handleJSONCommand(input);
        } else {
          String cmd = input;
          cmd.toUpperCase();

          Serial.print("📩 CMD: ");
          Serial.println(cmd);

          if (cmd == "F") startMotor(FORWARD_RUN);
          else if (cmd == "R") startMotor(REVERSE_RUN);
          else if (cmd == "S") stopMotor();
          else if (vState == WAIT_BYPASS) {
            if (cmd == "Y") {
              Serial.println("⚠️ BYPASS ENABLED");
              vState = BYPASS_ACTIVE;
              if (resumePending) {
                Serial.println("🔁 RESUMING");
                startMotor(resumeDirection);
                resumePending = false;
              }
            } else {
              Serial.println("❌ BYPASS DENIED");
              vState = WARNING;
            }
          }
        }
      }

      // Handle all sensors
      handleEncoder();
      handleLimit();
      handleCurrent();
      handleVoltageSafety();
      handleLTE();

      // Internet check (periodic)
      static unsigned long pingTimer = 0;
      if (millis() - pingTimer > 30000) {
        pingTimer = millis();
        Serial.println("🌐 INTERNET CHECK");
        SerialAT.println("AT+QPING=1,\"8.8.8.8\"");
      }

      handleBuzzer();
      printDashboard();

      delay(10);  // SHORT delay for responsive soft start
      break;

    case FW_SLEEP:
      
      // Non-blocking sleep loop
      if (handleNonBlockingSleep()) {
        // Wake condition detected
        sleepMode = false;
        idleTracking = false;
        idleStart = millis();
        
        Serial.println("🔄 RESUMED FROM SLEEP");
        fwState = FW_ACTIVE;
      }
      
      // Light sleep delay
      delay(100);
      break;
  }
}

// ================== COMPLETE SETUP ==================
void setup() {
  Serial.begin(115200);
  delay(2000);
  
  DEVICE_ID = getDeviceID();
  pubTopic = "actuator/" + DEVICE_ID + "/status";
  subTopic = "actuator/" + DEVICE_ID + "/cmd";

  Serial.print("📌 DEVICE ID: ");
  Serial.println(DEVICE_ID);

  // Initialize I2C
  Wire.begin(SDA_PIN, SCL_PIN);

  // Initialize relay pins
  pinMode(K1_RELAY, OUTPUT);
  pinMode(K2_RELAY, OUTPUT);
  pinMode(K3_RELAY, OUTPUT);
  
  digitalWrite(K1_RELAY, LOW);
  digitalWrite(K2_RELAY, LOW);
  digitalWrite(K3_RELAY, LOW);

  // Initialize PWM pin
  ledcAttach(PWM_PIN, PWM_FREQ, PWM_RES);
  ledcWrite(PWM_PIN, 0);

  // Other pins
  pinMode(LIMIT_SWITCH_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);

  // Initialize sensors
  ina226.init();
  prefs.begin("encoder", false);
  loadPosition();

  // Initialize LTE
  initLTE();
  
  // Connect MQTT
  connectMQTT();

  Serial.println("✅ SYSTEM READY");
  
  // Print soft start status
  if (SOFT_START_ENABLED) {
    Serial.print("🚀 SOFT START: ENABLED");
    Serial.print(" | Step: ");
    Serial.print(SOFT_START_STEP);
    Serial.print(" | Delay: ");
    Serial.print(SOFT_START_DELAY);
    Serial.println("ms");
  } else {
    Serial.println("⚡ SOFT START: DISABLED");
  }
}

// ================== MODEM SLEEP COMMANDS ==================
/*
BG96 MODEM SLEEP MODES:

1. LIGHT SLEEP (AT+QSCLK=1):
   - Modem remains connected to network
   - Can receive SMS/MQTT messages
   - Power draw: ~10-20mA
   - Wake: automatic or AT command

2. DEEP SLEEP (AT+QSCLK=2):
   - Disconnects from network
   - Cannot receive messages
   - Power draw: <5mA
   - Wake: GPIO pin or AT command

3. DISABLE SLEEP (AT+QSCLK=0):
   - Always active (high power)

RECOMMENDATION: Use AT+QSCLK=1 to stay connected to MQTT
*/

// ================== SOFT START SEQUENCE ==================
/*
HARDWARE SETUP:
- K1_RELAY: Forward direction
- K2_RELAY: Reverse direction
- K3_RELAY: Main bypass relay (full power)
- PWM_PIN: Controls transistor for K3_RELAY
- BC847B transistor with 1k base resistor

SOFT START SEQUENCE:
1. Turn OFF reverse relay
2. Wait 100ms
3. Turn ON forward relay
4. Wait 100ms
5. Turn OFF bypass relay (K3)
6. Start PWM ramp from 0→255
   - Each step: +3 PWM value
   - Each cycle: 30ms delay
   - Total ramp: ~2.5 seconds
7. Turn ON bypass relay (K3) at full PWM
8. Motor runs at full speed

SOFT STOP SEQUENCE:
1. Ramp PWM down from 255→0
   - Each step: -3 PWM value
   - Each cycle: 30ms delay
2. Turn OFF bypass relay
3. Turn OFF direction relays
4. Motor stops gradually

CONFIGURATION:
SOFT_START_STEP: Lower = smoother ramp, longer time
SOFT_START_DELAY: Time between PWM steps (ms)
BYPASS_DELAY: Wait time before full relay on (ms)

TUNING TIPS:
- Increase SOFT_START_STEP for faster ramp
- Decrease for gentler start
- Adjust SOFT_START_DELAY for finer control
- BYPASS_DELAY: Ensures PWM is established before full power
*/
