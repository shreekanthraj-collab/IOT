// ================== MODEM SLEEP MANAGEMENT ==================
enum ModemState { MODEM_ACTIVE, MODEM_SLEEP };
ModemState modemState = MODEM_ACTIVE;

// ================== SLEEP WITH MODEM POWER CONTROL ==================
void putModemToSleep() {
  Serial.println("😴 MODEM SLEEP");
  
  // Disconnect MQTT gracefully
  if (mqtt.connected()) {
    mqtt.disconnect();
    Serial.println("📡 MQTT DISCONNECTED");
  }
  
  // Send modem to sleep
  SerialAT.println("AT+QSCLK=1");
  delay(1000);
  
  // Clear any pending responses
  while (SerialAT.available()) {
    SerialAT.read();
  }
  
  modemState = MODEM_SLEEP;
}

void wakeModem() {
  Serial.println("🟢 MODEM WAKE");
  
  // Send AT command to wake
  SerialAT.println("AT");
  delay(500);
  
  // Read response
  while (SerialAT.available()) {
    Serial.write(SerialAT.read());
  }
  
  modemState = MODEM_ACTIVE;
  
  // Give modem time to stabilize
  delay(2000);
  
  // Reconnect to MQTT
  Serial.println("🔄 RECONNECTING MQTT");
}

// ================== NON-BLOCKING SLEEP ==================
unsigned long sleepStartTime = 0;
unsigned long sleepDuration = 60000;  // 60 seconds default

void initiateSleep() {
  Serial.println("💾 INITIATING SLEEP");
  savePosition();
  putModemToSleep();
  sleepStartTime = millis();
  sleepMode = true;
  fwState = FW_SLEEP;
}

bool handleNonBlockingSleep() {
  // Check for wake conditions
  
  // 1. Check serial input
  if (Serial.available()) {
    Serial.println("🟢 SERIAL WAKE");
    wakeModem();
    return true;
  }
  
  // 2. Check limit switch
  if (digitalRead(LIMIT_SWITCH_PIN) == LOW) {
    Serial.println("🟢 LIMIT SWITCH WAKE");
    wakeModem();
    return true;
  }
  
  // 3. Check MQTT message (modem still receives in light sleep)
  // We check this periodically by calling mqtt.loop()
  if (mqtt.connected() && Serial.available()) {
    Serial.println("🟢 MQTT WAKE");
    wakeModem();
    return true;
  }
  
  // 4. Check sleep duration exceeded
  if (millis() - sleepStartTime > sleepDuration) {
    Serial.println("⏰ SLEEP TIMEOUT");
    wakeModem();
    return true;
  }
  
  return false;
}

// ================== UPDATED LOOP WITH PROPER SLEEP ==================
void loop() {
  switch (fwState) {
    
    case FW_INIT:
      Serial.println("🚀 FW INIT → ACTIVE");
      fwState = FW_ACTIVE;
      break;

    case FW_ACTIVE:
      
      // Check idle condition
      if (motorState == IDLE && !isRetryActive()) {
        if (!idleTracking) {
          idleTracking = true;
          idleStart = millis();
        }
        
        // After 5 seconds of idle, enter sleep
        if (!sleepMode && millis() - idleStart > 5000) {
          Serial.println("💾 PRE-SLEEP SAVE");
          initiateSleep();  // This puts modem to sleep too
          break;
        }
      } else {
        idleTracking = false;
      }

      // Handle MQTT and LTE
      connectMQTT();
      mqtt.loop();
      
      // Handle commands (both serial and MQTT)
      if (Serial.available()) {
        String input = Serial.readStringUntil('\n');
        input.trim();

        if (input.startsWith("{")) {
          handleJSONCommand(input);
        } else {
          String cmd = input;
          cmd.toUpperCase();

          Serial.print("📩 CMD: ");
          Serial.println(cmd);

          if (cmd == "F") startMotor(FORWARD_RUN);
          else if (cmd == "R") startMotor(REVERSE_RUN);
          else if (cmd == "S") stopMotor();
          else if (vState == WAIT_BYPASS) {
            if (cmd == "Y") {
              Serial.println("⚠️ BYPASS ENABLED");
              vState = BYPASS_ACTIVE;
              if (resumePending) {
                Serial.println("🔁 RESUMING");
                startMotor(resumeDirection);
                resumePending = false;
              }
            } else {
              Serial.println("❌ BYPASS DENIED");
              vState = WARNING;
            }
          }
        }
      }

      // Handle all sensors
      handleEncoder();
      handleLimit();
      handleCurrent();
      handleVoltageSafety();
      handleLTE();

      // Internet check (periodic)
      static unsigned long pingTimer = 0;
      if (millis() - pingTimer > 30000) {
        pingTimer = millis();
        Serial.println("🌐 INTERNET CHECK");
        SerialAT.println("AT+QPING=1,\"8.8.8.8\"");
      }

      handleBuzzer();
      printDashboard();

      delay(20);
      break;

    case FW_SLEEP:
      
      // Non-blocking sleep loop
      if (handleNonBlockingSleep()) {
        // Wake condition detected
        sleepMode = false;
        idleTracking = false;
        idleStart = millis();
        
        Serial.println("🔄 RESUMED FROM SLEEP");
        fwState = FW_ACTIVE;
      }
      
      // Light sleep delay (still responsive)
      delay(100);
      break;
  }
}

// ================== COMPLETE SETUP ==================
void setup() {
  Serial.begin(115200);
  delay(2000);
  
  DEVICE_ID = getDeviceID();
  pubTopic = "actuator/" + DEVICE_ID + "/status";
  subTopic = "actuator/" + DEVICE_ID + "/cmd";

  Serial.print("📌 DEVICE ID: ");
  Serial.println(DEVICE_ID);

  // Initialize I2C
  Wire.begin(SDA_PIN, SCL_PIN);

  // Initialize pins
  pinMode(RELAY_PWR, OUTPUT);
  pinMode(RELAY_FWD, OUTPUT);
  pinMode(RELAY_REV, OUTPUT);
  pinMode(LIMIT_SWITCH_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);

  // Initialize sensors
  ina226.init();
  prefs.begin("encoder", false);
  loadPosition();

  // Initialize LTE
  initLTE();
  
  // Connect MQTT
  connectMQTT();

  Serial.println("✅ SYSTEM READY");
}

// ================== HELPER: MODEM SLEEP COMMANDS ==================
/*
BG96 MODEM SLEEP MODES:

1. LIGHT SLEEP (AT+QSCLK=1):
   - Modem remains connected to network
   - Can receive SMS/MQTT messages
   - Power draw: ~10-20mA
   - Wake: automatic or AT command

2. DEEP SLEEP (AT+QSCLK=2):
   - Disconnects from network
   - Cannot receive messages
   - Power draw: <5mA
   - Wake: GPIO pin or AT command

3. DISABLE SLEEP (AT+QSCLK=0):
   - Always active (high power)

RECOMMENDATION: Use AT+QSCLK=1 for your use case to stay connected to MQTT
*/
