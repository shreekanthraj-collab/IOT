// ================== [SENSOR] REAL SENSOR HEALTH VERIFICATION ==================

// ── INA226: read Manufacturer ID register 0xFE — must return 0x5449 ──
String checkINA226() {
  Wire.beginTransmission(INA_ADDR);
  if (Wire.endTransmission() != 0) return "NO_ACK";

  Wire.beginTransmission(INA_ADDR);
  Wire.write(0xFE);
  if (Wire.endTransmission(false) != 0) return "NO_ACK";

  Wire.requestFrom(INA_ADDR, 2);
  if (Wire.available() < 2) return "NO_ACK";
  uint16_t mfr = ((uint16_t)Wire.read() << 8) | Wire.read();
  if (mfr != 0x5449) return "BAD_ID";
  return "OK";
}

// ── AS5600: check STATUS (0x0B) and AGC (0x1A) registers ──
String checkAS5600() {
  Wire.beginTransmission(AS5600_ADDR);
  if (Wire.endTransmission() != 0) return "NO_ACK";

  // STATUS register 0x0B — bit 5 (MD) must be 1 = magnet detected
  Wire.beginTransmission(AS5600_ADDR);
  Wire.write(0x0B);
  if (Wire.endTransmission(false) != 0) return "NO_ACK";
  Wire.requestFrom(AS5600_ADDR, 1);
  if (!Wire.available()) return "NO_ACK";
  uint8_t status = Wire.read();
  if (!(status & 0x20)) return "NO_MAGNET";   // MD bit not set

  // AGC register 0x1A — 0 or 255 means magnet too close or too far
  Wire.beginTransmission(AS5600_ADDR);
  Wire.write(0x1A);
  if (Wire.endTransmission(false) != 0) return "NO_ACK";
  Wire.requestFrom(AS5600_ADDR, 1);
  if (!Wire.available()) return "NO_ACK";
  uint8_t agc = Wire.read();
  if (agc == 0 || agc == 255) return "AGC_SATURATED";

  return "OK";
}

void checkSensors() {
  String inaResult = checkINA226();
