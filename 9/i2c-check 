// ================== [RAMP] NON-BLOCKING RAMP HANDLER ==================
// Called every loop tick from FW_ACTIVE and FW_OTA_WAIT.
// Drives the ramp state machine; no delay() anywhere inside.
void handleMotorRamp() {
  if (rampState == RAMP_IDLE || rampState == RAMP_RUNNING) return;

  unsigned long now = millis();

  switch (rampState) {

    // ── Advance PWM 0 → 255 one step per RAMP_STEP_MS ──
    case RAMP_UP:
      if (now - rampTimer >= RAMP_STEP_MS) {
        rampTimer = now;
        rampDuty += 3;
        if (rampDuty > 255) rampDuty = 255;
        ledcWrite(PWM_PIN, rampDuty);

        if (rampDuty >= 255) {
          rampSettle = now;
          rampState  = RAMP_BYPASS;
          Serial.println("⏳ RAMP UP DONE — settling before bypass");
        }
      }
      break;

    // ── Wait RAMP_SETTLE_MS then close bypass relay K3 ──
    case RAMP_BYPASS:
      if (now - rampSettle >= RAMP_SETTLE_MS) {
        digitalWrite(RELAY_PWR, RELAY_ON);  // K3 closes — transistor bypassed
        ledcWrite(PWM_PIN, 255);             // keep transistor saturated
        motorState    = rampDir;
        lastDirection = rampDir;
        rampState     = RAMP_RUNNING;
        Serial.println("⚡ BYPASS RELAY ON — MOTOR RUNNING");
      }
      break;

    // ── Open bypass relay, hand load back to transistor ──
    case RAMP_DOWN_INIT:
      digitalWrite(RELAY_PWR, RELAY_OFF);  // drop bypass first
      rampDuty  = 255;
      ledcWrite(PWM_PIN, rampDuty);
      rampTimer = now;
      rampState = RAMP_DOWN;
      Serial.println("🔽 SOFT STOP — ramping PWM down");
      break;

    // ── Ramp PWM 255 → 0 one step per RAMP_STEP_MS ──
    case RAMP_DOWN:
      if (now - rampTimer >= RAMP_STEP_MS) {
        rampTimer = now;
        rampDuty -= 3;
        if (rampDuty < 0) rampDuty = 0;
        ledcWrite(PWM_PIN, rampDuty);

        if (rampDuty <= 0) {
          ledcWrite(PWM_PIN, 0);
          rampState = RAMP_DONE;
        }
      }
      break;

    // ── All clear — cut direction relays and finalise IDLE ──
    case RAMP_DONE:
      digitalWrite(RELAY_FWD, RELAY_OFF);
      digitalWrite(RELAY_REV, RELAY_OFF);
      ledcWrite(PWM_PIN, 0);
      rampState  = RAMP_IDLE;
      motorState = IDLE;
      savePosition();
      publishPosition(resumeDirection);   // FIX-03 preserved
      Serial.println("🛑 MOTOR STOPPED — IDLE");
      break;

    default: break;
  }
}




// ================== MOTOR ==================

// FIX-01: clearRelays() — kills relay power with NO side effects.
// MERGED: also zeros PWM so transistor is off before any relay change.
void clearRelays() {
  ledcWrite(PWM_PIN, 0);              // MERGED: transistor off first
  digitalWrite(RELAY_PWR, RELAY_OFF);
  digitalWrite(RELAY_FWD, RELAY_OFF);
  digitalWrite(RELAY_REV, RELAY_OFF);
}

// [RAMP] stopMotor — initiates non-blocking ramp-down via state machine
void stopMotor() {
  State stoppedFrom = motorState;   // FIX-03: capture direction BEFORE clearing

  if (motorState != IDLE) {
    resumeDirection = motorState;
    resumePending   = true;

    // If mid-ramp-up, abort cleanly — bypass not yet closed
    if (rampState == RAMP_UP || rampState == RAMP_BYPASS) {
      clearRelays();
      rampState  = RAMP_IDLE;
      motorState = IDLE;
      savePosition();
      publishPosition(stoppedFrom);   // FIX-03
      return;
    }

    // Normal running stop — initiate non-blocking ramp-down
    rampState = RAMP_DOWN_INIT;
    // motorState transitions to IDLE inside RAMP_DONE tick
    return;
  }

  // Already IDLE — safe no-op
  clearRelays();
  rampState = RAMP_IDLE;
}




// [RAMP] startMotor — initiates non-blocking ramp-up via state machine
void startMotor(State dir) {
  if (vState == LOCKED) { Serial.println("🔒 BATTERY LOCKED"); return; }
  if (lockFault)        { Serial.println("🔒 CURRENT LOCKED"); return; }
  if (!limitOverride &&
    dir == REVERSE_RUN &&
    totalTurns <= MIN_TURNS){ Serial.println("⛔ REVERSE BLOCKED"); return; }
  if (!limitOverride &&
    dir == FORWARD_RUN &&
    totalTurns >= MAX_TURNS){ Serial.println("⛔ FORWARD BLOCKED"); return; }

  // FIX-01: shoot-through protection — clearRelays() also zeros PWM now
  clearRelays();
  rampDuty  = 0;
  rampDir   = dir;
  rampTimer = millis() + 200;   // 200 ms relay settle baked into timer offset

  // Set direction relay; bypass relay (RELAY_PWR) stays OFF until RAMP_BYPASS
  if (dir == FORWARD_RUN) {
    digitalWrite(RELAY_REV, RELAY_OFF);
    digitalWrite(RELAY_FWD, RELAY_ON);
  } else {
    digitalWrite(RELAY_FWD, RELAY_OFF);
    digitalWrite(RELAY_REV, RELAY_ON);
  }

  rampState = RAMP_UP;
  Serial.println("🔼 SOFT START — non-blocking ramp initiated");
}




