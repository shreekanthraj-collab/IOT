uint8_t inaAddr = 0x00;
uint8_t encAddr = 0x00;
uint8_t rtcAddr = 0x00;
INA226_WE* ina226 = nullptr;




// ================== [VBAT] RAW BATTERY ADC ==================
#define VBAT_DIVIDER_RATIO  5.0f
#define VBAT_ADC_REF_MV     3300.0f
#define VBAT_ADC_RES        4095.0f
unsigned long vbatReadTimer = 0;
float         vbatMV        = 0.0f;

float readVBAT_mV() {
  int raw = analogRead(VBAT_ADC_PIN);
  return ((float)raw / VBAT_ADC_RES) * VBAT_ADC_REF_MV * VBAT_DIVIDER_RATIO;
}

volatile bool inaAlertFlag = false;
void IRAM_ATTR inaAlertISR() { inaAlertFlag = true; }




// ================== [RTC] PCF8563 DRIVER ==================
volatile bool rtcAlarmFlag = false;
void IRAM_ATTR rtcAlarmISR() { rtcAlarmFlag = true; }

uint8_t bcdToDec(uint8_t b) { return (b / 16 * 10) + (b % 16); }
uint8_t decToBcd(uint8_t d) { return (d / 10 * 16) + (d % 10); }

bool rtcGetTime(struct tm &t) {
  Wire.beginTransmission(rtcAddr); Wire.write(0x02);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(rtcAddr, (uint8_t)7);
  if (Wire.available() < 7) return false;
  uint8_t sec = Wire.read();
  if (sec & 0x80) return false;
  t.tm_sec  = bcdToDec(sec  & 0x7F);
  t.tm_min  = bcdToDec(Wire.read() & 0x7F);
  t.tm_hour = bcdToDec(Wire.read() & 0x3F);
  t.tm_mday = bcdToDec(Wire.read() & 0x3F);
  t.tm_wday = bcdToDec(Wire.read() & 0x07);
  t.tm_mon  = bcdToDec(Wire.read() & 0x1F) - 1;
  t.tm_year = bcdToDec(Wire.read()) + 100;
  return true;
}

bool rtcSetTime(const struct tm &t) {
  Wire.beginTransmission(rtcAddr); Wire.write(0x02);
  Wire.write(decToBcd(t.tm_sec)  & 0x7F);
  Wire.write(decToBcd(t.tm_min)  & 0x7F);
  Wire.write(decToBcd(t.tm_hour) & 0x3F);
  Wire.write(decToBcd(t.tm_mday) & 0x3F);
  Wire.write(decToBcd(t.tm_wday) & 0x07);
  Wire.write(decToBcd(t.tm_mon + 1) & 0x1F);
  Wire.write(decToBcd(t.tm_year - 100));
  return Wire.endTransmission() == 0;
}

bool rtcIsValid() {
  if (rtcAddr == 0x00) return false;
  Wire.beginTransmission(rtcAddr); Wire.write(0x02);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(rtcAddr, (uint8_t)1);
  if (!Wire.available()) return false;
  return !(Wire.read() & 0x80);
}

String rtcFormatISO(const struct tm &t) {
  char buf[25];
  snprintf(buf, sizeof(buf), "%04d-%02d-%02dT%02d:%02d:%02dZ",
           t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
           t.tm_hour, t.tm_min, t.tm_sec);
  return String(buf);
}

String getTimestamp() {
  struct tm t;
  if (!rtcIsValid())   return "RTC_INVALID";
  if (!rtcGetTime(t)) return "RTC_READ_ERR";
  return rtcFormatISO(t);
}

bool parseISO(const String &iso, struct tm &t) {
  if (iso.length() < 19) return false;
  t.tm_year = iso.substring(0,  4).toInt() - 1900;
  t.tm_mon  = iso.substring(5,  7).toInt() - 1;
  t.tm_mday = iso.substring(8,  10).toInt();
  t.tm_hour = iso.substring(11, 13).toInt();
  t.tm_min  = iso.substring(14, 16).toInt();
  t.tm_sec  = iso.substring(17, 19).toInt();
  int y = t.tm_year + 1900; int m = t.tm_mon + 1;
  if (m < 3) { m += 12; y--; }
  int k = y % 100; int j = y / 100;
  int h = (t.tm_mday + (13*(m+1))/5 + k + k/4 + j/4 + 5*j) % 7;
  t.tm_wday = (h + 6) % 7;
  return true;
}




// ================== [HW] HARDWARE AUTO-DETECTION ==================
bool validateINA226(uint8_t addr) {
  Wire.beginTransmission(addr); Wire.write(0xFE);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(addr, (uint8_t)2);
  if (Wire.available() < 2) return false;
  return (((uint16_t)Wire.read() << 8) | Wire.read()) == 0x5449;
}

bool validateAS5600(uint8_t addr) {
  Wire.beginTransmission(addr); Wire.write(0x0B);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(addr, (uint8_t)1);
  if (!Wire.available()) return false;
  return (Wire.read() & 0x38) != 0;
}

bool validatePCF8563(uint8_t addr) {
  Wire.beginTransmission(addr); Wire.write(0x0D);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(addr, (uint8_t)1);
  if (!Wire.available()) return false;
  return (Wire.read() & 0x78) == 0x00;
}

bool i2cAck(uint8_t addr) {
  Wire.beginTransmission(addr);
  return Wire.endTransmission() == 0;
}

void saveHWProfile() {
  prefs.begin("hw_profile", false);
  prefs.putUChar("ina_addr", inaAddr);
  prefs.putUChar("enc_addr", encAddr);
  prefs.putUChar("rtc_addr", rtcAddr);
  prefs.end();
  Serial.printf("💾 HW PROFILE SAVED — INA:0x%02X ENC:0x%02X RTC:0x%02X\n",
                inaAddr, encAddr, rtcAddr);
}

void loadHWProfile() {
  prefs.begin("hw_profile", true);
  inaAddr = prefs.getUChar("ina_addr", 0x00);
  encAddr = prefs.getUChar("enc_addr", 0x00);
  rtcAddr = prefs.getUChar("rtc_addr", 0x00);
  prefs.end();
}

void publishHWProfile();   // forward declaration

bool detectHardware() {
  Serial.println("🔍 HW DETECT — loading NVS cache...");
  loadHWProfile();
  bool inaOK = false, encOK = false, rtcOK = false;

  if (inaAddr != 0x00 && i2cAck(inaAddr) && validateINA226(inaAddr))
    { Serial.printf("✅ INA226 @ 0x%02X (cached)\n", inaAddr); inaOK = true; }
  if (encAddr != 0x00 && i2cAck(encAddr) && validateAS5600(encAddr))
    { Serial.printf("✅ AS5600 @ 0x%02X (cached)\n", encAddr); encOK = true; }
  if (rtcAddr != 0x00 && i2cAck(rtcAddr) && validatePCF8563(rtcAddr))
    { Serial.printf("✅ PCF8563 @ 0x%02X (cached)\n", rtcAddr); rtcOK = true; }

  if (!inaOK || !encOK || !rtcOK) {
    Serial.println("🔍 HW DETECT — full bus scan...");
    if (!inaOK) {
      inaAddr = 0x00;
      for (uint8_t addr = 0x40; addr <= 0x4F; addr++) {
        if (i2cAck(addr) && validateINA226(addr))
          { inaAddr = addr; Serial.printf("✅ INA226 @ 0x%02X\n", addr); inaOK = true; break; }
      }
      if (!inaOK) Serial.println("❌ INA226 NOT FOUND");
    }
    if (!encOK) {
      encAddr = 0x00;
      if (i2cAck(0x36) && validateAS5600(0x36))
        { encAddr = 0x36; Serial.println("✅ AS5600 @ 0x36"); encOK = true; }
      else Serial.println("❌ AS5600 NOT FOUND");
    }
    if (!rtcOK) {
      // Scan 0x50–0x57 — covers PCF8563 (0x51), HYM8563 (0x51), and
      // any compatible clone that may sit at a neighbouring address on
      // future board revisions.  Same pattern as INA226 (0x40–0x4F).
      rtcAddr = 0x00;
      for (uint8_t addr = 0x50; addr <= 0x57; addr++) {
        if (i2cAck(addr) && validatePCF8563(addr)) {
          rtcAddr = addr;
          Serial.printf("✅ PCF8563 found @ 0x%02X\n", addr);
          rtcOK = true;
          break;
        }
      }
      if (!rtcOK) Serial.println("❌ PCF8563 NOT FOUND (scanned 0x50–0x57)");
    }
    if (inaOK && encOK && rtcOK) saveHWProfile();
  }

  bool allOK = inaOK && encOK && rtcOK;
  if (!allOK)
    Serial.printf("🔴 HW DETECT FAILED — INA:%s ENC:%s RTC:%s\n",
                  inaOK?"OK":"MISSING", encOK?"OK":"MISSING", rtcOK?"OK":"MISSING");
  else
    Serial.println("✅ HW DETECT COMPLETE");
  return allOK;
}




// ================== [SCHED] SCHEDULE ENGINE ==================
#define SCHED_SLOTS 8
struct SchedSlot {
  bool    enabled;
  uint8_t action;
  uint8_t hour;
  uint8_t minute;
  char    days[8];
};
SchedSlot schedSlots[SCHED_SLOTS];

void saveSchedule() {
  prefs.begin("schedule", false);
  for (int i = 0; i < SCHED_SLOTS; i++) {
    String key = "slot" + String(i);
    uint8_t buf[12];
    buf[0]=schedSlots[i].enabled?1:0; buf[1]=schedSlots[i].action;
    buf[2]=schedSlots[i].hour;        buf[3]=schedSlots[i].minute;
    memcpy(buf+4, schedSlots[i].days, 7); buf[11]=0;
    prefs.putBytes(key.c_str(), buf, 12);
  }
  prefs.end();
  Serial.println("💾 SCHEDULE SAVED");
}

void loadSchedule() {
  prefs.begin("schedule", true);
  for (int i = 0; i < SCHED_SLOTS; i++) {
    String key = "slot" + String(i);
    uint8_t buf[12] = {0};
    size_t len = prefs.getBytes(key.c_str(), buf, 12);
    if (len == 12) {
      schedSlots[i].enabled=buf[0]; schedSlots[i].action=buf[1];
      schedSlots[i].hour=buf[2];    schedSlots[i].minute=buf[3];
      memcpy(schedSlots[i].days, buf+4, 7); schedSlots[i].days[7]='\0';
    } else {
      schedSlots[i].enabled=false; schedSlots[i].action=0;
      schedSlots[i].hour=0;        schedSlots[i].minute=0;
      memcpy(schedSlots[i].days, "0000000", 7); schedSlots[i].days[7]='\0';
    }
  }
  prefs.end();
  Serial.println("📂 SCHEDULE LOADED");
}

bool slotActiveToday(const SchedSlot &slot, int wday) { return slot.days[wday]=='1'; }

void armAlarm1(uint8_t hour, uint8_t minute) {
  if (rtcAddr == 0x00) return;
  Wire.beginTransmission(rtcAddr); Wire.write(0x01);
  if (Wire.endTransmission(false) == 0) {
    Wire.requestFrom(rtcAddr, (uint8_t)1);
    uint8_t ctrl2 = Wire.available() ? Wire.read() : 0;
    ctrl2 &= ~0x08;
    Wire.beginTransmission(rtcAddr); Wire.write(0x01); Wire.write(ctrl2); Wire.endTransmission();
  }
  Wire.beginTransmission(rtcAddr); Wire.write(0x09);
  Wire.write(decToBcd(minute)&0x7F); Wire.write(decToBcd(hour)&0x3F);
  Wire.write(0x80); Wire.write(0x80); Wire.endTransmission();
  Wire.beginTransmission(rtcAddr); Wire.write(0x01);
  if (Wire.endTransmission(false) == 0) {
    Wire.requestFrom(rtcAddr, (uint8_t)1);
    uint8_t ctrl2 = Wire.available() ? Wire.read() : 0;
    ctrl2 |= 0x02;
    Wire.beginTransmission(rtcAddr); Wire.write(0x01); Wire.write(ctrl2); Wire.endTransmission();
  }
  Serial.printf("⏰ ALARM ARMED: %02d:%02d\n", hour, minute);
}

void clearAlarm1Flag() {
  if (rtcAddr == 0x00) return;
  Wire.beginTransmission(rtcAddr); Wire.write(0x01);
  if (Wire.endTransmission(false) != 0) return;
  Wire.requestFrom(rtcAddr, (uint8_t)1);
  uint8_t ctrl2 = Wire.available() ? Wire.read() : 0;
  ctrl2 &= ~0x08;
  Wire.beginTransmission(rtcAddr); Wire.write(0x01); Wire.write(ctrl2); Wire.endTransmission();
}

void armNextAlarm() {
  if (!rtcIsValid()) { Serial.println("⚠️ RTC invalid — cannot arm scheduler"); return; }
  struct tm now; if (!rtcGetTime(now)) return;
  int bestSlot=-1, bestMinutes=9999, nowMinutes=now.tm_hour*60+now.tm_min;
  for (int i=0; i<SCHED_SLOTS; i++) {
    if (!schedSlots[i].enabled) continue;
    for (int d=0; d<=7; d++) {
      int wday=(now.tm_wday+d)%7;
      if (!slotActiveToday(schedSlots[i], wday)) continue;
      int slotMin=schedSlots[i].hour*60+schedSlots[i].minute;
      int diff=(d==0)?(slotMin-nowMinutes):(d*1440+slotMin-nowMinutes);
      if (d==0 && diff<=0) continue;
      if (diff<bestMinutes) { bestMinutes=diff; bestSlot=i; }
      break;
    }
  }
  if (bestSlot==-1) { Serial.println("📅 No active schedule slots"); return; }
  armAlarm1(schedSlots[bestSlot].hour, schedSlots[bestSlot].minute);
  Serial.printf("📅 Next: slot %d → %s at %02d:%02d\n", bestSlot,
                schedSlots[bestSlot].action==0?"OPEN":"CLOSE",
                schedSlots[bestSlot].hour, schedSlots[bestSlot].minute);
}

void handleScheduledAlarms() {
  if (!rtcIsValid()) return;
  struct tm now; if (!rtcGetTime(now)) return;
  for (int i=0; i<SCHED_SLOTS; i++) {
    if (!schedSlots[i].enabled) continue;
    if (!slotActiveToday(schedSlots[i], now.tm_wday)) continue;
    if (schedSlots[i].hour   != (uint8_t)now.tm_hour) continue;
    if (schedSlots[i].minute != (uint8_t)now.tm_min)  continue;
    Serial.printf("📅 SCHED ACTION: slot %d → %s\n", i,
                  schedSlots[i].action==0?"OPEN":"CLOSE");
    if (schedSlots[i].action==0) startMotor(FORWARD_RUN);
    else                         startMotor(REVERSE_RUN);
    if (mqtt.connected()) {
      StaticJsonDocument<192> doc;
      doc["device_id"]=DEVICE_ID; doc["sched_event"]=schedSlots[i].action==0?"SCHED_OPEN":"SCHED_CLOSE";
      doc["slot"]=i; doc["ts"]=getTimestamp();
      String out; serializeJson(doc, out);
      mqtt.publish(pubEventTopic.c_str(), out.c_str(), false, 1);
    }
  }
  clearAlarm1Flag(); armNextAlarm();
}

void publishSchedule() {
  StaticJsonDocument<512> doc;
  doc["device_id"]=DEVICE_ID; doc["ts"]=getTimestamp();
  JsonArray arr=doc.createNestedArray("schedule");
  for (int i=0; i<SCHED_SLOTS; i++) {
    JsonObject s=arr.createNestedObject();
    s["slot"]=i; s["enabled"]=schedSlots[i].enabled;
    s["action"]=schedSlots[i].action==0?"OPEN":"CLOSE";
    s["hour"]=schedSlots[i].hour; s["minute"]=schedSlots[i].minute;
    s["days"]=String(schedSlots[i].days);
  }
  String out; serializeJson(doc, out);
  mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
  Serial.print("📤 SCHEDULE: "); Serial.println(out);
}




// ================== MOTOR STATES ==================
enum State { IDLE, FORWARD_RUN, REVERSE_RUN };
State motorState      = IDLE;
State lastDirection   = FORWARD_RUN;
State resumeDirection = IDLE;
bool  resumePending   = false;




// ================== FIRMWARE STATE ==================
enum FirmwareState {
  FW_LTE_INIT, FW_TLS_INIT, FW_BOOT_VALIDATE,
  FW_INIT, FW_ACTIVE, FW_SLEEP, FW_OTA_WAIT, FW_OTA_FLASH
};
FirmwareState fwState = FW_LTE_INIT;




// ================== [DEEP] WAKE REASON ==================
bool isScheduledWake = false;
bool idleTracking = false;

// ================== [MANUAL-OVERRIDE] WAKE-ON-CRANK STATE ==================
// A hand crank / declutch lever shares a shaft with the AS5600 encoder, so
// a manual move is only trackable if we're actively polling the encoder
// WHILE the crank moves — see handleManualOverrideWake() for why a single
// before/after sample can't reconstruct a multi-turn manual move. Wake
// detection is via the limit switch pin as an ext1 deep-sleep wake source
// (see enterDeepSleep()), since there is no dedicated manual-override
// sense line in the current hardware.
bool          isManualOverrideWake      = false;
bool          manualOverridePendingPublish = false;
bool          manualOverrideSettledCleanly = false;
unsigned long manualOverrideWakeStartMs = 0;
#define MANUAL_OVERRIDE_SETTLE_STABLE_READS  6         // consecutive unchanged samples = settled
#define MANUAL_OVERRIDE_POLL_INTERVAL_MS     50UL
#define MANUAL_OVERRIDE_MAX_AWAKE_MS         300000UL  // 5 min hard ceiling on total awake time




// ================== LIMITS ==================
// [CAL] MIN_TURNS is always 0.0 after calibration — the closed physical stop
// is the absolute zero reference.  Set to 1.0 on first boot (before any
// calibration) as a conservative safety margin until the operator calibrates.
float MIN_TURNS = 1.0;   // overwritten to 0.0 on CAL_COMPLETE
float MAX_TURNS = 10.0;




// ================== [SLP] CONFIGURABLE SLEEP TIMEOUT ==================
#define DEFAULT_SLEEP_TIMEOUT_MS  300000UL   // 5 minutes
#define MIN_SLEEP_TIMEOUT_MS       30000UL   // 30 seconds (floor)
#define MAX_SLEEP_TIMEOUT_MS     3600000UL   // 1 hour (ceiling)
#define KEEP_AWAKE_MS              60000UL   // stay awake 60 s after last command

unsigned long sleepTimeoutMs   = DEFAULT_SLEEP_TIMEOUT_MS;
unsigned long keepAwakeTimer   = 0;
bool          keepAwakeActive  = false;




// ================== [WDT] WATCHDOG TIMERS ==================
#define WDT_TIMEOUT_S          60      // hardware task watchdog (seconds)
#define LTE_INIT_TIMEOUT_MS    120000UL  // LTE init hard deadline
#define MQTT_DEAD_MS           180000UL  // max time LTE ready but no MQTT

unsigned long lteInitStartTime = 0;
int           i2cRecoveryCount = 0;    // consecutive I2C recovery failures
#define I2C_RECOVERY_RESET_THRESHOLD  3  // ESP.restart() after this many




// ================== VOLTAGE — 4S LiFePO4 ==================
#define WARN_V_LOW  12.0
#define WARN_V_HIGH 12.4
#define CUT_V       11.6
#define CRITICAL_V  11.2
#define RESET_V     12.0
#define BYPASS_TIMEOUT_MS  120000UL   // [BYPASS] 2 min operator response window

enum VoltageState { NORMAL, WARNING, WAIT_BYPASS, BYPASS_ACTIVE, LOCKED };
VoltageState vState = NORMAL;
unsigned long bypassWaitStart = 0;   // [BYPASS] timestamp WAIT_BYPASS was entered




// ================== [BYPASS] DEFERRED SHADOW PUBLISH FLAG ==================
// Set when an emergency auto-close is COMMANDED (startMotor accepted), and
// consumed/cleared the moment motorState ACTUALLY becomes REVERSE_RUN in
// handleMotorRamp()'s RAMP_BYPASS->RAMP_RUNNING transition. This ensures the
// shadow's valve_state is only ever published as "CLOSING" once it is true,
// never at the moment the close is merely commanded.
bool bypassTimeoutClosePending = false;




// ================== [EMERGENCY] OFFLINE EMERGENCY ACTION STATE ==================
bool          emergencyPending   = false;   // RAM mirror of NVS "pending" flag
unsigned long lastEmergencyRetry = 0;
#define EMERGENCY_RETRY_MS  30000UL         // retry publish every 30 s while connected




// ================== [EOLCERT] EOL CERTIFICATION STATE ==================
// Mirrors, in RAM, the result of the last factory EOL test run (see [EOL]
// section near the bottom of this file). NOT_RUN is the default for any
// unit that has never had EOL mode entered at all. Declared early (enum +
// global only) so connectMQTT()/publishFullStatus(), which are defined
// before the [EOL] section itself, can reference it — actual
// load/save/string-mapper function bodies live in the [STATUS] section
// alongside the other shared state-string mappers.
enum EolCertState { EOL_CERT_NOT_RUN, EOL_CERT_FAILED, EOL_CERT_PASSED };
EolCertState eolCertState = EOL_CERT_NOT_RUN;
bool eolNotTestedAnnounced = false;   // [EOLCERT] true once NOT_EOL_TESTED has been announced this boot




// ================== [BROWNOUT] BOOT RESET REASON ==================
// Captured once in setup() via esp_reset_reason() and cached here — no new
// recovery state machine. positionConfident remains the sole gatekeeper for
// whether the motor is blocked and whether POSITION_UNCERTAIN fires;
// bootWasBrownout is used only to (a) tag that existing event with a
// "cause" field when position genuinely was left uncertain, and (b) log a
// separate, harmless, informational BROWNOUT_RESET event when the valve
// was idle with a known position at the time of the brownout — i.e. no
// action needed, logged for maintenance records only.
esp_reset_reason_t bootResetReason   = ESP_RST_UNKNOWN;
bool                bootWasBrownout   = false;
bool                brownoutAnnounced = false;   // true once BROWNOUT_RESET (or its absence) has been evaluated this boot




// ================== [LIFETIME] LIFETIME DIAGNOSTIC COUNTERS ==================
// NVS namespace "lifetime". Loaded once at boot; boot/brownout/watchdog
// counts written once per boot; motor-cycle counts written on every motor
// stop — same write-on-every-stop cadence savePosition() already uses for
// position, not a new flash-wear category. Visible only via
// GET_DIAGNOSTICS; purely informational — nothing reads these to make a
// safety/control decision.
struct LifetimeCounters {
  uint32_t bootCount;
  uint32_t brownoutCount;
  uint32_t watchdogCount;
  uint32_t openCount;    // motor stops that occurred while running FORWARD_RUN
  uint32_t closeCount;   // motor stops that occurred while running REVERSE_RUN
  uint32_t motorSeconds; // cumulative motor-energized time, seconds
  float    motorTurns;   // cumulative absolute distance traveled, turns
  uint32_t emergencyBypassCount;   // [LIFETIME v1.1.4] autonomous bypass-timeout auto-closes
  String   lastOtaVersion;          // [LIFETIME v1.1.4] FW_VERSION of the last successfully validated OTA
  String   lastOtaTs;                // [LIFETIME v1.1.4] RTC ISO timestamp of that validation
};
LifetimeCounters lifetime = {0,0,0,0,0,0,0.0f,0,"",""};

// Tracks the start of the CURRENT motor run, set in startMotor() on the
// success path, consumed by recordMotorCycle() when that run ends.
unsigned long motorRunStartMs  = 0;
float         turnsAtMoveStart = 0.0f;

void loadLifetimeCounters() {
  prefs.begin("lifetime", true);
  lifetime.bootCount           = prefs.getULong("boot_count", 0);
  lifetime.brownoutCount       = prefs.getULong("brownout_count", 0);
  lifetime.watchdogCount       = prefs.getULong("watchdog_count", 0);
  lifetime.openCount           = prefs.getULong("open_count", 0);
  lifetime.closeCount          = prefs.getULong("close_count", 0);
  lifetime.motorSeconds        = prefs.getULong("motor_seconds", 0);
  lifetime.motorTurns          = prefs.getFloat("motor_turns", 0.0f);
  lifetime.emergencyBypassCount= prefs.getULong("emerg_count", 0);
  lifetime.lastOtaVersion       = prefs.getString("last_ota_ver", "");
  lifetime.lastOtaTs            = prefs.getString("last_ota_ts", "");
  prefs.end();
}

void saveLifetimeBootCounters() {   // boot/brownout/watchdog — written once per boot
  prefs.begin("lifetime", false);
  prefs.putULong("boot_count",     lifetime.bootCount);
  prefs.putULong("brownout_count", lifetime.brownoutCount);
  prefs.putULong("watchdog_count", lifetime.watchdogCount);
  prefs.end();
}

void saveLifetimeMotorCounters() {   // open/close/seconds/turns — written on every motor stop
  prefs.begin("lifetime", false);
  prefs.putULong("open_count",    lifetime.openCount);
  prefs.putULong("close_count",   lifetime.closeCount);
  prefs.putULong("motor_seconds", lifetime.motorSeconds);
  prefs.putFloat("motor_turns",   lifetime.motorTurns);
  prefs.end();
}

// [LIFETIME v1.1.4] Written on each autonomous bypass-timeout auto-close —
// rare event, no meaningful flash-wear concern at this write frequency.
void recordEmergencyBypass() {
  lifetime.emergencyBypassCount++;
  prefs.begin("lifetime", false);
  prefs.putULong("emerg_count", lifetime.emergencyBypassCount);
  prefs.end();
}

// [LIFETIME v1.1.4] Written once, only on a successfully validated OTA —
// this is already a rare, already-flash-writing event (boot_check itself
// is persisted around the same OTA validation moment), so no new wear
// category is introduced here.
void recordOtaValidated() {
  lifetime.lastOtaVersion = FW_VERSION;
  lifetime.lastOtaTs      = getTimestamp();
  prefs.begin("lifetime", false);
  prefs.putString("last_ota_ver", lifetime.lastOtaVersion);
  prefs.putString("last_ota_ts",  lifetime.lastOtaTs);
  prefs.end();
}

// Called from both places a motor run can end: the early-abort branch in
// stopMotor() (stopped while still ramping up) and RAMP_DONE in
// handleMotorRamp() (stopped after reaching full run). Covers both so
// partial/aborted moves aren't missed.
void recordMotorCycle(State direction) {
  unsigned long elapsedSec = (millis() - motorRunStartMs) / 1000UL;
  lifetime.motorSeconds += elapsedSec;
  lifetime.motorTurns   += fabs(totalTurns - turnsAtMoveStart);
  if      (direction == FORWARD_RUN) lifetime.openCount++;
  else if (direction == REVERSE_RUN) lifetime.closeCount++;
  saveLifetimeMotorCounters();
}




