// ================== AWS FIRMWARE v1.2.0 ==================
// ESP32-S3 Municipal Actuator — Session 15
//
// Base: aws_firmware_v1.1.2 — all prior features preserved. (Note: a
// v1.1.3 was previously built as a purely-additive DeviceState mirror
// experiment and then explicitly reverted back to v1.1.2 before this
// version — v1.1.3/v1.1.4 numbering was intentionally skipped to avoid
// any ambiguity with that abandoned branch.)
//
// v1.2.0 CHANGES — Manual-Override Wake, Lifetime Diagnostics, Buzzer Patterns:
//
//   [MANUAL-OVERRIDE] Deep sleep now wakes on EITHER the RTC alarm
//             (scheduled) OR the limit switch (ext1 bitmask wake, both
//             pins active-low, ANY_LOW mode) — the hand-crank/declutch
//             lever shares a shaft with the AS5600 encoder, and the limit
//             switch is the only wake-capable proxy for "someone moved the
//             valve by hand" in current hardware; there's no dedicated
//             manual-override sense line.
//
//             handleManualOverrideWake() debounces switch noise (two
//             angle samples 300ms apart; if barely moved and the switch
//             isn't actively held, treat as noise, sleep immediately with
//             no publish). For genuine movement, it polls the encoder
//             continuously — NOT a single before/after sample, which
//             cannot distinguish e.g. 0.2 turns from 1.2 turns since
//             rotation-wrap tracking depends on frequent consecutive
//             samples — until the angle is stable for
//             MANUAL_OVERRIDE_SETTLE_STABLE_READS reads, or until
//             MANUAL_OVERRIDE_MAX_AWAKE_MS (5 min) is exceeded, in which
//             case it abandons the quick-resleep path and falls through to
//             full normal operation instead.
//
//             Once settled, savePosition() persists the new position
//             (positionConfident=true), then normal setup()/LTE/MQTT boot
//             proceeds unmodified. connectMQTT() publishes a one-time
//             MANUAL_OVERRIDE_MOVE event + full status, then — only on a
//             clean settle — immediately re-enters deep sleep rather than
//             lingering for the normal idle timeout. A loop()-level
//             ceiling independently forces sleep if LTE/MQTT never
//             connects within the awake budget; the position is not lost
//             in that case, only the cloud notification is skipped for
//             this cycle.
//
//             NOTE: esp_sleep_enable_ext1_wakeup()/ESP_EXT1_WAKEUP_ANY_LOW
//             naming/availability has shifted across ESP-IDF/Arduino-core
//             versions (same category of break as the Core 3.x watchdog
//             API). Verify on the bench before trusting in the field —
//             see the comment in enterDeepSleep() for the ext0 fallback if
//             needed.
//
//   [LIFETIME] New NVS namespace "lifetime": boot count, brownout count,
//             watchdog-reset count (written once per boot); open/close
//             motor-stop counts, cumulative motor-energized seconds,
//             cumulative absolute travel turns (written on every motor
//             stop — same cadence savePosition() already uses, not a new
//             wear category); emergency-bypass count (written on each
//             autonomous bypass-timeout auto-close); last validated OTA
//             version + timestamp (written once per successful OTA
//             validation). recordMotorCycle() is called from BOTH places a
//             motor run can end — the early-abort branch in stopMotor()
//             and RAMP_DONE in handleMotorRamp() — so partial/aborted
//             moves aren't undercounted. Exposed only via GET_DIAGNOSTICS,
//             never on a timer, never in publishFullStatus() — no AWS
//             traffic increase.
//
//   [BUZZ-PATTERN] New buzzPattern() helper for discrete, rare, one-shot
//             events: boot OK (1 beep, skipped during a manual-override
//             wake to keep that path quiet), LTE connected (2 beeps, same
//             skip), calibration complete (3 beeps), EOL passed (1 long
//             beep), low-voltage bypass entry (2 slow beeps), current-lock
//             fault trip (4 rapid beeps). Deliberately NOT a continuous
//             fault tone — handleBuzzer() already owns BUZZER_PIN
//             continuously for travel-limit proximity indication during
//             normal FW_ACTIVE operation; a second continuous driver would
//             fight it for the pin every loop tick. handleBuzzer() itself
//             is completely unmodified.
//
//   [MANUAL-BUZZER] Added one-shot buzzer indication for manual
//             limit-switch operation while the device is awake (distinct
//             from the deep-sleep manual-override-wake path above, which
//             does not call handleBuzzer() at all).
//
//             Indication is based on the calibrated valve endpoints
//             (MIN_TURNS/MAX_TURNS), not fixed turn counts, so it stays
//             correct across any valve's calibration.
//
//             Buzzer patterns:
//               3 beeps -> Calibrated CLOSED (MIN_TURNS ± MANUAL_LIMIT_CAL_TOLERANCE)
//               2 beeps -> Calibrated OPEN   (MAX_TURNS ± MANUAL_LIMIT_CAL_TOLERANCE)
//               1 beep  -> Limit switch active at an unexpected position
//
//             Edge-latched (manualLimitBeepPlayed) so holding the switch
//             doesn't repeatedly retrigger the pattern; latch clears on
//             release. If positionConfident==false at the moment the
//             switch is first seen active, stays silent for that press —
//             latch is taken before the confidence check, so the decision
//             can't change while still held; operator must release and
//             re-trigger after confidence is restored.
//
//             Implemented as a branch on motorState==IDLE inside the
//             EXISTING handleBuzzer(), not a parallel driver: motor IDLE
//             + limit switch active can only mean a hand-crank move (the
//             motor never engages the switch without leaving IDLE first),
//             so this is mutually exclusive with — and does not modify —
//             the pre-existing continuous motorized-approach proximity
//             indication in the same function. Touches nothing else:
//             encoder tracking, calibration state, position storage,
//             motor control, OTA, LTE, MQTT, and AWS traffic are all
//             unaffected.
//
//   [VER]   FW_VERSION bumped to aws-1.2.0
//
// ============================================================
// v1.1.2 CHANGES — Brownout Reset Logging (no new state machine):
//
//   [BROWNOUT] Deliberately NOT a new recovery FSM. positionConfident
//             remains the sole gatekeeper for motor blocking and for
//             whether POSITION_UNCERTAIN fires — unchanged from v1.0.x.
//             This adds only diagnostic/logging context on top of that
//             existing mechanism:
//
//             - bootResetReason / bootWasBrownout captured once in
//               setup() via esp_reset_reason(), cached for the boot.
//             - If a brownout reset left position uncertain (motor was
//               mid-move when power was lost — positionConfident was
//               already false, exactly as it already worked), the
//               existing POSITION_UNCERTAIN event now additionally
//               carries "cause":"BROWNOUT". No behavior change — the
//               operator still recovers via CALIBRATE_CLOSED or
//               CONFIRM_POSITION exactly as before.
//             - If a brownout reset did NOT leave position uncertain
//               (valve was idle, last position had already been saved —
//               a harmless power event), a one-time-per-boot informational
//               "BROWNOUT_RESET" event is logged for maintenance records.
//               No motor block, no operator action required.
//             - GET_DIAGNOSTICS' reset_reason field now sources from the
//               same cached bootResetReason rather than re-querying
//               esp_reset_reason() a second time.
//
//             Any other reset cause (watchdog, panic, power-on, etc.)
//             that leaves position uncertain is handled by the exact same
//             pre-existing POSITION_UNCERTAIN path — brownout is not a
//             special case for recovery purposes, only for logging.
//
//   [VER]   FW_VERSION bumped to aws-1.1.2
//
// ============================================================
// v1.1.1 CHANGES — Shadow Diffing + GET_DIAGNOSTICS:
//
//   [SHADOWDIFF] publishShadowReported() now caches every field it has ever
//             published (shadowLastReported) and diffs each new call
//             against it — only genuinely changed fields are sent, and if
//             nothing changed, the publish is skipped entirely. No call
//             site needed to change; the diffing is transparent to every
//             existing caller (bypass timeout, voltage recovery, emergency
//             replay, NOT_EOL_TESTED). Reduces redundant AWS Shadow traffic
//             without altering when/why any given call site decides to
//             call publishShadowReported() in the first place.
//
//   [DIAG]  New GET_DIAGNOSTICS command — service/engineering view,
//             deliberately separate from GET_STATUS (which remains the
//             operator view: valve state, position, voltage status, fault,
//             cal state, EOL status, firmware version). Diagnostics
//             payload: free/min-free heap, heap size, uptime, ESP reset
//             reason, LTE state machine state + registration retry count +
//             APN, MQTT connection state, detailed sensor health strings,
//             I2C fault/recovery counters, RTC validity/address, EOL
//             status. Published only on request — no periodic timer.
//             Does NOT re-probe the modem live (no blocking AT command)
//             to avoid colliding with any in-flight LTE exchange; reports
//             the firmware's own tracked lteReady/lteState instead.
//
//   [VER]   FW_VERSION bumped to aws-1.1.1
//
// ============================================================
// v1.1.0 CHANGES — EOL Certification Tracking + NOT_EOL_TESTED Status:
//
//   [EOLCERT] The v1.0.8 EOL test mode ran fully isolated from AWS/MQTT and
//             deliberately recorded no pass/fail result anywhere ("no
//             EOL-pass NVS stamp" — see v1.0.8 notes below). That meant
//             normal firmware had no way to know whether a unit had ever
//             been certified. This version adds that missing record and
//             surfaces it once the unit is back on AWS.
//
//             New NVS namespace "eol_cfg":
//               cert_state   — 0=NOT_RUN, 1=FAILED, 2=PASSED (uint8_t)
//               fail_count   — count of EOL_FAIL items on the qualifying run
//               last_run_ts  — RTC ISO timestamp of that run (or
//                              "RTC_INVALID"/"RTC_READ_ERR")
//
//             Written at the end of eolRunTestSequence() (still fully local,
//             no AWS/MQTT dependency — EOL mode's independence from
//             connectivity is unchanged). A run "PASSES" certification if
//             none of its items came back EOL_FAIL; EOL_SKIP (e.g. MODEM_CHECK
//             with no SIM installed yet) and EOL_INFO items do not block
//             certification, matching the existing pass/fail/skip semantics
//             each test routine already used.
//
//             EOL mode remains reentrant — running it again simply
//             overwrites the previous cert_state, exactly like every other
//             EOL result already worked. There is still no permanent
//             lockout; this only adds a persisted record of the *last*
//             result, not a one-time stamp.
//
//   [EOLCERT] Normal (non-EOL) firmware now loads this record at boot
//             (loadEolCertification(), called alongside loadCalState() —
//             before the EOL jumper check, same as every other piece of
//             state the EOL report already displays) and:
//               - includes "eol_status" in every publishFullStatus() payload,
//                 via the same eolCertStatusStr() shared-mapper pattern used
//                 for voltage/fault/valve state, so status topic and shadow
//                 can never drift on wording
//               - on a successful MQTT connect, if the unit is not currently
//                 EOL_CERT_PASSED, publishes a "NOT_EOL_TESTED" event (event
//                 topic) and an "eol_status" shadow field — ONCE PER BOOT,
//                 gated by the eolNotTestedAnnounced flag, so a unit left
//                 uncertified for an extended period doesn't re-announce
//                 this on every reconnect. (CAL_INCOMPLETE/POSITION_UNCERTAIN
//                 above do not have this gate and still announce on every
//                 connect — left unchanged since those are rarer,
//                 self-resolving conditions rather than a long-lived state.)
//
//             eolCertStatusStr() values: "CERTIFIED", "EOL_TEST_FAILED",
//             "NOT_EOL_TESTED" — chosen to match the terminology already
//             used for the equivalent LoRa-node-side event
//             (EVT_NOT_EOL_TESTED) in the Orb Drive gateway/node protocol,
//             even though this cellular-direct node has no LoRa wire
//             protocol of its own — the mobile/web app can display a
//             single consistent vocabulary ("EOL Test Pending" / "Not EOL
//             Certified" / etc.) across both device families.
//
//             This is a status signal only — no motor/valve behavior is
//             gated on cert_state. A never-certified unit still operates
//             normally; the goal is visibility for commissioning/maintenance
//             workflows, not a lockout.
//
//   [VER]   FW_VERSION bumped to aws-1.1.0
//
// ============================================================
// v1.0.9 CHANGES — Autonomous Emergency Bypass Close + Shadow Consistency:
//
//   [BYPASS]  Emergency autonomous valve close after LOW_VOLTAGE_BYPASS
//             timeout when no operator response (BYPASS_Y / BYPASS_N via
//             F/R/S "Y"/"N" bypass prompt) is received within 2 minutes.
//
//             Sequence:
//               CUT_V crossed while motor running -> stopMotor(), vState=
//               WAIT_BYPASS, bypassWaitStart=millis(), event "CUT" published.
//               Operator has BYPASS_TIMEOUT_MS (120000 ms / 2 min) to send
//               Y (continue under bypass) or N (abandon, return to WARNING).
//               If no response within the window:
//                 - event BYPASS_TIMEOUT_AUTO_CLOSE published (if connected)
//                 - vState forced to BYPASS_ACTIVE (suppresses CUT_V re-trip
//                   so the forced close is not immediately re-interrupted)
//                 - startMotor(REVERSE_RUN) forces the valve CLOSED,
//                   regardless of what direction was interrupted
//               This is independent of MQTT/LTE connectivity — the timeout
//               and the close both run entirely on local timers/sensors.
//
//   [EMERGENCY] Autonomous emergency actions are persisted to NVS
//             ("emergency" namespace) at the moment the firmware decides
//             to act — before the motor is commanded — so the record
//             survives a reboot at any point during or after the close.
//             Record: reason, mqtt_conn (connectivity AT TRIGGER),
//             valve_pos (totalTurns), battery_v, trigger_ts (RTC ISO,
//             or literal "RTC_INVALID"/"RTC_READ_ERR" if RTC unavailable).
//
//             Replay: emergencyPublishIfPending() is called (a) immediately
//             after a successful MQTT connect in connectMQTT(), and (b)
//             every EMERGENCY_RETRY_MS (30 s) while already connected, in
//             case the connect succeeded but the publish itself failed
//             (broker hiccup, buffer limits, transient network condition —
//             a successful mqtt.connect() does not guarantee publish()
//             reaches the broker). NVS record is cleared ONLY after
//             publish() returns true. If the same event is republished
//             twice due to a lost ack, the duplicate carries identical
//             device_id + trigger_time + reason and is straightforward to
//             recognize/dedupe downstream. Design principle: never lose an
//             emergency report; a duplicate is an acceptable tradeoff.
//
//             Also applies if startMotor(REVERSE_RUN) itself is rejected
//             by a safety guard (lockFault/i2cFault/encFault/position
//             uncertain) — the emergency record is still saved and
//             published (valve_state will correctly read IDLE, and
//             fault will correctly show the blocking condition), so the
//             cloud is never left silently guessing whether a shadow
//             update was lost, the firmware crashed, or the close was
//             rejected.
//
//   [SHADOW] AWS Device Shadow ($aws/things/<id>/shadow/update) is now
//             updated via a generic publishShadowReported(JsonObject)
//             helper at every meaningful state transition (bypass timeout
//             close-commanded, voltage genuinely recovered, emergency
//             replay). Shadow always reflects CURRENT device state, never
//             commanded/future state — e.g. valve_state is only published
//             as "CLOSING" from the actual RAMP_BYPASS->RAMP_RUNNING
//             transition in handleMotorRamp() (where motorState truly
//             becomes REVERSE_RUN), not from the moment startMotor() is
//             merely called. Event topic remains the sole historical/event
//             log; shadow is state-only (voltage_status, bypass_active,
//             fault, valve_state, last_event).
//
//   [STATUS] Consolidated three previously-duplicated string mappings
//             (voltage status switch, fault if/else chain, and a new
//             valve motion string) into shared helpers voltageStatusStr(),
//             faultStatusStr(), valveStateStr(). Both publishFullStatus()
//             (status topic) and all shadow publishes now source these
//             strings from the same functions, so the two topics cannot
//             drift apart on wording. faultStatusStr() still returns "OK"
//             for no-fault (unchanged from shipped v1.0.8 status-topic
//             vocabulary — NOT changed to "NONE", to avoid a breaking
//             change for existing dashboards/rules).
//
//   [VER]   FW_VERSION bumped to aws-1.0.9
//
// ============================================================
// v1.0.8 CHANGES — Factory EOL (End-Of-Line) Test Mode:
//
//   [EOL]   Local WiFi-AP-hosted manufacturing test, fully independent of
//             AWS/MQTT/cellular. Entered by pulling GPIO45 LOW at boot
//             (factory test-jig jumper; same pin previously documented as
//             "push button — no FW handling", now repurposed for EOL entry).
//
//             Boot sequence:
//               GPIO45 LOW at boot → skip LTE/MQTT entirely → start WiFi AP
//               "VALVE-EOL-<last 4 hex of chip ID>", open (no password) →
//               start HTTP server on 192.168.4.1 → run test sequence once →
//               serve results as an HTML report → technician's laptop
//               connects to the AP and views results in a browser.
//
//             Test sequence (each produces PASS / FAIL / SKIP):
//               1. I2C_SCAN     — INA226 / AS5600 / PCF8563 detected + address
//               2. RTC_CHECK    — write known time, read back, compare
//               3. ENCODER_READ — raw angle + AGC value (magnet alignment)
//               4. MOTOR_FWD    — 2 s soft-start pulse, checks encoder moved
//                                 (>0.05 turns) and current stayed < CURRENT_OFF
//               5. MOTOR_REV    — same checks, reverse direction
//               6. LIMIT_SWITCH — reports current state (operator may toggle
//                                 manually during the test window)
//               7. BATTERY_V    — INA226 bus voltage, flagged if outside
//                                 11.0–14.6 V (4S LiFePO4 safe range)
//               8. BUZZER       — audible beep, informational only (no P/F)
//               9. MODEM_CHECK  — PWRKEY pulse + AT ping; SKIP (not FAIL) if
//                                 no response, since SIM/antenna may not yet
//                                 be installed at this assembly stage
//
//             Existing NVS state (position, calibration, fault history) is
//             preserved and displayed in the report, not wiped — diagnostic
//             value matters more for a returned unit than a clean slate.
//             EOL mode is reentrant: any unit can be retested at any time
//             by pulling GPIO45 LOW at boot. There is no permanent lockout
//             and no EOL-pass NVS stamp that disables future entry.
//
//             A "Reboot to normal mode" button on the report page calls
//             ESP.restart(); the firmware then re-checks GPIO45 — removing
//             the jumper before reboot returns the unit to normal AWS operation.
//
//   [VER]   FW_VERSION bumped to aws-1.0.8
//
// PIN MAP ADDITION:
//   GPIO45  EOL test jumper (pull LOW at boot to enter EOL mode)
//             *** Previously documented as "Push Button — no FW handling" ***
//
//   [CAL]   Previous single-command CALIBRATE replaced with a three-command
//             operator-driven field calibration sequence.  The firmware never
//             moves the valve autonomously — the operator drives it manually
//             via normal F/R/S commands and sends calibration markers at each
//             physical endpoint.
//
//           Calibration state machine (persisted in NVS "cal_state"):
//
//             CAL_IDLE
//               │  CALIBRATE_CLOSED  (1st send — enter cal mode)
//               ▼
//             CAL_AWAITING_CLOSED
//               │  F/R/S commands still accepted — operator drives to closed stop
//               │  CALIBRATE_CANCEL → restore previous endpoints → CAL_IDLE
//               │  CALIBRATE_CLOSED  (2nd send — record closed position)
//               ▼
//             CAL_CLOSED_SET
//               │  rotationCount=0, totalTurns=0, MIN_TURNS=0 saved to NVS
//               │  Publishes CAL_CLOSED_SET {turns:0}
//               │  Previous MAX_TURNS backed up to NVS "max_turns_bak"
//               │  F/R/S commands still accepted — operator drives to open stop
//               │  CALIBRATE_CANCEL → restore backup endpoints → CAL_IDLE
//               │  CALIBRATE_OPEN (single send — record open position)
//               ▼
//             CAL_COMPLETE  (transient — immediately returns to CAL_IDLE)
//               │  MAX_TURNS = totalTurns, MIN_TURNS = 0
//               │  positionConfident = HIGH
//               │  Saves all to NVS
//               │  Publishes CAL_COMPLETE {closed:0, open:X.XX, duration_ms:...}
//               ▼
//             CAL_IDLE
//
//           Safety rules during calibration:
//             - Motor guards (voltage, current, I2C, encoder) all still active
//             - CALIBRATE_OPEN rejected if not in CAL_CLOSED_SET state
//             - If device reboots in CAL_AWAITING_CLOSED or CAL_CLOSED_SET:
//                 motor is blocked, CAL_INCOMPLETE published on MQTT connect
//                 operator must send CALIBRATE_CLOSED (restart) or CALIBRATE_CANCEL
//             - Double-tap on CALIBRATE_CLOSED prevents accidental zero at wrong pos:
//                 first send = enter mode, second send = confirm and record
//
//           New MQTT commands:
//             CALIBRATE_CLOSED  {"cmd":"CALIBRATE_CLOSED","device_id":"..."}
//             CALIBRATE_OPEN    {"cmd":"CALIBRATE_OPEN",  "device_id":"..."}
//             CALIBRATE_CANCEL  {"cmd":"CALIBRATE_CANCEL","device_id":"..."}
//
//           Removed commands (replaced by above):
//             CALIBRATE, SET_MIN_TURNS, CONFIRM_POSITION
//             (CONFIRM_POSITION absorbed — completing calibration sets confidence)
//
//           MIN_TURNS fixed at 0.0 after calibration — closed stop is the
//           absolute zero reference.  The 1.0-turn safety margin from v1.0.5
//           is removed; the physical closed stop is the authoritative limit.
//
//   [VER]   FW_VERSION bumped to aws-1.0.7
//
//   [APN]   APN loaded from NVS instead of hardcoded "iot.com"
//             Key "apn" in "aws_creds" NVS namespace (same namespace
//             as TLS certs — provisioning sketch writes it once).
//             Fallback: compile-time DEFAULT_APN if NVS key absent.
//             New MQTT command: SET_APN {"cmd":"SET_APN","apn":"..."}
//             Saves to NVS, takes effect on next LTE init or reboot.
//             Current APN included in publishFullStatus() payload.
//
//   [MDM]   Modem changed from Quectel BG96 to SIMCom A7670C
//             TinyGSM modem type: TINY_GSM_MODEM_A7670C
//             PWRKEY pin: GPIO46 (MODEM_PWRKEY) — confirm vs schematic
//             Power-on sequence:
//               Pull PWRKEY LOW for 1500 ms → HIGH → wait 5 s for AT ready
//             Power-off sequence:
//               Send AT+CPOF (graceful) → wait for "NORMAL POWER DOWN" URC
//               If URC not seen in 5 s: pulse PWRKEY LOW 3 s (hard off)
//             Wake from deep sleep: PWRKEY pulse in setup() restores modem
//             AT+CREG changed to AT+CREG? (A7670C response format unchanged)
//             Ping command: AT+CPING instead of AT+QPING
//             Baud rate: 115200 (same)
//
//   [SLP]   Sleep idle timeout configurable, not hardcoded at 10 s
//             Default: 300 000 ms (5 minutes) — appropriate for municipal
//             NVS key "sleep_timeout_ms" in "device_cfg" namespace
//             New MQTT command: SET_SLEEP_TIMEOUT {"cmd":"SET_SLEEP_TIMEOUT",
//               "value":300000}  (range: 30 000 – 3 600 000 ms)
//             Keep-awake window: any MQTT command received resets a
//             keepAwakeTimer; device will not sleep for KEEP_AWAKE_MS
//             (60 s) after the last command, giving operator time to
//             send follow-up commands without the device sleeping mid-session.
//
//   [CAL]   Calibration edge cases fixed
//             After CALIBRATE, MIN_TURNS remains as a relative safety margin.
//             If calibration is performed near the physical closed stop
//             (i.e. position was < MIN_TURNS before calibration), the reverse
//             block would trigger immediately after zeroing. Fixed by:
//               - New configurable MIN_TURNS (was fixed 1.0)
//               - New MQTT command: SET_MIN_TURNS {"cmd":"SET_MIN_TURNS",
//                 "value":1.0}  (range: 0.0 – 5.0)
//               - After CALIBRATE, CAL_DONE payload includes new zero and
//                 current MIN_TURNS so operator can verify margin is sensible
//               - CALIBRATE also accepts optional "min_turns" field to
//                 atomically reset the margin at the same time as zeroing
//
//   [WDT]   Application watchdog added
//             esp_task_wdt used with 60 s timeout on main loop task.
//             WDT is fed in FW_ACTIVE loop tick (normal operation).
//             LTE init: separate LTE_INIT_TIMEOUT_MS (120 s); if exceeded,
//               modem is power-cycled via PWRKEY and LTE init restarts.
//             MQTT: if not connected for MQTT_DEAD_MS (180 s) after LTE ready,
//               full modem power-cycle + LTE reinit triggered.
//             I2C: existing fail-count recovery unchanged; if recovery fails
//               3× consecutive times, ESP.restart() is called (last resort).
//             WDT is suspended during OTA flash (expected long operation).
//
//   [VER]   FW_VERSION bumped to aws-1.0.5
//
// PIN MAP — ESP32-S3 PCB (GPIO46 added for A7670C PWRKEY):
//   GPIO40  K1 Relay FWD,    GPIO41  K2 Relay REV,   GPIO42  K3 Relay PWR
//   GPIO36  Soft Start PWM,  GPIO8   I2C SDA,         GPIO9   I2C SCL
//   GPIO2   INA226 Alert,    GPIO19  Limit Switch
//   GPIO43  LTE UART TX,     GPIO44  LTE UART RX
//   GPIO46  A7670C PWRKEY    *** NEW — verify vs schematic ***
//   GPIO48  Buzzer,          GPIO1   VBAT ADC
//   GPIO4   RTC Interrupt    (EXT0 deep-sleep wakeup)
//   GPIO20  Flow Pulse (reserved), GPIO45 Push Button (HW reset)
// =========================================================




#include <Wire.h>
#include <INA226_WE.h>
#include <Preferences.h>
#include <Update.h>
#include <ArduinoJson.h>
#include <mbedtls/sha256.h>
#include <esp_sleep.h>
#include <esp_system.h>
#include <esp_task_wdt.h>
#include <WiFi.h>
#include <WebServer.h>
#define TINY_GSM_MODEM_A7670C
#include <TinyGsmClient.h>
#include <PubSubClient.h>




HardwareSerial SerialAT(1);
TinyGsm        modem(SerialAT);
TinyGsmClientSecure gsmClient(modem, 0);
TinyGsmClientSecure otaClient(modem, 1);
PubSubClient   mqtt(gsmClient);




// ================== FIRMWARE VERSION ==================
