// ================== UNIFIED SLEEP GUARD ==================
bool safeToSleep() {
  return (motorState == IDLE      &&
          rampState  == RAMP_IDLE &&
          !resumePending          &&
          !isRetryActive());
}




// ================== HELPERS ==================
float getVoltage() { return ina226 ? ina226->getBusVoltage_V() : 0.0f; }
float getCurrent() { return ina226 ? abs(ina226->getCurrent_mA()) / 1000.0f : 0.0f; }

String getDeviceID() {
  prefs.begin("aws_creds", true);
  String id = prefs.getString("device_id", "");
  prefs.end();
  if (id.length() > 0) return id;
  uint64_t chipid = ESP.getEfuseMac();
  char buf[28];
  sprintf(buf, "ESP32S3-%04X%08X", (uint16_t)(chipid >> 32), (uint32_t)chipid);
  return String(buf);
}

// [SLP] Called by every MQTT command handler to reset the keep-awake window
void touchKeepAwake() {
  keepAwakeTimer  = millis();
  keepAwakeActive = true;
}




// ================== [STATUS] SHARED STATE-STRING MAPPERS ==================
// Single source of truth for every derived state string. Used identically
// by publishFullStatus() (status topic) and every publishShadowReported()
// call site (shadow topic) so the two can never drift apart on wording.

const char* voltageStatusStr() {
  switch (vState) {
    case NORMAL:        return "NORMAL";
    case WARNING:       return "WARNING";
    case WAIT_BYPASS:   return "LOW_VOLTAGE_CUT";
    case BYPASS_ACTIVE: return "BYPASS_ACTIVE";
    case LOCKED:        return "CRITICAL_LOCK";
  }
  return "UNKNOWN";
}

// NOTE: kept as "OK" (not "NONE") to match the value publishFullStatus()
// already emits on the status topic in shipped v1.0.8 — changing this
// string would be a breaking change for existing dashboards/rules.
const char* faultStatusStr() {
  if      (lockFault)          return "CURRENT_LOCK";
  else if (vState==LOCKED)     return "VOLTAGE_LOCK";
  else if (i2cFault)           return "I2C_FAULT";
  else if (encFault)           return "ENC_FAULT";
  else if (calInProgress())    return "CAL_IN_PROGRESS";
  else if (!positionConfident) return "POSITION_UNCERTAIN";
  else                          return "OK";
}

// Valve motion state — distinct from voltage/fault state. Reads motorState
// ONLY (current, actual state) — deliberately does NOT inspect rampState/
// rampDir/commanded intent, so it can never report a future/commanded state
// before that state is genuinely true.
const char* valveStateStr() {
  if      (motorState==FORWARD_RUN) return "OPENING";
  else if (motorState==REVERSE_RUN) return "CLOSING";
  else                                return "IDLE";
}

// [EOLCERT] Shared mapper for EOL certification status — same
// single-source-of-truth pattern as voltageStatusStr()/faultStatusStr()/
// valveStateStr() above. Sourced from eolCertState, which is loaded from
// NVS "eol_cfg" at boot (loadEolCertification()) and written only at the
// end of a completed EOL test run (saveEolCertification(), called from
// eolRunTestSequence() in the [EOL] section).
const char* eolCertStatusStr() {
  switch (eolCertState) {
    case EOL_CERT_PASSED: return "CERTIFIED";
    case EOL_CERT_FAILED: return "EOL_TEST_FAILED";
    default:               return "NOT_EOL_TESTED";
  }
}

// Loads the last EOL run's result. Called once at boot, before the EOL
// jumper check, so the EOL report page can also show "previous result"
// immediately on entry (see eolBuildReportHTML()).
void loadEolCertification() {
  prefs.begin("eol_cfg", true);
  eolCertState = (EolCertState)prefs.getUChar("cert_state", (uint8_t)EOL_CERT_NOT_RUN);
  prefs.end();
  Serial.printf("🏭 EOL CERTIFICATION (loaded): %s\n", eolCertStatusStr());
}

// Persists the result of a completed EOL run. Called ONLY from
// eolRunTestSequence() — still fully local/offline, no AWS/MQTT dependency,
// consistent with the rest of EOL mode's independence from connectivity.
// Reentrant: re-running EOL simply overwrites the previous record, exactly
// like every other EOL result already worked (no permanent lockout).
void saveEolCertification(EolCertState state, int failCount) {
  prefs.begin("eol_cfg", false);
  prefs.putUChar("cert_state", (uint8_t)state);
  prefs.putInt("fail_count", failCount);
  prefs.putString("last_run_ts", getTimestamp());
  prefs.end();
  eolCertState = state;
  Serial.printf("🏭 EOL CERTIFICATION (saved): %s (fail_count=%d)\n", eolCertStatusStr(), failCount);
}




// ================== [SHADOW] DEVICE SHADOW REPORTED-STATE HELPER ==================
// Generic reported-state publisher for ALL "state changed" call sites
// (bypass timeout, emergency replay, and any future state-change event).
// Caller fills a JsonObject with whatever reported keys changed — AWS IoT
// shadow does a partial merge on "reported", it does NOT overwrite
// unmentioned keys. One schema, one code path, everywhere. Shadow reflects
// CURRENT device state only — never commanded/future/intended state.
// [SHADOWDIFF] Cache of the last successfully published "reported" values,
// keyed by field name. Every publishShadowReported() call is now diffed
// against this cache — only fields whose value actually changed are sent,
// and if nothing in the call changed, the publish is skipped entirely.
// Sized generously (640 bytes) since this accumulates every distinct key
// ever reported across the firmware's lifetime (voltage_status,
// bypass_active, fault, valve_state, last_event, eol_status, and any
// future additions), not just one call site's fields.
StaticJsonDocument<640> shadowLastReported;

void publishShadowReported(JsonObject fields) {
  if (!mqtt.connected()) return;

  StaticJsonDocument<320> changedDoc;
  JsonObject changed = changedDoc.to<JsonObject>();
  bool anyChanged = false;

  for (JsonPair kv : fields) {
    JsonVariantConst newVal = kv.value();
    JsonVariantConst oldVal = shadowLastReported[kv.key()];
    bool same = (!oldVal.isNull()) && (oldVal == newVal);
    if (!same) {
      changed[kv.key()] = newVal;
      shadowLastReported[kv.key()] = newVal;   // update cache with the new value
      anyChanged = true;
    }
  }

  if (!anyChanged) {
    Serial.println("📤 SHADOW: no changed fields — publish skipped");
    return;
  }

  StaticJsonDocument<320> doc;
  JsonObject state    = doc.createNestedObject("state");
  JsonObject reported = state.createNestedObject("reported");
  for (JsonPair kv : changed) reported[kv.key()] = kv.value();
  String out; serializeJson(doc, out);
  mqtt.publish(shadowUpdateTopic.c_str(), out.c_str(), false, 1);
  Serial.print("📤 SHADOW: "); Serial.println(out);
}




// ================== [EMERGENCY] OFFLINE EMERGENCY ACTION RECORD ==================
// Survives reboot and arbitrary MQTT/LTE outage length. Written at the moment
// the firmware autonomously decides to act — BEFORE the motor is commanded —
// and replayed to the cloud the next time a connection is available. NVS
// namespace "emergency" — isolated from "device_cfg" since this is a rare,
// safety-relevant record, not routine config.
//
// Design principle: never lose an emergency event. A duplicate report
// (e.g. from a lost PUBACK triggering a retry of an already-delivered
// message) is an acceptable tradeoff — it carries the same device_id +
// trigger_time + reason and is straightforward to recognize/dedupe
// downstream if the backend is ever enhanced to do so.

void emergencySaveTrigger(const char* reason) {
  prefs.begin("emergency", false);
  prefs.putUChar("pending", 1);
  prefs.putString("reason", reason);
  prefs.putUChar("mqtt_conn", mqtt.connected() ? 1 : 0);   // connectivity AT TRIGGER
  prefs.putFloat("valve_pos", totalTurns);
  prefs.putFloat("battery_v", getVoltage());
  prefs.putString("trigger_ts", getTimestamp());           // may read "RTC_INVALID"/"RTC_READ_ERR"
  prefs.end();
  emergencyPending = true;
  Serial.printf("💾 EMERGENCY TRIGGER SAVED: reason=%s mqtt=%s v=%.2f pos=%.2f\n",
                reason, mqtt.connected()?"UP":"DOWN", getVoltage(), totalTurns);
}

bool emergencyHasPending() {
  prefs.begin("emergency", true);
  bool pending = prefs.getUChar("pending", 0) == 1;
  prefs.end();
  return pending;
}

void emergencyClearPending() {
  prefs.begin("emergency", false);
  prefs.putUChar("pending", 0);
  prefs.end();
  emergencyPending = false;
  Serial.println("✅ EMERGENCY PENDING CLEARED");
}

// Called from connectMQTT() right after a successful connection, AND from
// the FW_ACTIVE periodic retry — a successful mqtt.connect() does not
// guarantee the first publish() reaches the broker (buffer limits,
// transient broker issues), so this must be retriable independent of the
// connect event itself.
void emergencyPublishIfPending() {
  if (!emergencyHasPending()) return;
  if (!mqtt.connected())      return;

  prefs.begin("emergency", true);
  String reason    = prefs.getString("reason", "UNKNOWN");
  bool   mqttWasUp = prefs.getUChar("mqtt_conn", 0) == 1;
  float  valvePos  = prefs.getFloat("valve_pos", totalTurns);
  float  battV     = prefs.getFloat("battery_v", getVoltage());
  String trigTs    = prefs.getString("trigger_ts", "");
  prefs.end();

  StaticJsonDocument<256> doc;
  doc["device_id"]         = DEVICE_ID;
  doc["event"]              = "EMERGENCY_AUTO_CLOSE";
  doc["reason"]              = reason;
  doc["trigger_time"]       = trigTs;
  doc["executed_offline"]   = !mqttWasUp;
  doc["operator_response"]  = false;
  doc["mqtt_available"]     = mqttWasUp;
  doc["valve_position"]     = valvePos;
  doc["battery_voltage"]    = battV;
  String out; serializeJson(doc, out);
  bool ok = mqtt.publish(pubEventTopic.c_str(), out.c_str(), false, 1);

  if (ok) {
    Serial.print("📤 EMERGENCY EVENT: "); Serial.println(out);
    // [SHADOW] reflect it as current state too, not just an event
    StaticJsonDocument<192> fields;
    fields["last_event"]     = "EMERGENCY_AUTO_CLOSE";
    fields["bypass_active"]  = false;   // the bypass window itself is long over by reconnect
    fields["voltage_status"] = voltageStatusStr();
    fields["fault"]          = faultStatusStr();
    fields["valve_state"]    = valveStateStr();
    publishShadowReported(fields.as<JsonObject>());
    emergencyClearPending();
  } else {
    Serial.println("⚠️ EMERGENCY EVENT publish failed — retry on next connect/tick");
    // pending intentionally left set — same fire-and-forget QoS1 pattern
    // used everywhere else in this firmware; no ack tracking exists yet.
  }
}




// ================== [TLS] CREDENTIAL LOADER ==================
bool loadAndApplyTLSCredentials() {
  Serial.println("🔐 Loading TLS credentials...");
  prefs.begin("aws_creds", true);
  awsEndpoint = prefs.getString("endpoint", "");
  awsCert     = prefs.getString("cert",     "");
  awsPkey     = prefs.getString("pkey",     "");
  awsRootCA   = prefs.getString("rootca",   "");
  prefs.end();
  if (awsEndpoint.length()==0){Serial.println("❌ TLS: endpoint missing");    return false;}
  if (awsCert.length()    ==0){Serial.println("❌ TLS: cert missing");        return false;}
  if (awsPkey.length()    ==0){Serial.println("❌ TLS: private key missing"); return false;}
  if (awsRootCA.length()  ==0){Serial.println("❌ TLS: root CA missing");     return false;}
  gsmClient.setCACert(awsRootCA.c_str()); gsmClient.setCertificate(awsCert.c_str());
  gsmClient.setPrivateKey(awsPkey.c_str());
  otaClient.setCACert(awsRootCA.c_str()); otaClient.setCertificate(awsCert.c_str());
  otaClient.setPrivateKey(awsPkey.c_str());
  Serial.println("✅ TLS credentials applied");
  Serial.print("🌐 Endpoint: "); Serial.println(awsEndpoint);
  return true;
}




// ================== [I2C-REC] BUS RECOVERY ==================
void recoverI2C() {
  Serial.println("🔧 I2C RECOVERY");
  pinMode(SDA_PIN, INPUT_PULLUP); pinMode(SCL_PIN, OUTPUT);
  for (int i=0; i<9; i++) {
    digitalWrite(SCL_PIN, HIGH); delayMicroseconds(5);
    digitalWrite(SCL_PIN, LOW);  delayMicroseconds(5);
    if (digitalRead(SDA_PIN)==HIGH) { Serial.printf("✅ SDA released after %d pulses\n",i+1); break; }
  }
  pinMode(SDA_PIN, OUTPUT);
  digitalWrite(SDA_PIN, LOW);  delayMicroseconds(5);
  digitalWrite(SCL_PIN, HIGH); delayMicroseconds(5);
  digitalWrite(SDA_PIN, HIGH); delayMicroseconds(5);
  Wire.begin(SDA_PIN, SCL_PIN);
  Serial.println("🔧 I2C reinitialised");
}




// ================== [SENSOR] HEALTH CHECK ==================
String checkINA226str() {
  if (inaAddr==0x00) return "NO_ADDR";
  if (!i2cAck(inaAddr)) return "NO_ACK";
  if (!validateINA226(inaAddr)) return "BAD_ID";
  return "OK";
}

String checkAS5600str() {
  if (encAddr==0x00) return "NO_ADDR";
  if (!i2cAck(encAddr)) return "NO_ACK";
  Wire.beginTransmission(encAddr); Wire.write(0x0B);
  if (Wire.endTransmission(false)!=0) return "NO_ACK";
  Wire.requestFrom(encAddr,(uint8_t)1);
  if (!Wire.available()) return "NO_ACK";
  uint8_t status=Wire.read();
  if (!(status&0x20)) return "NO_MAGNET";
  Wire.beginTransmission(encAddr); Wire.write(0x1A);
  if (Wire.endTransmission(false)!=0) return "NO_ACK";
  Wire.requestFrom(encAddr,(uint8_t)1);
  if (!Wire.available()) return "NO_ACK";
  uint8_t agc=Wire.read();
  if (agc==0||agc==255) return "AGC_SAT";
  return "OK";
}

bool checkSensors() {
  String inaResult=checkINA226str(), encResult=checkAS5600str();
  Serial.printf("🔬 INA226@0x%02X:%s  AS5600@0x%02X:%s\n",
                inaAddr,inaResult.c_str(),encAddr,encResult.c_str());

  bool inaNoAck=(inaResult=="NO_ACK"||inaResult=="NO_ADDR");
  bool encNoAck=(encResult=="NO_ACK"||encResult=="NO_ADDR");
  if (inaNoAck) inaFailCount++; else inaFailCount=0;
  if (encNoAck) encFailCount++; else encFailCount=0;

  if (inaFailCount>=2 || encFailCount>=2) {
    Serial.println("⚠️ CONSECUTIVE NO_ACK — I2C recovery");
    recoverI2C();
    bool redetected=detectHardware();
    inaFailCount=0; encFailCount=0;
    if (redetected && ina226!=nullptr)
      { delete ina226; ina226=new INA226_WE(inaAddr); ina226->init(); configureINAAlert(); }
    inaResult=checkINA226str(); encResult=checkAS5600str();
    bool recovered=(inaResult=="OK"&&encResult=="OK");
    if (!recovered) {
      i2cRecoveryCount++;   // [WDT] count consecutive recovery failures
      Serial.printf("🔴 I2C RECOVERY FAILED (%d/%d)\n", i2cRecoveryCount, I2C_RECOVERY_RESET_THRESHOLD);
      if (i2cRecoveryCount >= I2C_RECOVERY_RESET_THRESHOLD) {
        Serial.println("🔴 I2C RECOVERY THRESHOLD — ESP.restart()");
        if (mqtt.connected()) {
          StaticJsonDocument<96> e; e["device_id"]=DEVICE_ID; e["event"]="I2C_HARD_RESET";
          String o; serializeJson(e,o); mqtt.publish(pubStatusTopic.c_str(),o.c_str(),false,1); delay(200);
        }
        ESP.restart();
      }
      if (!i2cFault) {
        i2cFault=true;
        if (mqtt.connected()) {
          StaticJsonDocument<160> doc;
          doc["device_id"]=DEVICE_ID; doc["i2c_event"]="I2C_RECOVERY_FAIL";
          doc["ina226"]=inaResult; doc["as5600"]=encResult;
          String out; serializeJson(doc,out);
          mqtt.publish(pubStatusTopic.c_str(),out.c_str(),false,1);
        }
      }
    } else {
      i2cRecoveryCount=0;
      if (i2cFault) {
        i2cFault=false; publishHWProfile();
        if (mqtt.connected()) {
          StaticJsonDocument<96> doc; doc["device_id"]=DEVICE_ID; doc["i2c_event"]="I2C_RECOVERED";
          String out; serializeJson(doc,out); mqtt.publish(pubStatusTopic.c_str(),out.c_str(),false,1);
        }
      }
    }
  } else if (i2cFault&&inaResult=="OK"&&encResult=="OK") {
    i2cFault=false; i2cRecoveryCount=0;
    if (mqtt.connected()) {
      StaticJsonDocument<96> doc; doc["device_id"]=DEVICE_ID; doc["i2c_event"]="I2C_RECOVERED";
      String out; serializeJson(doc,out); mqtt.publish(pubStatusTopic.c_str(),out.c_str(),false,1);
    }
  }

  if (mqtt.connected()) {
    StaticJsonDocument<192> doc;
    doc["device_id"]=DEVICE_ID; doc["ina226"]=inaResult; doc["as5600"]=encResult;
    char buf[8];
    snprintf(buf,sizeof(buf),"0x%02X",inaAddr); doc["ina_addr"]=String(buf);
    snprintf(buf,sizeof(buf),"0x%02X",encAddr); doc["enc_addr"]=String(buf);
    String out; serializeJson(doc,out);
    mqtt.publish(pubStatusTopic.c_str(),out.c_str(),false,1);
  }
  return (inaResult=="OK"&&encResult=="OK");
}




// ================== [INA ALERT] ==================
void configureINAAlert() {
  if (inaAddr==0x00) return;
  uint16_t alertLimit=(uint16_t)((CURRENT_OFF*1000.0*10.0)/2.5);
  Wire.beginTransmission(inaAddr); Wire.write(0x07);
  Wire.write((alertLimit>>8)&0xFF); Wire.write(alertLimit&0xFF); Wire.endTransmission();
  Wire.beginTransmission(inaAddr); Wire.write(0x06);
  Wire.write(0x80); Wire.write(0x00); Wire.endTransmission();
  Serial.printf("⚡ INA226@0x%02X alert: %.2fA\n",inaAddr,CURRENT_OFF);
}




// ================== [POS] STORAGE ==================
void savePosition() {
  prefs.begin("encoder", false);
  prefs.putLong("rot", rotationCount);
  prefs.putInt("angle", angle);
  prefs.putBool("pos_conf", true);
  prefs.end();
  positionConfident=true;
  Serial.println("💾 POSITION SAVED (confidence HIGH)");
}

void loadPosition() {
  prefs.begin("encoder", true);
  rotationCount     = prefs.getLong("rot", 0);
  angle             = prefs.getInt("angle", 0);
  positionConfident = prefs.getBool("pos_conf", false);
  prefs.end();
  prevAngle  = angle;
  totalTurns = rotationCount + (angle / 4096.0);
  if (positionConfident)
    Serial.printf("📂 POSITION: %.2f turns (HIGH confidence)\n", totalTurns);
  else
    Serial.printf("⚠️ POSITION: %.2f turns (LOW confidence — send CALIBRATE_CLOSED or CONFIRM_POSITION)\n", totalTurns);
}




// ================== [CAL] FIELD CALIBRATION STATE MACHINE ==================
//
// CalState persisted in NVS "device_cfg" / "cal_state" so a power loss
// mid-sequence is detected on the next boot and the motor is blocked until
// the operator restarts or cancels calibration.
//
// CAL_IDLE            → normal operation
// CAL_AWAITING_CLOSED → 1st CALIBRATE_CLOSED received; operator driving to closed stop
// CAL_CLOSED_SET      → 2nd CALIBRATE_CLOSED received; closed zero recorded;
//                        operator driving to open stop
//
// Transitions to CAL_COMPLETE are transient — state immediately returns to
// CAL_IDLE after saving to NVS and publishing CAL_COMPLETE.

enum CalState { CAL_IDLE, CAL_AWAITING_CLOSED, CAL_CLOSED_SET };
CalState calState = CAL_IDLE;

unsigned long calStartMs = 0;   // timestamp of CALIBRATE_CLOSED (1st send)

void saveCalState(CalState s) {
  prefs.begin("device_cfg", false);
  prefs.putUChar("cal_state", (uint8_t)s);
  prefs.end();
}

void loadCalState() {
  prefs.begin("device_cfg", true);
  calState = (CalState)prefs.getUChar("cal_state", (uint8_t)CAL_IDLE);
  prefs.end();
  if (calState != CAL_IDLE) {
    Serial.printf("⚠️ CAL STATE ON BOOT: %s — motor blocked until CALIBRATE_CLOSED or CALIBRATE_CANCEL\n",
                  calState == CAL_AWAITING_CLOSED ? "CAL_AWAITING_CLOSED" : "CAL_CLOSED_SET");
  }
}

// Returns true if calibration is in progress (motor block condition)
bool calInProgress() { return calState != CAL_IDLE; }

// Publish calibration incomplete warning — called on MQTT connect if cal was
// interrupted by a reboot between the two CALIBRATE_CLOSED sends or before
// CALIBRATE_OPEN was received.
void publishCalIncomplete() {
  if (!mqtt.connected()) return;
  StaticJsonDocument<192> doc;
  doc["device_id"] = DEVICE_ID;
  doc["cal_event"] = "CAL_INCOMPLETE";
  doc["cal_state"] = calState == CAL_AWAITING_CLOSED ? "AWAITING_CLOSED" : "CLOSED_SET";
  doc["ts"]        = getTimestamp();
  doc["action"]    = "Send CALIBRATE_CLOSED to restart or CALIBRATE_CANCEL to abort";
  String out; serializeJson(doc, out);
  mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
  Serial.println("⚠️ CAL_INCOMPLETE published");
}

// ── CALIBRATE_CLOSED handler ──────────────────────────────────────────────
// First call:  enter CAL_AWAITING_CLOSED, inform operator to drive to closed stop
// Second call: record closed position as zero, advance to CAL_CLOSED_SET
void handleCalClosed() {
  if (motorState != IDLE || rampState != RAMP_IDLE) {
    Serial.println("❌ CALIBRATE_CLOSED blocked — motor running");
    if (mqtt.connected()) {
      StaticJsonDocument<128> doc;
      doc["device_id"] = DEVICE_ID; doc["cal_event"] = "CAL_BLOCKED";
      doc["reason"] = "MOTOR_RUNNING"; doc["ts"] = getTimestamp();
      String out; serializeJson(doc, out);
      mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
    }
    return;
  }

  if (calState == CAL_IDLE) {
    // ── First send: enter calibration mode ──
    calState   = CAL_AWAITING_CLOSED;
    calStartMs = millis();
    saveCalState(calState);
    Serial.println("📐 CAL: entered CAL_AWAITING_CLOSED — drive valve to fully closed, then send CALIBRATE_CLOSED again");
    if (mqtt.connected()) {
      StaticJsonDocument<160> doc;
      doc["device_id"] = DEVICE_ID; doc["cal_event"] = "CAL_AWAITING_CLOSED";
      doc["ts"]        = getTimestamp();
      doc["action"]    = "Drive valve to fully closed stop, then send CALIBRATE_CLOSED again";
      String out; serializeJson(doc, out);
      mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
    }
    return;
  }

  if (calState == CAL_AWAITING_CLOSED) {
    // ── Second send: record closed position as zero ──
    // Back up current MAX_TURNS before overwriting, so CALIBRATE_CANCEL can restore it
    prefs.begin("device_cfg", false);
    prefs.putFloat("max_turns_bak", MAX_TURNS);
    prefs.putFloat("min_turns_bak", MIN_TURNS);
    prefs.end();

    // Zero encoder at current physical position (closed stop)
    rotationCount = 0;
    totalTurns    = 0;
    MIN_TURNS     = 0.0f;
    // angle/prevAngle preserved — diff calculation stays continuous
    savePosition();   // saves with HIGH confidence + pos_conf=true

    prefs.begin("device_cfg", false);
    prefs.putFloat("min_turns", MIN_TURNS);
    prefs.end();

    calState = CAL_CLOSED_SET;
    saveCalState(calState);

    Serial.println("📐 CAL: closed stop recorded — totalTurns=0, MIN_TURNS=0");
    Serial.println("📐 CAL: drive valve to fully open, then send CALIBRATE_OPEN");

    if (mqtt.connected()) {
      StaticJsonDocument<160> doc;
      doc["device_id"] = DEVICE_ID; doc["cal_event"] = "CAL_CLOSED_SET";
      doc["turns"]     = totalTurns; doc["min_turns"] = MIN_TURNS;
      doc["ts"]        = getTimestamp();
      doc["action"]    = "Drive valve to fully open stop, then send CALIBRATE_OPEN";
      String out; serializeJson(doc, out);
      mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
    }
    return;
  }

  // calState == CAL_CLOSED_SET — operator may have sent CALIBRATE_CLOSED by mistake
  // Inform them to send CALIBRATE_OPEN instead
  Serial.println("⚠️ CAL: closed already set — send CALIBRATE_OPEN or CALIBRATE_CANCEL");
  if (mqtt.connected()) {
    StaticJsonDocument<160> doc;
    doc["device_id"] = DEVICE_ID; doc["cal_event"] = "CAL_ALREADY_CLOSED";
    doc["ts"]        = getTimestamp();
    doc["action"]    = "Send CALIBRATE_OPEN to record open stop, or CALIBRATE_CANCEL to abort";
    String out; serializeJson(doc, out);
    mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
  }
}

// ── CALIBRATE_OPEN handler ────────────────────────────────────────────────
// Only valid in CAL_CLOSED_SET state.
// Records current totalTurns as MAX_TURNS, completes calibration.
void handleCalOpen() {
  if (calState != CAL_CLOSED_SET) {
    Serial.println("❌ CALIBRATE_OPEN rejected — send CALIBRATE_CLOSED first");
    if (mqtt.connected()) {
      StaticJsonDocument<128> doc;
      doc["device_id"] = DEVICE_ID; doc["cal_event"] = "CAL_OPEN_REJECTED";
      doc["reason"]    = "CLOSED_NOT_SET"; doc["ts"] = getTimestamp();
      String out; serializeJson(doc, out);
      mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
    }
    return;
  }

  if (motorState != IDLE || rampState != RAMP_IDLE) {
    Serial.println("❌ CALIBRATE_OPEN blocked — motor running");
    if (mqtt.connected()) {
      StaticJsonDocument<128> doc;
      doc["device_id"] = DEVICE_ID; doc["cal_event"] = "CAL_BLOCKED";
      doc["reason"]    = "MOTOR_RUNNING"; doc["ts"] = getTimestamp();
      String out; serializeJson(doc, out);
      mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
    }
    return;
  }

  if (totalTurns < 0.5f) {
    // Sanity check: open position must be meaningfully different from closed.
    // Less than half a turn suggests the operator sent CALIBRATE_OPEN without
    // actually driving the valve open — reject to prevent a zero-range cal.
    Serial.printf("❌ CALIBRATE_OPEN rejected — totalTurns=%.2f too small (drive valve open first)\n", totalTurns);
    if (mqtt.connected()) {
      StaticJsonDocument<128> doc;
      doc["device_id"] = DEVICE_ID; doc["cal_event"] = "CAL_OPEN_REJECTED";
      doc["reason"]    = "TURNS_TOO_SMALL"; doc["turns"] = totalTurns; doc["ts"] = getTimestamp();
      String out; serializeJson(doc, out);
      mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
    }
    return;
  }

  // Record open stop
  unsigned long durationMs = millis() - calStartMs;
  MAX_TURNS = totalTurns;
  MIN_TURNS = 0.0f;
  positionConfident = true;

  // Save all calibration results to NVS
  prefs.begin("device_cfg", false);
  prefs.putFloat("max_turns", MAX_TURNS);
  prefs.putFloat("min_turns", MIN_TURNS);
  prefs.putUChar("cal_state", (uint8_t)CAL_IDLE);   // clear cal_state
  prefs.end();
  savePosition();   // saves turns + pos_conf=HIGH

  calState = CAL_IDLE;

  Serial.printf("✅ CAL COMPLETE — closed:0.00 open:%.2f turns, duration:%lums\n",
                MAX_TURNS, durationMs);

  if (mqtt.connected()) {
    StaticJsonDocument<192> doc;
    doc["device_id"]   = DEVICE_ID; doc["cal_event"] = "CAL_COMPLETE";
    doc["closed_turns"] = 0.0f;     doc["open_turns"] = MAX_TURNS;
    doc["min_turns"]   = MIN_TURNS; doc["duration_ms"] = durationMs;
    doc["ts"]          = getTimestamp();
    String out; serializeJson(doc, out);
    mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
  }

  publishFullStatus();
  buzzPattern(3, 100, 120);   // [BUZZ-PATTERN] calibration complete — 3 beeps
}

// ── CALIBRATE_CANCEL handler ──────────────────────────────────────────────
// Restores previous MAX_TURNS and MIN_TURNS from NVS backup.
// If cancel happens after CAL_CLOSED_SET (zero was already written),
// the encoder zero is NOT restored — position is now uncertain.
// Operator must send CONFIRM_POSITION or redo calibration.
void handleCalCancel() {
  if (calState == CAL_IDLE) {
    Serial.println("⚠️ CALIBRATE_CANCEL — no calibration in progress");
    return;
  }

  bool zeroWasWritten = (calState == CAL_CLOSED_SET);

  // Restore backed-up endpoints
  prefs.begin("device_cfg", true);
  float bakMax = prefs.getFloat("max_turns_bak", MAX_TURNS);
  float bakMin = prefs.getFloat("min_turns_bak", MIN_TURNS);
  prefs.end();

  MAX_TURNS = bakMax;
  MIN_TURNS = bakMin;

  prefs.begin("device_cfg", false);
  prefs.putFloat("max_turns", MAX_TURNS);
  prefs.putFloat("min_turns", MIN_TURNS);
  prefs.putUChar("cal_state", (uint8_t)CAL_IDLE);
  prefs.end();

  calState = CAL_IDLE;

  if (zeroWasWritten) {
    // Closed zero was recorded — current position is now unknown relative
    // to the restored MAX_TURNS. Mark as uncertain.
    setPositionConfidence(false);
    Serial.println("⚠️ CAL CANCELLED after zero written — position uncertain");
    Serial.println("   Send CONFIRM_POSITION to accept current position, or redo calibration");
  } else {
    Serial.println("✅ CAL CANCELLED — previous endpoints restored, position unchanged");
  }

  if (mqtt.connected()) {
    StaticJsonDocument<192> doc;
    doc["device_id"]   = DEVICE_ID; doc["cal_event"] = "CAL_CANCELLED";
    doc["max_turns"]   = MAX_TURNS; doc["min_turns"]  = MIN_TURNS;
    doc["pos_confident"] = positionConfident; doc["ts"] = getTimestamp();
    if (zeroWasWritten) doc["warning"] = "Position uncertain — send CONFIRM_POSITION or recalibrate";
    String out; serializeJson(doc, out);
    mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
  }
}




// ================== RETRY ==================
bool isRetryActive() { return (retryCount>0&&retryCount<3&&!lockFault); }




// ================== [RAMP] NON-BLOCKING RAMP HANDLER ==================
void handleMotorRamp() {
  if (rampState==RAMP_IDLE||rampState==RAMP_RUNNING) return;
  unsigned long now=millis();
  switch (rampState) {
    case RAMP_UP:
      if (now-rampTimer>=RAMP_STEP_MS) {
        rampTimer=now; rampDuty+=3; if (rampDuty>255) rampDuty=255;
        ledcWrite(PWM_PIN,rampDuty);
        if (rampDuty>=255){rampSettle=now;rampState=RAMP_BYPASS;}
      } break;
    case RAMP_BYPASS:
      if (now-rampSettle>=RAMP_SETTLE_MS) {
        digitalWrite(RELAY_PWR,RELAY_ON); ledcWrite(PWM_PIN,255);
        motorState=rampDir; lastDirection=rampDir; rampState=RAMP_RUNNING;
        Serial.println("⚡ BYPASS ON — RUNNING");

        // [SHADOW] motorState is now genuinely REVERSE_RUN (or FORWARD_RUN) —
        // valveStateStr() reads current state only. Publish exactly here so
        // the shadow never claims "CLOSING" before it's actually true.
        if (bypassTimeoutClosePending) {
          bypassTimeoutClosePending = false;
          StaticJsonDocument<192> fields;
          fields["voltage_status"] = voltageStatusStr();   // "BYPASS_ACTIVE"
          fields["bypass_active"]  = true;
          fields["fault"]          = faultStatusStr();
          fields["valve_state"]    = valveStateStr();       // "CLOSING" — true at publish time
          fields["last_event"]     = "BYPASS_TIMEOUT";
          publishShadowReported(fields.as<JsonObject>());
        }
      } break;
    case RAMP_DOWN_INIT:
      digitalWrite(RELAY_PWR,RELAY_OFF);
      rampDuty=255; ledcWrite(PWM_PIN,rampDuty); rampTimer=now; rampState=RAMP_DOWN;
      Serial.println("🔽 SOFT STOP"); break;
    case RAMP_DOWN:
      if (now-rampTimer>=RAMP_STEP_MS) {
        rampTimer=now; rampDuty-=3; if (rampDuty<0) rampDuty=0;
        ledcWrite(PWM_PIN,rampDuty);
        if (rampDuty<=0){ledcWrite(PWM_PIN,0);rampState=RAMP_DONE;}
      } break;
    case RAMP_DONE:
      digitalWrite(RELAY_FWD,RELAY_OFF); digitalWrite(RELAY_REV,RELAY_OFF);
      ledcWrite(PWM_PIN,0); rampState=RAMP_IDLE; motorState=IDLE;
      savePosition(); publishPosition(resumeDirection); recordMotorCycle(resumeDirection);
      Serial.println("🛑 STOPPED — IDLE"); break;
    default: break;
  }
}




// ================== MOTOR ==================
void clearRelays() {
  ledcWrite(PWM_PIN,0);
  digitalWrite(RELAY_PWR,RELAY_OFF);
  digitalWrite(RELAY_FWD,RELAY_OFF);
  digitalWrite(RELAY_REV,RELAY_OFF);
}

void stopMotor() {
  State stoppedFrom=motorState;
  if (motorState!=IDLE) {
    resumeDirection=motorState; resumePending=true;
    if (rampState==RAMP_UP||rampState==RAMP_BYPASS)
      { clearRelays(); rampState=RAMP_IDLE; motorState=IDLE; savePosition(); publishPosition(stoppedFrom); recordMotorCycle(stoppedFrom); return; }
    rampState=RAMP_DOWN_INIT; return;
  }
  clearRelays(); rampState=RAMP_IDLE;
}

// [BYPASS] Now returns bool: true if the ramp was actually started, false if
// a safety guard rejected the command. Callers that need to know whether the
// motor genuinely started (e.g. the emergency auto-close path) can check
// this instead of duplicating the guard conditions themselves.
bool startMotor(State dir) {
  if (vState  ==LOCKED)      { Serial.println("🔒 BATTERY LOCKED");     return false; }
  if (lockFault)              { Serial.println("🔒 CURRENT LOCKED");     return false; }
  if (i2cFault)               { Serial.println("🔒 I2C FAULT");          return false; }
  if (encFault)               { Serial.println("🔒 ENC FAULT");          return false; }
  if (!positionConfident && !calInProgress()) { Serial.println("🔒 POSITION UNCERTAIN"); return false; }
  if (!limitOverride&&dir==REVERSE_RUN&&totalTurns<=MIN_TURNS) { Serial.println("⛔ REVERSE BLOCKED"); return false; }
  if (!limitOverride&&dir==FORWARD_RUN&&totalTurns>=MAX_TURNS) { Serial.println("⛔ FORWARD BLOCKED"); return false; }
  setPositionConfidence(false);
  clearRelays();
  rampDuty=0; rampDir=dir; rampTimer=millis()+200;
  motorRunStartMs = millis(); turnsAtMoveStart = totalTurns;   // [LIFETIME] mark start of this run
  if (dir==FORWARD_RUN){ digitalWrite(RELAY_REV,RELAY_OFF); digitalWrite(RELAY_FWD,RELAY_ON); }
  else                 { digitalWrite(RELAY_FWD,RELAY_OFF); digitalWrite(RELAY_REV,RELAY_ON); }
  rampState=RAMP_UP;
  Serial.println("🔼 SOFT START");
  return true;
}




// ================== [QOS1] MQTT PUBLISH WRAPPER ==================
bool mqttPublish(const char* topic, const String& payload) {
  if (!mqtt.connected()){Serial.println("⚠️ MQTT not connected");return false;}
  return mqtt.publish(topic, payload.c_str(), false, 1);
}




// ================== MQTT PUBLISH FUNCTIONS ==================
void publishHWProfile() {
  if (!mqtt.connected()) return;
  StaticJsonDocument<192> doc;
  doc["device_id"]=DEVICE_ID; doc["event"]="HW_PROFILE";
  char buf[8]; JsonObject hw=doc.createNestedObject("hw_profile");
  snprintf(buf,sizeof(buf),"0x%02X",inaAddr); hw["ina_addr"]=String(buf);
  snprintf(buf,sizeof(buf),"0x%02X",encAddr); hw["enc_addr"]=String(buf);
  snprintf(buf,sizeof(buf),"0x%02X",rtcAddr); hw["rtc_addr"]=String(buf);
  doc["ts"]=getTimestamp();
  String out; serializeJson(doc,out);
  mqtt.publish(pubStatusTopic.c_str(),out.c_str(),false,1);
  Serial.print("📤 HW PROFILE: "); Serial.println(out);
}

void publishPosition(State stoppedFrom) {
  StaticJsonDocument<224> doc;
  doc["device_id"]=DEVICE_ID; doc["turns"]=totalTurns; doc["state"]="IDLE";
  doc["pos_confident"]=positionConfident; doc["ts"]=getTimestamp();
  if      (stoppedFrom==FORWARD_RUN) doc["stopped_from"]="FORWARD";
  else if (stoppedFrom==REVERSE_RUN) doc["stopped_from"]="REVERSE";
  else                                doc["stopped_from"]="IDLE";
  String out; serializeJson(doc,out); mqttPublish(pubStatusTopic.c_str(),out);
  Serial.print("📤 POS: "); Serial.println(out);
}

void publishVoltageEvent(String event, float v) {
  StaticJsonDocument<160> doc;
  doc["device_id"]=DEVICE_ID; doc["voltage_event"]=event;
  doc["voltage_v"]=v; doc["ts"]=getTimestamp();
  String out; serializeJson(doc,out); mqttPublish(pubEventTopic.c_str(),out);
}

void publishCurrentEvent(String event, float current) {
  StaticJsonDocument<160> doc;
  doc["device_id"]=DEVICE_ID; doc["current_event"]=event;
  doc["current_a"]=current; doc["threshold_a"]=CURRENT_OFF;
  doc["retry"]=retryCount; doc["ts"]=getTimestamp();
  String out; serializeJson(doc,out); mqttPublish(pubEventTopic.c_str(),out);
}

void publishFullStatus() {
  StaticJsonDocument<576> doc;
  doc["device_id"]=DEVICE_ID; doc["fw_version"]=FW_VERSION; doc["fw_type"]=FW_TYPE;
  if      (motorState==IDLE)        doc["state"]="IDLE";
  else if (motorState==FORWARD_RUN) doc["state"]="FORWARD";
  else                              doc["state"]="REVERSE";
  doc["turns"]=totalTurns; doc["max_turns"]=MAX_TURNS; doc["min_turns"]=MIN_TURNS;
  doc["ts"]=getTimestamp(); doc["rtc_valid"]=rtcIsValid();
  doc["pos_confident"]=positionConfident;
  doc["apn"]=apn;   // [APN]
  doc["sleep_timeout_ms"]=sleepTimeoutMs;   // [SLP]
  doc["voltage_status"] = voltageStatusStr();   // [STATUS] shared mapper
  doc["vbat_raw_mv"]=vbatMV; doc["oc_threshold"]=CURRENT_OFF; doc["retry"]=retryCount;
  doc["fault"] = faultStatusStr();   // [STATUS] shared mapper
  doc["eol_status"] = eolCertStatusStr();   // [EOLCERT] shared mapper
  // [CAL] calibration state in every status payload
  const char* calStateStr[] = {"CAL_IDLE","CAL_AWAITING_CLOSED","CAL_CLOSED_SET"};
  doc["cal_state"] = calStateStr[calState];
  char buf[8]; JsonObject hw=doc.createNestedObject("hw_profile");
  snprintf(buf,sizeof(buf),"0x%02X",inaAddr); hw["ina_addr"]=String(buf);
  snprintf(buf,sizeof(buf),"0x%02X",encAddr); hw["enc_addr"]=String(buf);
  snprintf(buf,sizeof(buf),"0x%02X",rtcAddr); hw["rtc_addr"]=String(buf);
  if (updateAvailable){doc["update_available"]=true;doc["update_version"]=pendingUpdateVer;}
  String out; serializeJson(doc,out); mqttPublish(pubStatusTopic.c_str(),out);
  Serial.print("📤 STATUS: "); Serial.println(out);
}




const char* lteStateStr() {
  switch (lteState) {
    case LTE_AT:       return "AT";
    case LTE_CPIN:     return "CPIN";
    case LTE_CSQ:      return "CSQ";
    case LTE_CREG:     return "CREG";
    case LTE_CGATT:    return "CGATT";
    case LTE_CGDCONT:  return "CGDCONT";
    case LTE_CGACT:    return "CGACT";
    case LTE_CGPADDR:  return "CGPADDR";
    case LTE_PING:     return "PING";
    case LTE_DONE:     return "DONE";
    default:           return "UNKNOWN";
  }
}

const char* resetReasonStr(esp_reset_reason_t r) {
  switch (r) {
    case ESP_RST_POWERON:   return "POWERON";
    case ESP_RST_EXT:       return "EXT_PIN";
    case ESP_RST_SW:        return "SW_RESTART";
    case ESP_RST_PANIC:     return "PANIC";
    case ESP_RST_INT_WDT:   return "INT_WDT";
    case ESP_RST_TASK_WDT:  return "TASK_WDT";
    case ESP_RST_WDT:       return "OTHER_WDT";
    case ESP_RST_DEEPSLEEP: return "DEEPSLEEP_WAKE";
    case ESP_RST_BROWNOUT:  return "BROWNOUT";
    case ESP_RST_SDIO:      return "SDIO";
    default:                return "UNKNOWN";
  }
}

// [DIAG] Service/engineering view — distinct from publishFullStatus(), which
// stays focused on operator-facing state (valve, position, voltage, fault,
// cal, EOL). This is for troubleshooting: memory, LTE/MQTT internals,
// sensor health detail, RTC, reset reason. Published ONLY on request
// (GET_DIAGNOSTICS), never on a timer or automatically.
//
// Deliberately does NOT re-probe the modem live (no modemIsAlive() call
// here) — that sends a blocking AT command over SerialAT, which could
// collide with an in-flight LTE init/AT exchange if diagnostics happens to
// be requested mid-connection. Instead this reports the firmware's own
// tracked LTE state (lteReady/lteState), which is always safe to read.
void publishDiagnostics() {
  StaticJsonDocument<640> doc;
  doc["device_id"]   = DEVICE_ID;
  doc["fw_version"]  = FW_VERSION;
  doc["ts"]          = getTimestamp();
  doc["uptime_ms"]   = millis();
  doc["reset_reason"]= resetReasonStr(bootResetReason);   // [BROWNOUT] cached at boot

  JsonObject mem = doc.createNestedObject("memory");
  mem["free_heap"]     = ESP.getFreeHeap();
  mem["min_free_heap"] = ESP.getMinFreeHeap();
  mem["heap_size"]     = ESP.getHeapSize();

  JsonObject lte = doc.createNestedObject("lte");
  lte["ready"]     = lteReady;
  lte["state"]     = lteStateStr();
  lte["reg_tries"] = lteRegTries;
  lte["apn"]       = apn;

  JsonObject mqttObj = doc.createNestedObject("mqtt");
  mqttObj["connected"] = mqtt.connected();
  mqttObj["state"]     = mqtt.state();   // PubSubClient status code

  JsonObject sensors = doc.createNestedObject("sensors");
  sensors["ina226"]             = checkINA226str();
  sensors["as5600"]              = checkAS5600str();
  sensors["i2c_fault"]           = i2cFault;
  sensors["i2c_recovery_count"]  = i2cRecoveryCount;

  JsonObject rtc = doc.createNestedObject("rtc");
  rtc["valid"] = rtcIsValid();
  char rtcAddrBuf[8]; snprintf(rtcAddrBuf, sizeof(rtcAddrBuf), "0x%02X", rtcAddr);
  rtc["addr"] = String(rtcAddrBuf);

  doc["eol_status"] = eolCertStatusStr();

  JsonObject lifetimeObj = doc.createNestedObject("lifetime");
  lifetimeObj["boot_count"]      = lifetime.bootCount;
  lifetimeObj["brownout_count"]  = lifetime.brownoutCount;
  lifetimeObj["watchdog_count"]  = lifetime.watchdogCount;
  lifetimeObj["open_count"]      = lifetime.openCount;
  lifetimeObj["close_count"]     = lifetime.closeCount;
  lifetimeObj["motor_seconds"]   = lifetime.motorSeconds;
  lifetimeObj["motor_turns"]     = lifetime.motorTurns;
  lifetimeObj["emergency_count"] = lifetime.emergencyBypassCount;
  lifetimeObj["last_ota_ver"]    = lifetime.lastOtaVersion;
  lifetimeObj["last_ota_ts"]     = lifetime.lastOtaTs;

  String out; serializeJson(doc, out);
  mqttPublish(pubStatusTopic.c_str(), out);
  Serial.print("📤 DIAGNOSTICS: "); Serial.println(out);
}




// ================== ENCODER ==================
int readAngle() {
  if (encAddr==0x00) return -1;
  Wire.beginTransmission(encAddr); Wire.write(0x0E); Wire.endTransmission(false);
  Wire.requestFrom(encAddr,(uint8_t)2);
  if (Wire.available()==2) { int h=Wire.read(),l=Wire.read(); return ((h<<8)|l)&0x0FFF; }
  return -1;
}

void handleEncoderFault(const String &result) {
  bool hardFault=(result=="NO_ACK"||result=="NO_ADDR"||result=="NO_MAGNET");
  bool softFault=(result=="AGC_SAT");
  bool healthy  =(result=="OK");
  if (hardFault&&!encFault) {
    encFault=true; encFaultPublished=false;
    Serial.printf("🔴 ENC FAULT: %s\n",result.c_str());
    if (motorState!=IDLE) stopMotor();
    if (mqtt.connected()&&!encFaultPublished) {
      StaticJsonDocument<160> doc;
      doc["device_id"]=DEVICE_ID; doc["enc_event"]="ENC_FAULT";
      doc["fault_code"]=result; doc["ts"]=getTimestamp();
      String out; serializeJson(doc,out);
      mqtt.publish(pubEventTopic.c_str(),out.c_str(),false,1);
      encFaultPublished=true;
    }
  }
  if (softFault&&!agcWarn) {
    agcWarn=true;
    Serial.println("⚠️ ENC AGC SATURATED");
    if (mqtt.connected()) {
      StaticJsonDocument<160> doc;
      doc["device_id"]=DEVICE_ID; doc["enc_event"]="ENC_AGC_WARN";
      doc["fault_code"]=result; doc["ts"]=getTimestamp();
      String out; serializeJson(doc,out);
      mqtt.publish(pubEventTopic.c_str(),out.c_str(),false,1);
    }
  }
  if (healthy) {
    if (encFault) {
      encFault=false; encFaultPublished=false;
      Serial.println("✅ ENC FAULT CLEARED");
      if (mqtt.connected()) {
        StaticJsonDocument<128> doc;
        doc["device_id"]=DEVICE_ID; doc["enc_event"]="ENC_RECOVERED"; doc["ts"]=getTimestamp();
        String out; serializeJson(doc,out); mqtt.publish(pubEventTopic.c_str(),out.c_str(),false,1);
      }
    }
    if (agcWarn) { agcWarn=false; Serial.println("✅ ENC AGC CLEARED"); }
  }
}

void handleEncoder() {
  String encResult=checkAS5600str();
  handleEncoderFault(encResult);
  if (encFault) return;
  int a=readAngle(); if (a==-1) return;
  int diff=a-prevAngle;
  if (diff> 3000) rotationCount--;
  if (diff<-3000) rotationCount++;
  prevAngle=a; angle=a;
  totalTurns=rotationCount+(angle/4096.0);
  if (motorState==FORWARD_RUN&&totalTurns>=MAX_TURNS){Serial.println("🛑 FWD LIMIT"); stopMotor();}
  if (motorState==REVERSE_RUN&&totalTurns<=MIN_TURNS){Serial.println("🛑 REV LIMIT"); stopMotor();}
}




// ================== [BUZZ] BUZZER ==================
// [BUZZ-PATTERN] One-shot blocking buzzer pattern for discrete, rare events
// (boot OK, LTE connected, calibration complete, EOL passed, low-voltage
// bypass, fault trip). Blocking briefly here is consistent with the
// delay()-based patterns already used elsewhere in this firmware (EOL
// buzzer test, motor pulse tests) — these are momentary, non-time-critical
// moments, not continuous operation.
//
// Deliberately NOT used for a continuous "fault" tone: handleBuzzer() below
// already owns BUZZER_PIN continuously during normal FW_ACTIVE operation
// (travel-limit proximity indication). A second continuous driver would
// fight it for the pin every loop tick. Instead, a fault trip gets a single
// bounded rapid-beep burst at the moment it's first detected — distinct
// enough to notice, without needing a priority-arbitration layer between
// two competing buzzer state machines. A true continuous fault indication
// would be a reasonable future addition if this bounded burst proves
// insufficient in the field.
void buzzPattern(int beeps, int onMs, int offMs) {
  for (int i = 0; i < beeps; i++) {
    digitalWrite(BUZZER_PIN, LOW);  delay(onMs);
    digitalWrite(BUZZER_PIN, HIGH); delay(offMs);
  }
}

// [MANUAL-BUZZER] One-shot calibrated-endpoint identification, only
// relevant while the motor is IDLE (see handleBuzzer() below for why that
// gate is what makes this mutually exclusive with the continuous
// motorized-approach indication, rather than colliding with it).
#define MANUAL_LIMIT_CAL_TOLERANCE 0.15f   // turns — allowed error from a calibrated endpoint
bool manualLimitBeepPlayed = false;         // edge-latched: one beep sequence per switch press

void handleBuzzer() {
  bool limitActive=(digitalRead(LIMIT_SWITCH_PIN)==LOW);
  if (!limitActive){digitalWrite(BUZZER_PIN,HIGH);buzzerTimer=millis();manualLimitBeepPlayed=false;return;}

  // [MANUAL-BUZZER] Motor IDLE + limit switch active can only mean the
  // valve was moved by hand (declutch lever/crank) — the motor never
  // engages the switch without motorState first leaving IDLE. This branch
  // is mutually exclusive with the continuous motorized-approach
  // indication below, which assumes an active motor run in progress.
  if (motorState == IDLE) {
    if (manualLimitBeepPlayed) return;
    manualLimitBeepPlayed = true;   // latch immediately on first detection this press

    // Position was not trusted when the switch was first seen active —
    // stay silent for this press. Latching happens above BEFORE this
    // check, so the decision can't change while the switch is still held;
    // operator must release (resets the latch, above) and trigger again
    // after confidence is restored.
    if (!positionConfident) return;

    if      (fabs(totalTurns - MIN_TURNS) <= MANUAL_LIMIT_CAL_TOLERANCE) buzzPattern(3, 100, 120);  // calibrated CLOSED
    else if (fabs(totalTurns - MAX_TURNS) <= MANUAL_LIMIT_CAL_TOLERANCE) buzzPattern(2, 100, 120);  // calibrated OPEN
    else                                                                  buzzPattern(1, 100, 120);  // unexpected position
    return;
  }

  int mode=1;
  if      (totalTurns<=MIN_TURNS) mode=2;
  else if (totalTurns>=MAX_TURNS) mode=3;
  unsigned long now=millis(),elapsed=now-buzzerTimer;
  if (mode==1) {
    if      (elapsed<150)  digitalWrite(BUZZER_PIN,LOW);
    else if (elapsed<600)  digitalWrite(BUZZER_PIN,HIGH);
    else                   buzzerTimer=now;
  } else if (mode==2) {
    if      (elapsed<150)   digitalWrite(BUZZER_PIN,LOW);
    else if (elapsed<300)   digitalWrite(BUZZER_PIN,HIGH);
    else if (elapsed<450)   digitalWrite(BUZZER_PIN,LOW);
    else if (elapsed<600)   digitalWrite(BUZZER_PIN,HIGH);
    else if (elapsed>=1100) buzzerTimer=now;
  } else {
    if      (elapsed<150)   digitalWrite(BUZZER_PIN,LOW);
    else if (elapsed<300)   digitalWrite(BUZZER_PIN,HIGH);
    else if (elapsed<450)   digitalWrite(BUZZER_PIN,LOW);
    else if (elapsed<600)   digitalWrite(BUZZER_PIN,HIGH);
    else if (elapsed<750)   digitalWrite(BUZZER_PIN,LOW);
    else if (elapsed<900)   digitalWrite(BUZZER_PIN,HIGH);
    else if (elapsed>=1400) buzzerTimer=now;
  }
}




// ================== LIMIT SWITCH ==================
void handleLimit() {
  bool limitNow=(digitalRead(LIMIT_SWITCH_PIN)==LOW);
  if (!limitOverride&&limitNow&&lastLimitState==HIGH){Serial.println("🔴 LIMIT SWITCH");stopMotor();}
  lastLimitState=limitNow;
}




// ================== CURRENT ==================
void handleCurrent() {
  float current=getCurrent();
  bool  over=(current>CURRENT_OFF)||inaAlertFlag;
  if (inaAlertFlag){inaAlertFlag=false;Serial.println("⚡ INA ALERT");}
  if (motorState!=IDLE&&over&&!lastOvercurrent) {
    Serial.println("⚠️ OVERCURRENT");
    stopMotor(); retryCount++; ocTripTime=millis(); ocFault=true;
    Serial.printf("🔁 ATTEMPT: %d\n",retryCount);
    publishCurrentEvent("OC_TRIP",current);
    if (retryCount>=3){Serial.println("🔒 CURRENT LOCKED");lockFault=true;publishCurrentEvent("LOCKED",current);buzzPattern(4,80,80);}
  }
  lastOvercurrent=over;
  if (ocFault&&!lockFault&&millis()-ocTripTime>RETRY_DELAY)
    { publishCurrentEvent("OC_RETRY",current); startMotor(lastDirection); ocFault=false; }
  static bool ocEventActive=false;
  if (ocEventActive&&!over&&!ocFault&&!lockFault){publishCurrentEvent("OC_RESET",current);ocEventActive=false;}
  if (ocFault&&!lockFault) ocEventActive=true;
}




// ================== VOLTAGE ==================
// [BYPASS] handleVoltageSafety() now also owns the 2-minute operator-response
// timeout for the WAIT_BYPASS state. If BYPASS_Y/BYPASS_N never arrives
// (operator away, or MQTT/LTE unavailable entirely), the firmware forces an
// autonomous CLOSE — independent of connectivity — and records the action
// to NVS via emergencySaveTrigger() BEFORE commanding the motor, so the
// event survives a reboot at any point during or after the close.
void handleVoltageSafety() {
  float v=getVoltage();
  if (v<=CRITICAL_V&&vState!=LOCKED){Serial.printf("🛑 CRITICAL %.2fV\n",v);stopMotor();vState=LOCKED;publishVoltageEvent("LOCKED",v);return;}
  if (vState==LOCKED){if(v>=RESET_V){vState=NORMAL;publishVoltageEvent("NORMAL",v);}return;}
  if (vState==BYPASS_ACTIVE){
    if(v<=CRITICAL_V){stopMotor();vState=LOCKED;publishVoltageEvent("LOCKED",v);return;}
    if(v>=RESET_V){
      vState=NORMAL; publishVoltageEvent("NORMAL",v);
      // [SHADOW] Voltage genuinely recovered — reflect real settled state
      StaticJsonDocument<192> fields;
      fields["voltage_status"] = voltageStatusStr();   // "NORMAL"
      fields["bypass_active"]  = false;
      fields["fault"]          = faultStatusStr();     // "OK" unless another fault is active
      fields["valve_state"]    = valveStateStr();
      fields["last_event"]     = "VOLTAGE_RECOVERED";
      publishShadowReported(fields.as<JsonObject>());
    }
    return;
  }

  // [BYPASS] No Y/N response within BYPASS_TIMEOUT_MS — fail closed
  if (vState==WAIT_BYPASS) {
    if (millis()-bypassWaitStart >= BYPASS_TIMEOUT_MS) {
      Serial.println("⏱️ BYPASS TIMEOUT — no operator response, auto-closing valve");
      publishVoltageEvent("BYPASS_TIMEOUT_AUTO_CLOSE", v);   // event topic — historical record
      emergencySaveTrigger("BYPASS_TIMEOUT");                // [EMERGENCY] persist BEFORE acting
      recordEmergencyBypass();                                 // [LIFETIME v1.1.4]

      resumePending = false;
      vState = BYPASS_ACTIVE;   // suppress CUT_V re-trip so the close can complete/be reflected

      if (startMotor(REVERSE_RUN)) {
        // Motor accepted the command — defer shadow publish to the real
        // RAMP_BYPASS→RAMP_RUNNING transition in handleMotorRamp()
        bypassTimeoutClosePending = true;
      } else {
        // Rejected by a guard (lock/I2C/encoder/position) — publish the
        // TRUE current state immediately, don't leave the shadow silent
        bypassTimeoutClosePending = false;
        StaticJsonDocument<192> fields;
        fields["voltage_status"] = voltageStatusStr();   // "BYPASS_ACTIVE"
        fields["bypass_active"]  = true;
        fields["fault"]          = faultStatusStr();     // real blocking reason
        fields["valve_state"]    = valveStateStr();       // "IDLE" — true, motor never started
        fields["last_event"]     = "BYPASS_TIMEOUT";
        publishShadowReported(fields.as<JsonObject>());
      }
    }
    return;
  }

  if (v<WARN_V_LOW) {
    if (vState==NORMAL){vState=WARNING;warnPrintTimer=0;publishVoltageEvent("WARNING",v);}
    if (millis()-warnPrintTimer>5000){warnPrintTimer=millis();Serial.printf("⚠️ VOLTAGE %.2fV\n",v);}
  } else if (v>WARN_V_HIGH&&vState==WARNING){vState=NORMAL;publishVoltageEvent("NORMAL",v);}
  if (v<CUT_V&&motorState!=IDLE&&vState!=WAIT_BYPASS)
    {Serial.printf("🛑 LOW VOLTAGE CUT %.2fV\n",v);stopMotor();vState=WAIT_BYPASS;bypassWaitStart=millis();publishVoltageEvent("CUT",v);buzzPattern(2,500,400);}
}




// ================== [DEEP] ENTER DEEP SLEEP ==================
void enterDeepSleep() {
  Serial.println("😴 ENTERING DEEP SLEEP");
  clearRelays(); motorState=IDLE; rampState=RAMP_IDLE;
  if (mqtt.connected()){mqtt.disconnect();delay(100);}
  modemPowerOff();
  savePosition();
  setPositionConfidence(true);
  armNextAlarm();
  // [MANUAL-OVERRIDE] ext1 bitmask wake — wakes on RTC alarm (scheduled) OR
  // limit switch toggle (manual crank/declutch lever also moves the AS5600
  // magnet; the limit switch is the wake-capable proxy for "valve moved" —
  // there is no dedicated manual-override sense line in current hardware).
  // Both signals are active-low in this firmware, hence ANY_LOW.
  // NOTE: exact ESP_EXT1_WAKEUP_* enum naming/availability has shifted
  // across ESP-IDF/Arduino-core versions (same category of break as the
  // Core 3.x watchdog API change) — verify this compiles and wakes as
  // expected on your specific core version on the bench before relying on
  // it in the field. If ext1 is unavailable/behaves unexpectedly on your
  // core, reverting to the single-pin ext0 RTC-only wake
  // (esp_sleep_enable_ext0_wakeup((gpio_num_t)RTC_INT_PIN, 0)) restores
  // exact v1.1.2 sleep behavior, at the cost of losing manual-override wake.
  uint64_t wakeMask = (1ULL << RTC_INT_PIN) | (1ULL << LIMIT_SWITCH_PIN);
  esp_sleep_enable_ext1_wakeup(wakeMask, ESP_EXT1_WAKEUP_ANY_LOW);
  Serial.println("💤 esp_deep_sleep_start()");
  Serial.flush();
  esp_deep_sleep_start();
}




// ================== [MANUAL-OVERRIDE] WAKE-ON-CRANK HANDLER ==================
// Called from setup() only when isManualOverrideWake is true (deep sleep
// woke via the limit-switch ext1 source, not the RTC alarm). The manual
// hand-crank/declutch lever shares a shaft with the AS5600 encoder, so a
// manual move is only trackable if we're actively polling the encoder
// WHILE the crank moves — a single before/after sample cannot distinguish
// e.g. 0.2 turns from 1.2 turns, since normal rotation tracking depends on
// comparing frequent consecutive samples (see handleEncoder()'s wrap
// logic, mirrored here). So this polls continuously, at a similar cadence
// to handleEncoder() while awake, until the position is stable for
// MANUAL_OVERRIDE_SETTLE_STABLE_READS consecutive samples, or until
// MANUAL_OVERRIDE_MAX_AWAKE_MS is exceeded — in which case it abandons the
// quick-sleep path and falls through to full normal operation instead of
// forcing another sleep cycle on something stuck/unusual.
void handleManualOverrideWake() {
  manualOverrideWakeStartMs = millis();
  Serial.println("🖐️ MANUAL OVERRIDE WAKE — checking for real movement");

  if (encAddr == 0x00) {
    Serial.println("⚠️ MANUAL OVERRIDE: no encoder detected — cannot track, falling through to normal boot");
    setPositionConfidence(false);
    manualOverridePendingPublish = true;
    manualOverrideSettledCleanly = false;
    return;
  }

  // Debounce: a single switch-bounce/noise wake shouldn't trigger a full
  // poll cycle or a battery-costing publish+reconnect. Take two readings a
  // short settle apart; if the angle barely moved and the switch isn't
  // actively held, treat it as noise and go straight back to sleep.
  int startAngle = readAngle();
  delay(300);
  int checkAngle = readAngle();
  bool limitCurrentlyTriggered = (digitalRead(LIMIT_SWITCH_PIN) == LOW);

  if (startAngle != -1 && checkAngle != -1 &&
      abs(checkAngle - startAngle) < 20 && !limitCurrentlyTriggered) {
    Serial.println("🖐️ MANUAL OVERRIDE: no real movement detected (debounce) — back to sleep");
    isManualOverrideWake = false;   // consumed
    enterDeepSleep();               // does not return
    return;
  }

  // Real movement suspected — poll continuously until it settles or we
  // hit the max-awake ceiling. Uses the same wrap-detection logic as
  // handleEncoder(), continuing from the prevAngle/rotationCount already
  // restored by loadPosition() earlier in setup(), so tracking is
  // continuous with the pre-sleep saved state.
  int  stableCount = 0;
  int  lastAngle   = checkAngle;
  bool timedOut    = true;

  while (millis() - manualOverrideWakeStartMs < MANUAL_OVERRIDE_MAX_AWAKE_MS) {
    String encResult = checkAS5600str();
    if (encResult != "OK") {
      Serial.printf("⚠️ MANUAL OVERRIDE: encoder fault mid-poll (%s) — aborting, position uncertain\n", encResult.c_str());
      setPositionConfidence(false);
      manualOverridePendingPublish = true;
      manualOverrideSettledCleanly = false;
      return;
    }

    int a = readAngle();
    if (a != -1) {
      int diff = a - prevAngle;
      if (diff >  3000) rotationCount--;
      if (diff < -3000) rotationCount++;
      prevAngle = a; angle = a;
      totalTurns = rotationCount + (angle / 4096.0);

      if (abs(a - lastAngle) < 8) stableCount++; else stableCount = 0;
      lastAngle = a;

      if (stableCount >= MANUAL_OVERRIDE_SETTLE_STABLE_READS) { timedOut = false; break; }
    }
    delay(MANUAL_OVERRIDE_POLL_INTERVAL_MS);
  }

  savePosition();   // sets positionConfident = true, persists rotationCount/angle
  manualOverridePendingPublish = true;
  manualOverrideSettledCleanly = !timedOut;

  if (timedOut) Serial.println("⚠️ MANUAL OVERRIDE: did not settle within max-awake window — falling through to full normal operation");
  else          Serial.printf("✅ MANUAL OVERRIDE: settled at %.2f turns\n", totalTurns);
}




// ================== JSON COMMAND HANDLER ==================
void handleJSONCommand(String input) {
  StaticJsonDocument<256> doc;
  if (deserializeJson(doc,input)){Serial.println("❌ JSON ERROR");return;}
  String id=doc["device_id"]; if (id!=DEVICE_ID) return;
  String cmd=doc["cmd"];
  touchKeepAwake();   // [SLP] any valid command resets keep-awake window

  if      (cmd=="F"){ startMotor(FORWARD_RUN); }
  else if (cmd=="R"){ startMotor(REVERSE_RUN); }
  else if (cmd=="S"){ stopMotor(); }

  else if (vState==WAIT_BYPASS) {
    if (cmd=="Y"){vState=BYPASS_ACTIVE;publishVoltageEvent("BYPASS",getVoltage());if(resumePending){startMotor(resumeDirection);resumePending=false;}}
    else if (cmd=="N"){vState=WARNING;resumePending=false;}
  }

  // [CAL] Field calibration state machine — three commands
  else if (cmd=="CALIBRATE_CLOSED") { handleCalClosed(); }
  else if (cmd=="CALIBRATE_OPEN")   { handleCalOpen();   }
  else if (cmd=="CALIBRATE_CANCEL") { handleCalCancel(); }

  // CONFIRM_POSITION — still valid outside of calibration to accept uncertain position
  else if (cmd=="CONFIRM_POSITION") {
    if (calInProgress()) {
      Serial.println("❌ CONFIRM_POSITION blocked during calibration — use CALIBRATE_CANCEL first");
    } else {
      setPositionConfidence(true);
      Serial.println("✅ POSITION CONFIRMED");
      if (mqtt.connected()) {
        StaticJsonDocument<128> d2; d2["device_id"]=DEVICE_ID; d2["pos_event"]="POSITION_CONFIRMED";
        d2["turns"]=totalTurns; d2["ts"]=getTimestamp();
        String out; serializeJson(d2,out); mqttPublish(pubStatusTopic.c_str(),out);
      }
    }
  }

  else if (cmd=="SET_TIME") {
    String iso=doc["iso"]|"";
    if (iso.length()>=19) {
      struct tm t;
      if (parseISO(iso,t)&&rtcSetTime(t)) {
        Serial.println("✅ RTC SET: "+iso);
        StaticJsonDocument<128> r; r["device_id"]=DEVICE_ID; r["rtc_event"]="TIME_SET"; r["ts"]=getTimestamp();
        String out; serializeJson(r,out); mqttPublish(pubStatusTopic.c_str(),out);
        armNextAlarm();
      } else Serial.println("❌ RTC write failed");
    } else Serial.println("❌ SET_TIME: missing iso");
  }

  else if (cmd=="SCHEDULE") {
    int slot=doc["slot"]|-1;
    if (slot>=0&&slot<SCHED_SLOTS) {
      String action=doc["action"]|"OPEN"; String days=doc["days"]|"0000000";
      int hour=doc["hour"]|0; int minute=doc["minute"]|0;
      schedSlots[slot].enabled=true; schedSlots[slot].action=(action=="CLOSE")?1:0;
      schedSlots[slot].hour=(uint8_t)constrain(hour,0,23);
      schedSlots[slot].minute=(uint8_t)constrain(minute,0,59);
      if (days.length()==7){memcpy(schedSlots[slot].days,days.c_str(),7);schedSlots[slot].days[7]='\0';}
      else                 {memcpy(schedSlots[slot].days,"0000000",7);   schedSlots[slot].days[7]='\0';}
      saveSchedule(); armNextAlarm(); publishSchedule();
      Serial.printf("📅 SLOT %d: %s %02d:%02d %s\n",slot,action.c_str(),hour,minute,days.c_str());
    } else Serial.println("❌ SCHEDULE: invalid slot");
  }

  else if (cmd=="CLEAR_SCHEDULE") {
    int slot=doc["slot"]|-1;
    if (slot>=0&&slot<SCHED_SLOTS) {
      schedSlots[slot].enabled=false;
      memcpy(schedSlots[slot].days,"0000000",7); schedSlots[slot].days[7]='\0';
      saveSchedule(); armNextAlarm(); publishSchedule();
      Serial.printf("📅 SLOT %d CLEARED\n",slot);
    } else Serial.println("❌ CLEAR_SCHEDULE: invalid slot");
  }

  else if (cmd=="GET_SCHEDULE")   { publishSchedule();   }
  else if (cmd=="GET_HW_PROFILE") { publishHWProfile();  }
  else if (cmd=="GET_STATUS")     { publishFullStatus(); }
  else if (cmd=="GET_DIAGNOSTICS"){ publishDiagnostics(); }
  else if (cmd=="GET_SENSORS")    { checkSensors();      }

  // [APN] SET_APN
  else if (cmd=="SET_APN") {
    String newApn=doc["apn"]|"";
    if (newApn.length()>0&&newApn.length()<64) {
      saveAPN(newApn);
      Serial.println("✅ APN SET: "+newApn);
      StaticJsonDocument<128> d2; d2["device_id"]=DEVICE_ID; d2["apn_event"]="APN_SET";
      d2["apn"]=newApn; d2["note"]="Takes effect on next LTE init";
      String out; serializeJson(d2,out); mqttPublish(pubStatusTopic.c_str(),out);
    } else Serial.println("❌ SET_APN: invalid value");
  }

  // [SLP] SET_SLEEP_TIMEOUT
  else if (cmd=="SET_SLEEP_TIMEOUT") {
    unsigned long v=(unsigned long)(doc["value"]|sleepTimeoutMs);
    if (v>=MIN_SLEEP_TIMEOUT_MS&&v<=MAX_SLEEP_TIMEOUT_MS) {
      sleepTimeoutMs=v;
      prefs.begin("device_cfg",false); prefs.putULong("sleep_timeout",sleepTimeoutMs); prefs.end();
      Serial.printf("😴 SLEEP TIMEOUT: %lu ms\n",sleepTimeoutMs); publishFullStatus();
    } else Serial.printf("❌ SET_SLEEP_TIMEOUT: range %lu–%lu ms\n",MIN_SLEEP_TIMEOUT_MS,MAX_SLEEP_TIMEOUT_MS);
  }

  else if (cmd=="SET_CURRENT") {
    float val=doc["value"]|CURRENT_OFF;
    if (val>0.1&&val<10.0) {
      CURRENT_OFF=val;
      prefs.begin("device_cfg",false); prefs.putFloat("oc_thresh",CURRENT_OFF); prefs.end();
      lockFault=false; ocFault=false; retryCount=0;
      configureINAAlert(); publishCurrentEvent("THRESHOLD_SET",getCurrent());
    } else Serial.println("❌ INVALID CURRENT VALUE");
  }

  else if (cmd=="SET_TURNS") {
    float val=doc["value"]|MAX_TURNS;
    if (val>=2.0&&val<=20.0) {
      MAX_TURNS=val;
      prefs.begin("device_cfg",false); prefs.putFloat("max_turns",MAX_TURNS); prefs.end();
      publishFullStatus();
    } else Serial.println("❌ INVALID TURNS (2.0–20.0)");
  }

  else if (cmd=="CHECK_UPDATE") {
    StaticJsonDocument<128> u; u["device_id"]=DEVICE_ID; u["update_available"]=updateAvailable;
    u["current_version"]=FW_VERSION; if(updateAvailable) u["update_version"]=pendingUpdateVer;
    String out; serializeJson(u,out); mqttPublish(pubStatusTopic.c_str(),out);
  }

  else if (cmd=="DO_UPDATE") {
    if (updateAvailable&&pendingUpdateURL.length()>0)
      { Serial.println("🚀 OTA — waiting idle"); stopMotor(); fwState=FW_OTA_WAIT; }
    else Serial.println("❌ NO UPDATE PENDING");
  }
}




// ================== UPDATE TOPIC HANDLER ==================
void handleUpdatePayload(String payload) {
  StaticJsonDocument<256> doc;
  if (deserializeJson(doc,payload)) return;
  String version=doc["version"]|""; String url=doc["url"]|""; String sha256=doc["sha256"]|"";
  if (version.length()==0) return;
  if (version!=FW_VERSION) {
    updateAvailable=true; pendingUpdateVer=version; pendingUpdateURL=url; pendingUpdateSHA=sha256;
    StaticJsonDocument<192> n; n["device_id"]=DEVICE_ID; n["update_available"]=true;
    n["update_version"]=version; n["current_version"]=FW_VERSION; n["note"]="Send DO_UPDATE";
    String out; serializeJson(n,out); mqttPublish(pubStatusTopic.c_str(),out);
    touchKeepAwake();
  } else { updateAvailable=false; Serial.println("✅ FW UP TO DATE"); }
}




// ================== [OTA] FULL OTA ==================
void performOTA() {
  Serial.println("🚀 OTA START");
  esp_task_wdt_delete(NULL);   // [WDT] suspend watchdog during flash — expected long operation
  String url=pendingUpdateURL; String host="",path="/"; int port=443;
  if (url.startsWith("https://")) url=url.substring(8);
  else if (url.startsWith("http://")) {url=url.substring(7);port=80;}
  int si=url.indexOf('/');
  if (si==-1) host=url; else {host=url.substring(0,si);path=url.substring(si);}
  int ci=host.indexOf(':');
  if (ci!=-1){port=host.substring(ci+1).toInt();host=host.substring(0,ci);}
  if (!otaClient.connect(host.c_str(),port)) {
    Serial.println("❌ OTA TCP fail");
    if(mqtt.connected()){StaticJsonDocument<96>e;e["device_id"]=DEVICE_ID;e["ota_event"]="OTA_FAIL";e["reason"]="TCP_CONNECT";String o;serializeJson(e,o);mqttPublish(pubStatusTopic.c_str(),o);}
    fwState=FW_ACTIVE; esp_task_wdt_add(NULL); return;
  }
  otaClient.print(String("GET ")+path+" HTTP/1.1\r\nHost: "+host+"\r\nConnection: close\r\n\r\n");
  unsigned long hdrT=millis(); int contentLength=-1; bool hdrDone=false;
  while (!hdrDone&&millis()-hdrT<10000) {
    if (otaClient.available()) {
      String line=otaClient.readStringUntil('\n'); line.trim();
      if (line.startsWith("Content-Length:")||line.startsWith("content-length:"))
        contentLength=line.substring(line.indexOf(':')+1).toInt();
      if (line.length()==0) hdrDone=true;
    }
  }
  if (contentLength<=0||!Update.begin(contentLength)) {
    otaClient.stop();
    if(mqtt.connected()){StaticJsonDocument<96>e;e["device_id"]=DEVICE_ID;e["ota_event"]="OTA_FAIL";e["reason"]="BAD_LENGTH";String o;serializeJson(e,o);mqttPublish(pubStatusTopic.c_str(),o);}
    fwState=FW_ACTIVE; esp_task_wdt_add(NULL); return;
  }
  bool doChecksum=(pendingUpdateSHA.length()==64);
  mbedtls_sha256_context sha256ctx;
  if (doChecksum){mbedtls_sha256_init(&sha256ctx);mbedtls_sha256_starts(&sha256ctx,0);}
  uint8_t buf[256]; int written=0,lastPct=-1; unsigned long dataT=millis();
  while (written<contentLength) {
    if (!otaClient.connected()&&!otaClient.available()){Serial.println("❌ OTA dropped");break;}
    int rd=otaClient.readBytes(buf,min((int)sizeof(buf),contentLength-written));
    if (rd>0) {
      Update.write(buf,rd); if(doChecksum) mbedtls_sha256_update(&sha256ctx,buf,rd);
      written+=rd; dataT=millis();
      int pct=(written*100)/contentLength,bucket=pct/10;
      if (bucket!=lastPct){lastPct=bucket;Serial.printf("📶 OTA: %d%%\n",pct);if(mqtt.connected()){StaticJsonDocument<96>p;p["device_id"]=DEVICE_ID;p["ota_event"]="OTA_PROGRESS";p["progress_pct"]=pct;String o;serializeJson(p,o);mqttPublish(pubStatusTopic.c_str(),o);}}
    } else if (millis()-dataT>10000){Serial.println("❌ OTA timeout");break;}
  }
  otaClient.stop();
  if (written!=contentLength) {
    Update.abort(); if(doChecksum) mbedtls_sha256_free(&sha256ctx);
    if(mqtt.connected()){StaticJsonDocument<96>e;e["device_id"]=DEVICE_ID;e["ota_event"]="OTA_FAIL";e["reason"]="INCOMPLETE";String o;serializeJson(e,o);mqttPublish(pubStatusTopic.c_str(),o);}
    fwState=FW_ACTIVE; esp_task_wdt_add(NULL); return;
  }
  if (doChecksum) {
    uint8_t digest[32]; mbedtls_sha256_finish(&sha256ctx,digest); mbedtls_sha256_free(&sha256ctx);
    char hex[65]; for(int i=0;i<32;i++) sprintf(hex+i*2,"%02x",digest[i]); hex[64]='\0';
    if (String(hex)!=pendingUpdateSHA) {
      Serial.println("❌ CHECKSUM MISMATCH"); Update.abort();
      if(mqtt.connected()){StaticJsonDocument<96>e;e["device_id"]=DEVICE_ID;e["ota_event"]="OTA_FAIL";e["reason"]="CHECKSUM";String o;serializeJson(e,o);mqttPublish(pubStatusTopic.c_str(),o);}
      fwState=FW_ACTIVE; esp_task_wdt_add(NULL); return;
    }
    Serial.println("✅ CHECKSUM OK");
  }
  if (!Update.end()) {
    if(mqtt.connected()){StaticJsonDocument<96>e;e["device_id"]=DEVICE_ID;e["ota_event"]="OTA_FAIL";e["reason"]="UPDATE_END";String o;serializeJson(e,o);mqttPublish(pubStatusTopic.c_str(),o);}
    fwState=FW_ACTIVE; esp_task_wdt_add(NULL); return;
  }
  pref
