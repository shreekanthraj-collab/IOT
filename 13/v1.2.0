// ================== [MDM] A7670C POWER CONTROL ==================
// PWRKEY is active-low on the A7670C.
// Power-on: pull low ≥1500 ms, then release. Module takes ~5 s to be AT-ready.
// Power-off (graceful): AT+CPOF, wait for "NORMAL POWER DOWN" URC ≤5 s.
//   If URC not received: pulse PWRKEY low 3 s (hard power-off).
// Called from setup() on every boot (cold + wake) to ensure modem is on.

#define A7670C_PWRON_PULSE_MS   1500UL   // PWRKEY low duration for power-on
#define A7670C_PWRON_SETTLE_MS  5000UL   // wait after releasing PWRKEY
#define A7670C_PWROFF_PULSE_MS  3000UL   // PWRKEY low duration for hard power-off
#define A7670C_CPOF_TIMEOUT_MS  5000UL   // wait for "NORMAL POWER DOWN" after AT+CPOF

// Probe whether the modem is already running (responds to AT)
bool modemIsAlive() {
  while (SerialAT.available()) SerialAT.read();   // flush
  SerialAT.println("AT");
  unsigned long t = millis();
  String resp = "";
  while (millis() - t < 500) {
    while (SerialAT.available()) resp += (char)SerialAT.read();
    if (resp.indexOf("OK") != -1) return true;
  }
  return false;
}

// Power on A7670C via PWRKEY pulse.
// Skipped if modem already responds to AT (avoids double-pulse on warm boot).
void modemPowerOn() {
  if (modemIsAlive()) {
    Serial.println("📶 A7670C already alive — skipping power-on pulse");
    return;
  }
  Serial.println("📶 A7670C POWER ON — PWRKEY pulse");
  digitalWrite(MODEM_PWRKEY_PIN, LOW);
  delay(A7670C_PWRON_PULSE_MS);
  digitalWrite(MODEM_PWRKEY_PIN, HIGH);
  Serial.println("📶 Waiting for A7670C ready...");
  delay(A7670C_PWRON_SETTLE_MS);
}

// Graceful power-off: AT+CPOF → wait for URC → hard pulse on timeout
void modemPowerOff() {
  Serial.println("📴 A7670C POWER OFF — AT+CPOF");
  while (SerialAT.available()) SerialAT.read();
  SerialAT.println("AT+CPOF");
  unsigned long t = millis();
  String resp = "";
  while (millis() - t < A7670C_CPOF_TIMEOUT_MS) {
    while (SerialAT.available()) resp += (char)SerialAT.read();
    if (resp.indexOf("NORMAL POWER DOWN") != -1) {
      Serial.println("✅ A7670C graceful power-down confirmed");
      return;
    }
  }
  // URC not received — hard power-off via PWRKEY
  Serial.println("⚠️ AT+CPOF timeout — hard PWRKEY power-off");
  digitalWrite(MODEM_PWRKEY_PIN, LOW);
  delay(A7670C_PWROFF_PULSE_MS);
  digitalWrite(MODEM_PWRKEY_PIN, HIGH);
  delay(500);
  Serial.println("✅ A7670C hard power-off complete");
}

// Power-cycle: off then on. Used by watchdog recovery and LTE reinit.
void modemPowerCycle() {
  Serial.println("🔄 MODEM POWER CYCLE");
  modemPowerOff();
  delay(1000);
  modemPowerOn();
}




