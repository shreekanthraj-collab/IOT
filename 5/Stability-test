// ================== LOOP ==================
void loop() {
















  switch (fwState) {
















    case FW_INIT:
      Serial.println("🚀 FW INIT → ACTIVE");
      fwState = FW_ACTIVE;
      break;
















    case FW_ACTIVE:
















      if (motorState == IDLE && !isRetryActive()) {
















        if (!idleTracking) {
          idleTracking = true;
          idleStart = millis();
        }
















        if (!sleepMode && millis() - idleStart > 5000) {
          Serial.println("💾 PRE-SLEEP SAVE");
          savePosition();
          sleepMode = true;
        }
















      } else {
        idleTracking = false;
      }
















      if (sleepMode) {
        fwState = FW_SLEEP;
        break;
      }
















      if (Serial.available()) {








  String input = Serial.readStringUntil('\n');
  input.trim();








  if (input.startsWith("{")) {
    handleJSONCommand(input);   // JSON commands
  } else {
    // ORIGINAL COMMAND LOGIC (unchanged)








    String cmd = input;
    cmd.trim();
    cmd.toUpperCase();








    Serial.print("📩 CMD: ");
    Serial.println(cmd);








    if (cmd == "F") startMotor(FORWARD_RUN);
    else if (cmd == "R") startMotor(REVERSE_RUN);
    else if (cmd == "S") stopMotor();








    else if (vState == WAIT_BYPASS) {








      if (cmd == "Y") {
        Serial.println("⚠️ BYPASS ENABLED");
        vState = BYPASS_ACTIVE;








        if (resumePending) {
          Serial.println("🔁 RESUMING");
          startMotor(resumeDirection);
          resumePending = false;
        }








      } else {
        Serial.println("❌ BYPASS DENIED");
        vState = WARNING;
      }
    }
  }
}
