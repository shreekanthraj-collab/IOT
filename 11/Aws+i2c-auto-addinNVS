// Base: aws_firmware_v1.0.2 — PCF8563 RTC + Scheduler preserved.
//
// v1.0.3 CHANGES — I2C Hardware Auto-Detection + NVS Caching:
//   [HW]    All three I2C devices auto-detected at boot instead of
//             using hardcoded addresses. Detected addresses cached in
//             NVS under "hw_profile" namespace so future boots skip
//             the scan and use cached values immediately.
//
//   [INA]   INA226 scanned across full valid range 0x40–0x4F
//             Validated by manufacturer ID register 0xFE == 0x5449
//             Global: uint8_t inaAddr  (replaces #define INA_ADDR 0x40)
//             INA226_WE ina226 allocated via pointer after detection
//
//   [ENC]   AS5600 scanned at 0x36 (silicon-fixed, no alt address)
//             Validated by STATUS register 0x0B bit5 (MH/ML/MD magnet flags)
//             AGC register 0x1A checked for saturation
//             Global: uint8_t encAddr  (replaces hardcoded AS5600_ADDR 0x36)
//
//   [RTC]   PCF8563 scanned at 0x51 (includes HYM8563 / compatible clones)
//             Validated by writing a known value and reading it back
//             via the CLKOUT register 0x0D (safe non-destructive probe)
//             Global: uint8_t rtcAddr  (replaces hardcoded PCF8563_ADDR 0x51)
//             All RTC driver calls updated to use rtcAddr variable
//
//   [NVS]   hw_profile namespace: "ina_addr", "enc_addr", "rtc_addr"
//             On first boot: scan → validate → save
//             On subsequent boots: load from NVS → verify ACK → use
//             If cached device no longer ACKs: re-scan and re-save
//
//   [AWS]   Hardware profile published to AWS on every MQTT connect:
//             {"device_id":"...","hw_profile":{"ina_addr":"0x40",
//              "enc_addr":"0x36","rtc_addr":"0x51"},"ts":"..."}
//             Also re-published after any re-scan event
//
//   [ERR]   If any device cannot be found after full scan:
//             Fatal error logged to serial + MQTT
//             Motor blocked (i2cFault = true)
//             Device continues attempting re-scan every 30 s via
//             existing sensorCheckTimer path
//
//   [VER]   FW_VERSION bumped to aws-1.0.3
//
// PIN MAP — ESP32-S3 PCB FINAL LOCKED (unchanged):
