// ================== [I2C-REC] BUS RECOVERY ==================
void recoverI2C() {
  Serial.println("🔧 I2C RECOVERY — bit-bang clock pulses");
  pinMode(SDA_PIN, INPUT_PULLUP);
  pinMode(SCL_PIN, OUTPUT);
  for (int i = 0; i < 9; i++) {
    digitalWrite(SCL_PIN, HIGH); delayMicroseconds(5);
    digitalWrite(SCL_PIN, LOW);  delayMicroseconds(5);
    if (digitalRead(SDA_PIN) == HIGH) {
      Serial.printf("✅ SDA released after %d pulses\n", i + 1);
      break;
    }
  }
  pinMode(SDA_PIN, OUTPUT);
  digitalWrite(SDA_PIN, LOW);  delayMicroseconds(5);
  digitalWrite(SCL_PIN, HIGH); delayMicroseconds(5);
  digitalWrite(SDA_PIN, HIGH); delayMicroseconds(5);
  Wire.begin(SDA_PIN, SCL_PIN);
  Serial.println("🔧 I2C Wire reinitialised");
}




// ================== [SENSOR] HEALTH CHECK ==================
// Uses detected addresses (inaAddr, encAddr) instead of hardcoded constants.
// If a device has moved address (shouldn't happen, but bus fault recovery may
// cause glitches), re-scan is triggered via the existing i2cFault path.

String checkINA226() {
  if (inaAddr == 0x00) return "NO_ADDR";
  Wire.beginTransmission(inaAddr);
  if (Wire.endTransmission() != 0) return "NO_ACK";
  if (!validateINA226(inaAddr)) return "BAD_ID";
  return "OK";
}

String checkAS5600() {
  if (encAddr == 0x00) return "NO_ADDR";
  Wire.beginTransmission(encAddr);
  if (Wire.endTransmission() != 0) return "NO_ACK";
  Wire.beginTransmission(encAddr);
  Wire.write(0x0B);
  if (Wire.endTransmission(false) != 0) return "NO_ACK";
  Wire.requestFrom(encAddr, (uint8_t)1);
  if (!Wire.available()) return "NO_ACK";
  uint8_t status = Wire.read();
  if (!(status & 0x20)) return "NO_MAGNET";
  Wire.beginTransmission(encAddr);
  Wire.write(0x1A);
  if (Wire.endTransmission(false) != 0) return "NO_ACK";
  Wire.requestFrom(encAddr, (uint8_t)1);
  if (!Wire.available()) return "NO_ACK";
  uint8_t agc = Wire.read();
  if (agc == 0 || agc == 255) return "AGC_SATURATED";
  return "OK";
}

bool checkSensors() {
  String inaResult = checkINA226();
  String encResult = checkAS5600();

  Serial.printf("🔬 INA226 @ 0x%02X: %s\n", inaAddr, inaResult.c_str());
  Serial.printf("🔬 AS5600 @ 0x%02X: %s\n", encAddr, encResult.c_str());

  bool inaNoAck = (inaResult == "NO_ACK" || inaResult == "NO_ADDR");
  bool encNoAck = (encResult == "NO_ACK" || encResult == "NO_ADDR");
  if (inaNoAck) inaFailCount++; else inaFailCount = 0;
  if (encNoAck) encFailCount++; else encFailCount = 0;

  if (inaFailCount >= 2 || encFailCount >= 2) {
    Serial.println("⚠️ CONSECUTIVE NO_ACK — attempting I2C recovery");
    recoverI2C();
    // Re-run full hardware detection after bus recovery
    bool redetected = detectHardware();
    inaFailCount = 0; encFailCount = 0;
    if (redetected && ina226 != nullptr) {
      // Re-init INA226 with potentially updated address
      delete ina226;
      ina226 = new INA226_WE(inaAddr);
      ina226->init();
      configureINAAlert();
    }
    inaResult = checkINA226();
    encResult = checkAS5600();
    bool recovered = (inaResult == "OK" && encResult == "OK");
    if (!recovered) {
      if (!i2cFault) {
        i2cFault = true;
        Serial.println("🔴 I2C RECOVERY FAILED — motor blocked");
        if (mqtt.connected()) {
          StaticJsonDocument<160> doc;
          doc["device_id"] = DEVICE_ID;
          doc["i2c_event"] = "I2C_RECOVERY_FAIL";
          doc["ina226"]    = inaResult;
          doc["as5600"]    = encResult;
          String out; serializeJson(doc, out);
          mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
        }
      }
    } else {
      if (i2cFault) {
        i2cFault = false;
        Serial.println("✅ I2C RECOVERED");
        publishHWProfile();   // re-publish updated addresses after recovery
        if (mqtt.connected()) {
          StaticJsonDocument<96> doc;
          doc["device_id"] = DEVICE_ID;
          doc["i2c_event"] = "I2C_RECOVERED";
          String out; serializeJson(doc, out);
          mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
        }
      }
    }
  } else {
    if (i2cFault && inaResult == "OK" && encResult == "OK") {
      i2cFault = false;
      Serial.println("✅ I2C RECOVERED");
      if (mqtt.connected()) {
        StaticJsonDocument<96> doc;
        doc["device_id"] = DEVICE_ID;
        doc["i2c_event"] = "I2C_RECOVERED";
        String out; serializeJson(doc, out);
        mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
      }
    }
  }

  if (mqtt.connected()) {
    StaticJsonDocument<192> doc;
    doc["device_id"] = DEVICE_ID;
    doc["ina226"]    = inaResult;
    doc["as5600"]    = encResult;
    char buf[8];
    snprintf(buf, sizeof(buf), "0x%02X", inaAddr); doc["ina_addr"] = String(buf);
    snprintf(buf, sizeof(buf), "0x%02X", encAddr); doc["enc_addr"] = String(buf);
    String out; serializeJson(doc, out);
    mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
  }

  return (inaResult == "OK" && encResult == "OK");
}




// ================== [INA ALERT] CONFIGURE HARDWARE ALERT ==================
void configureINAAlert() {
  if (inaAddr == 0x00) return;
  uint16_t alertLimit = (uint16_t)((CURRENT_OFF * 1000.0 * 10.0) / 2.5);
  Wire.beginTransmission(inaAddr);
  Wire.write(0x07);
  Wire.write((alertLimit >> 8) & 0xFF);
  Wire.write(alertLimit & 0xFF);
  Wire.endTransmission();
  Wire.beginTransmission(inaAddr);
  Wire.write(0x06);
  Wire.write(0x80);
  Wire.write(0x00);
  Wire.endTransmission();
  Serial.printf("⚡ INA226 ALERT @ 0x%02X: %.2fA threshold\n", inaAddr, CURRENT_OFF);
}




