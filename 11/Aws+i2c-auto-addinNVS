// ================== ENCODER ==================
int readAngle() {
  if (encAddr == 0x00) return -1;
  Wire.beginTransmission(encAddr);
  Wire.write(0x0E);
  Wire.endTransmission(false);
  Wire.requestFrom(encAddr, (uint8_t)2);
  if (Wire.available() == 2) {
    int high = Wire.read(); int low = Wire.read();
    return ((high << 8) | low) & 0x0FFF;
  }
  return -1;
}

void handleEncoder() {
  int a = readAngle(); if (a == -1) return;
  int diff = a - prevAngle;
  if (diff >  3000) rotationCount--;
  if (diff < -3000) rotationCount++;
  prevAngle = a; angle = a;
  totalTurns = rotationCount + (angle / 4096.0);
  if (motorState == FORWARD_RUN && totalTurns >= MAX_TURNS) {
    Serial.println("🛑 FORWARD LIMIT REACHED"); stopMotor();
  }
  if (motorState == REVERSE_RUN && totalTurns <= MIN_TURNS) {
    Serial.println("🛑 REVERSE LIMIT REACHED"); stopMotor();
  }
}




// ================== [BUZZ] BUZZER HANDLER ==================
void handleBuzzer() {
  bool limitActive = (digitalRead(LIMIT_SWITCH_PIN) == LOW);
  if (!limitActive) { digitalWrite(BUZZER_PIN, HIGH); buzzerTimer = millis(); return; }

  int mode = 1;
  if      (totalTurns <= MIN_TURNS) mode = 2;
  else if (totalTurns >= MAX_TURNS) mode = 3;

  unsigned long now = millis(), elapsed = now - buzzerTimer;

  if (mode == 1) {
    if      (elapsed < 150) digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 600) digitalWrite(BUZZER_PIN, HIGH);
    else                    buzzerTimer = now;
  } else if (mode == 2) {
    if      (elapsed < 150)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 300)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed < 450)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 600)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed >= 1100) buzzerTimer = now;
  } else {
    if      (elapsed < 150)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 300)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed < 450)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 600)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed < 750)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 900)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed >= 1400) buzzerTimer = now;
  }
}




// ================== LIMIT SWITCH ==================
void handleLimit() {
  bool limitNow = (digitalRead(LIMIT_SWITCH_PIN) == LOW);
  if (!limitOverride && limitNow && lastLimitState == HIGH) {
    Serial.println("🔴 LIMIT SWITCH"); stopMotor();
  }
  lastLimitState = limitNow;
}




// ================== CURRENT ==================
void handleCurrent() {
  float current = getCurrent();
  bool  over    = (current > CURRENT_OFF) || inaAlertFlag;

  if (inaAlertFlag) { inaAlertFlag = false; Serial.println("⚡ INA ALERT INTERRUPT FIRED"); }

  if (motorState != IDLE && over && !lastOvercurrent) {
    Serial.println("⚠️ OVERCURRENT");
    stopMotor(); retryCount++; ocTripTime = millis(); ocFault = true;
    Serial.printf("🔁 ATTEMPT: %d\n", retryCount);
    publishCurrentEvent("OC_TRIP", current);
    if (retryCount >= 3) {
      Serial.println("🔒 CURRENT LOCKED");
      lockFault = true; publishCurrentEvent("LOCKED", current);
    }
  }
  lastOvercurrent = over;

  if (ocFault && !lockFault && millis() - ocTripTime > RETRY_DELAY) {
    Serial.println("🔁 RETRYING");
    publishCurrentEvent("OC_RETRY", current);
    startMotor(lastDirection); ocFault = false;
  }

  static bool ocEventActive = false;
  if (ocEventActive && !over && !ocFault && !lockFault) {
    publishCurrentEvent("OC_RESET", current); ocEventActive = false;
  }
  if (ocFault && !lockFault) ocEventActive = true;
}




// ================== VOLTAGE ==================
void handleVoltageSafety() {
  float v = getVoltage();

  if (v <= CRITICAL_V && vState != LOCKED) {
    Serial.printf("🛑 CRITICAL: %.2fV → LOCK\n", v);
    stopMotor(); vState = LOCKED; publishVoltageEvent("LOCKED", v); return;
  }
  if (vState == LOCKED) {
    if (v >= RESET_V) { vState = NORMAL; publishVoltageEvent("NORMAL", v); } return;
  }
  if (vState == BYPASS_ACTIVE) {
    if (v <= CRITICAL_V) { stopMotor(); vState = LOCKED; publishVoltageEvent("LOCKED", v); return; }
    if (v >= RESET_V)    { vState = NORMAL; publishVoltageEvent("NORMAL", v); }
    return;
  }
  if (vState == WAIT_BYPASS) return;

  if (v < WARN_V_LOW) {
    if (vState == NORMAL) { vState = WARNING; warnPrintTimer = 0; publishVoltageEvent("WARNING", v); }
    if (millis() - warnPrintTimer > 5000) {
      warnPrintTimer = millis();
      Serial.printf("⚠️ VOLTAGE: %.2fV\n", v);
    }
  } else if (v > WARN_V_HIGH && vState == WARNING) {
    vState = NORMAL; publishVoltageEvent("NORMAL", v);
  }
  if (v < CUT_V && motorState != IDLE && vState != WAIT_BYPASS) {
    Serial.printf("🛑 LOW VOLTAGE CUT: %.2fV\n", v);
    stopMotor(); vState = WAIT_BYPASS; publishVoltageEvent("CUT", v);
  }
}




// ================== JSON COMMAND HANDLER ==================
bool sleepCommandReceived = false;

void handleJSONCommand(String input) {
  StaticJsonDocument<256> doc;
  if (deserializeJson(doc, input)) { Serial.println("❌ JSON ERROR"); return; }
  String id = doc["device_id"]; if (id != DEVICE_ID) return;
  String cmd = doc["cmd"];

  if      (cmd == "F") { startMotor(FORWARD_RUN); sleepCommandReceived = true; }
  else if (cmd == "R") { startMotor(REVERSE_RUN); sleepCommandReceived = true; }
  else if (cmd == "S") { stopMotor(); }

  else if (vState == WAIT_BYPASS) {
    if (cmd == "Y") {
      vState = BYPASS_ACTIVE; publishVoltageEvent("BYPASS", getVoltage());
      if (resumePending) { startMotor(resumeDirection); resumePending = false; }
      sleepCommandReceived = true;
    } else if (cmd == "N") { vState = WARNING; resumePending = false; sleepCommandReceived = true; }
  }

  else if (cmd == "SET_TIME") {
    String iso = doc["iso"] | "";
    if (iso.length() >= 19) {
      struct tm t;
      if (parseISO(iso, t) && rtcSetTime(t)) {
        Serial.println("✅ RTC TIME SET: " + iso);
        StaticJsonDocument<128> resp;
        resp["device_id"] = DEVICE_ID; resp["rtc_event"] = "TIME_SET"; resp["ts"] = getTimestamp();
        String out; serializeJson(resp, out); mqttPublish(pubStatusTopic.c_str(), out);
        armNextAlarm();
      } else { Serial.println("❌ RTC write failed"); }
    } else { Serial.println("❌ SET_TIME: missing iso field"); }
    sleepCommandReceived = true;
  }

  else if (cmd == "SCHEDULE") {
    int slot = doc["slot"] | -1;
    if (slot >= 0 && slot < SCHED_SLOTS) {
      String action = doc["action"] | "OPEN";
      String days   = doc["days"]   | "0000000";
      int    hour   = doc["hour"]   | 0;
      int    minute = doc["minute"] | 0;
      schedSlots[slot].enabled = true;
      schedSlots[slot].action  = (action == "CLOSE") ? 1 : 0;
      schedSlots[slot].hour    = (uint8_t)constrain(hour,   0, 23);
      schedSlots[slot].minute  = (uint8_t)constrain(minute, 0, 59);
      if (days.length() == 7) { memcpy(schedSlots[slot].days, days.c_str(), 7); schedSlots[slot].days[7] = '\0'; }
      else                    { memcpy(schedSlots[slot].days, "0000000", 7);    schedSlots[slot].days[7] = '\0'; }
      saveSchedule(); armNextAlarm(); publishSchedule();
      Serial.printf("📅 SLOT %d SET: %s %02d:%02d days=%s\n", slot, action.c_str(), hour, minute, days.c_str());
    } else { Serial.println("❌ SCHEDULE: invalid slot (0–7)"); }
    sleepCommandReceived = true;
  }

  else if (cmd == "CLEAR_SCHEDULE") {
    int slot = doc["slot"] | -1;
    if (slot >= 0 && slot < SCHED_SLOTS) {
      schedSlots[slot].enabled = false;
      memcpy(schedSlots[slot].days, "0000000", 7); schedSlots[slot].days[7] = '\0';
      saveSchedule(); armNextAlarm(); publishSchedule();
      Serial.printf("📅 SLOT %d CLEARED\n", slot);
    } else { Serial.println("❌ CLEAR_SCHEDULE: invalid slot (0–7)"); }
    sleepCommandReceived = true;
  }

  else if (cmd == "GET_SCHEDULE") { publishSchedule(); sleepCommandReceived = true; }

  else if (cmd == "GET_HW_PROFILE") { publishHWProfile(); sleepCommandReceived = true; }

  else if (cmd == "SET_CURRENT") {
    float newVal = doc["value"] | CURRENT_OFF;
    if (newVal > 0.1 && newVal < 10.0) {
      CURRENT_OFF = newVal;
      prefs.begin("device_cfg", false); prefs.putFloat("oc_thresh", CURRENT_OFF); prefs.end();
      lockFault = false; ocFault = false; retryCount = 0;
      configureINAAlert(); publishCurrentEvent("THRESHOLD_SET", getCurrent());
    } else { Serial.println("❌ INVALID CURRENT VALUE"); }
    sleepCommandReceived = true;
  }

  else if (cmd == "SET_TURNS") {
    float newTurns = doc["value"] | MAX_TURNS;
    if (newTurns >= 2.0 && newTurns <= 20.0) {
      MAX_TURNS = newTurns;
      prefs.begin("device_cfg", false); prefs.putFloat("max_turns", MAX_TURNS); prefs.end();
      publishFullStatus();
    } else { Serial.println("❌ INVALID TURNS VALUE (2.0–20.0)"); }
    sleepCommandReceived = true;
  }

  else if (cmd == "GET_STATUS")  { publishFullStatus(); sleepCommandReceived = true; }
  else if (cmd == "GET_SENSORS") { checkSensors();      sleepCommandReceived = true; }

  else if (cmd == "CHECK_UPDATE") {
    StaticJsonDocument<128> upd;
    upd["device_id"]        = DEVICE_ID;
    upd["update_available"] = updateAvailable;
    upd["current_version"]  = FW_VERSION;
    if (updateAvailable) upd["update_version"] = pendingUpdateVer;
    String out; serializeJson(upd, out); mqttPublish(pubStatusTopic.c_str(), out);
    sleepCommandReceived = true;
  }

  else if (cmd == "DO_UPDATE") {
    if (updateAvailable && pendingUpdateURL.length() > 0) {
      Serial.println("🚀 OTA ACCEPTED — waiting for motor idle");
      stopMotor(); fwState = FW_OTA_WAIT;
    } else { Serial.println("❌ NO UPDATE PENDING"); }
    sleepCommandReceived = true;
  }

  else { sleepCommandReceived = true; }
}




// ================== UPDATE TOPIC HANDLER ==================
void handleUpdatePayload(String payload) {
  StaticJsonDocument<256> doc;
  if (deserializeJson(doc, payload)) return;
  String version = doc["version"] | "";
  String url     = doc["url"]     | "";
  String sha256  = doc["sha256"]  | "";
  if (version.length() == 0) return;

  if (version != FW_VERSION) {
    updateAvailable  = true;
    pendingUpdateVer = version;
    pendingUpdateURL = url;
    pendingUpdateSHA = sha256;
    if (sha256.length() == 0) Serial.println("⚠️ No SHA-256 — integrity check skipped");
    StaticJsonDocument<192> notif;
    notif["device_id"]        = DEVICE_ID;
    notif["update_available"] = true;
    notif["update_version"]   = version;
    notif["current_version"]  = FW_VERSION;
    notif["note"]             = "Send DO_UPDATE to install";
    String out; serializeJson(notif, out); mqttPublish(pubStatusTopic.c_str(), out);
    sleepCommandReceived = true;
  } else {
    updateAvailable = false;
    Serial.println("✅ FIRMWARE UP TO DATE");
  }
}




// ================== [OTA] FULL OTA WITH TLS + CHECKSUM + ROLLBACK ==================
void performOTA() {
  Serial.println("🚀 OTA START");
  String url = pendingUpdateURL; String host = ""; String path = "/"; int port = 443;
  if (url.startsWith("https://")) url = url.substring(8);
  else if (url.startsWith("http://")) { url = url.substring(7); port = 80; }
  int slashIdx = url.indexOf('/');
  if (slashIdx == -1) { host = url; } else { host = url.substring(0, slashIdx); path = url.substring(slashIdx); }
  int colonIdx = host.indexOf(':');
  if (colonIdx != -1) { port = host.substring(colonIdx + 1).toInt(); host = host.substring(0, colonIdx); }

  if (!otaClient.connect(host.c_str(), port)) {
    Serial.println("❌ OTA TCP failed");
    if (mqtt.connected()) { StaticJsonDocument<96> e; e["device_id"]=DEVICE_ID; e["ota_event"]="OTA_FAIL"; e["reason"]="TCP_CONNECT"; String o; serializeJson(e,o); mqttPublish(pubStatusTopic.c_str(),o); }
    fwState = FW_ACTIVE; return;
  }
  otaClient.print(String("GET ") + path + " HTTP/1.1\r\nHost: " + host + "\r\nConnection: close\r\n\r\n");

  unsigned long hdrT = millis(); int contentLength = -1; bool hdrDone = false;
  while (!hdrDone && millis() - hdrT < 10000) {
    if (otaClient.available()) {
      String line = otaClient.readStringUntil('\n'); line.trim();
      if (line.startsWith("Content-Length:") || line.startsWith("content-length:"))
        contentLength = line.substring(line.indexOf(':') + 1).toInt();
      if (line.length() == 0) hdrDone = true;
    }
  }
  if (contentLength <= 0 || !Update.begin(contentLength)) {
    otaClient.stop();
    if (mqtt.connected()) { StaticJsonDocument<96> e; e["device_id"]=DEVICE_ID; e["ota_event"]="OTA_FAIL"; e["reason"]="BAD_CONTENT_LENGTH"; String o; serializeJson(e,o); mqttPublish(pubStatusTopic.c_str(),o); }
    fwState = FW_ACTIVE; return;
  }

  bool doChecksum = (pendingUpdateSHA.length() == 64);
  mbedtls_sha256_context sha256ctx;
  if (doChecksum) { mbedtls_sha256_init(&sha256ctx); mbedtls_sha256_starts(&sha256ctx, 0); }

  uint8_t buf[256]; int written = 0; int lastPct = -1; unsigned long dataT = millis();
  while (written < contentLength) {
    if (!otaClient.connected() && !otaClient.available()) { Serial.println("❌ OTA dropped"); break; }
    int rd = otaClient.readBytes(buf, min((int)sizeof(buf), contentLength - written));
    if (rd > 0) {
      Update.write(buf, rd);
      if (doChecksum) mbedtls_sha256_update(&sha256ctx, buf, rd);
      written += rd; dataT = millis();
      int pct = (written * 100) / contentLength; int bucket = pct / 10;
      if (bucket != lastPct) {
        lastPct = bucket; Serial.printf("📶 OTA: %d%%\n", pct);
        if (mqtt.connected()) { StaticJsonDocument<96> p; p["device_id"]=DEVICE_ID; p["ota_event"]="OTA_PROGRESS"; p["progress_pct"]=pct; String o; serializeJson(p,o); mqttPublish(pubStatusTopic.c_str(),o); }
      }
    } else if (millis() - dataT > 10000) { Serial.println("❌ OTA timeout"); break; }
  }
  otaClient.stop();

  if (written != contentLength) {
    Update.abort(); if (doChecksum) mbedtls_sha256_free(&sha256ctx);
    if (mqtt.connected()) { StaticJsonDocument<96> e; e["device_id"]=DEVICE_ID; e["ota_event"]="OTA_FAIL"; e["reason"]="INCOMPLETE_WRITE"; String o; serializeJson(e,o); mqttPublish(pubStatusTopic.c_str(),o); }
    fwState = FW_ACTIVE; return;
  }

  if (doChecksum) {
    uint8_t digest[32]; mbedtls_sha256_finish(&sha256ctx, digest); mbedtls_sha256_free(&sha256ctx);
    char hex[65]; for (int i=0;i<32;i++) sprintf(hex+i*2,"%02x",digest[i]); hex[64]='\0';
    if (String(hex) != pendingUpdateSHA) {
      Serial.println("❌ CHECKSUM MISMATCH"); Update.abort();
      if (mqtt.connected()) { StaticJsonDocument<96> e; e["device_id"]=DEVICE_ID; e["ota_event"]="OTA_FAIL"; e["reason"]="CHECKSUM_MISMATCH"; String o; serializeJson(e,o); mqttPublish(pubStatusTopic.c_str(),o); }
      fwState = FW_ACTIVE; return;
    }
    Serial.println("✅ CHECKSUM OK");
  }

  if (!Update.end()) {
    if (mqtt.connected()) { StaticJsonDocument<96> e; e["device_id"]=DEVICE_ID; e["ota_event"]="OTA_FAIL"; e["reason"]="UPDATE_END"; String o; serializeJson(e,o); mqttPublish(pubStatusTopic.c_str(),o); }
    fwState = FW_ACTIVE; return;
  }

  prefs.begin("device_cfg", false); prefs.putString("boot_check", "PENDING"); prefs.end();
  Serial.println("✅ OTA WRITTEN — rebooting");
  if (mqtt.connected()) {
    StaticJsonDocument<96> d; d["device_id"]=DEVICE_ID; d["ota_event"]="OTA_DONE"; d["update_version"]=pendingUpdateVer;
    String o; serializeJson(d,o); mqttPublish(pubStatusTopic.c_str(),o); delay(500);
  }
  ESP.restart();
}




