uint8_t bcdToDec(uint8_t b) { return (b / 16 * 10) + (b % 16); }
uint8_t decToBcd(uint8_t d) { return (d / 10 * 16) + (d % 10); }

// All RTC driver functions use rtcAddr variable (set by detectHardware)
// so they work regardless of whether the chip is at 0x51 or a clone address.

bool rtcGetTime(struct tm &t) {
  Wire.beginTransmission(rtcAddr);
  Wire.write(0x02);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(rtcAddr, (uint8_t)7);
  if (Wire.available() < 7) return false;

  uint8_t sec = Wire.read();
  if (sec & 0x80) return false;             // VL flag — clock integrity lost
  t.tm_sec  = bcdToDec(sec  & 0x7F);
  t.tm_min  = bcdToDec(Wire.read() & 0x7F);
  t.tm_hour = bcdToDec(Wire.read() & 0x3F);
  t.tm_mday = bcdToDec(Wire.read() & 0x3F);
  t.tm_wday = bcdToDec(Wire.read() & 0x07);
  uint8_t monthRaw = Wire.read();
  t.tm_mon  = bcdToDec(monthRaw & 0x1F) - 1;
  t.tm_year = bcdToDec(Wire.read()) + 100;
  return true;
}

bool rtcSetTime(const struct tm &t) {
  Wire.beginTransmission(rtcAddr);
  Wire.write(0x02);
  Wire.write(decToBcd(t.tm_sec)  & 0x7F);
  Wire.write(decToBcd(t.tm_min)  & 0x7F);
  Wire.write(decToBcd(t.tm_hour) & 0x3F);
  Wire.write(decToBcd(t.tm_mday) & 0x3F);
  Wire.write(decToBcd(t.tm_wday) & 0x07);
  Wire.write(decToBcd(t.tm_mon + 1) & 0x1F);
  Wire.write(decToBcd(t.tm_year - 100));
  if (Wire.endTransmission() != 0) return false;
  return true;
}

bool rtcIsValid() {
  if (rtcAddr == 0x00) return false;
  Wire.beginTransmission(rtcAddr);
  Wire.write(0x02);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(rtcAddr, (uint8_t)1);
  if (!Wire.available()) return false;
  uint8_t sec = Wire.read();
  return !(sec & 0x80);
}

String rtcFormatISO(const struct tm &t) {
  char buf[25];
  snprintf(buf, sizeof(buf), "%04d-%02d-%02dT%02d:%02d:%02dZ",
           t.tm_year + 1900, t.tm_mon + 1, t.tm_mday,
           t.tm_hour, t.tm_min, t.tm_sec);
  return String(buf);
}

String getTimestamp() {
  struct tm t;
  if (!rtcIsValid()) return "RTC_INVALID";
  if (!rtcGetTime(t)) return "RTC_READ_ERR";
  return rtcFormatISO(t);
}

bool parseISO(const String &iso, struct tm &t) {
  if (iso.length() < 19) return false;
  t.tm_year = iso.substring(0,  4).toInt() - 1900;
  t.tm_mon  = iso.substring(5,  7).toInt() - 1;
  t.tm_mday = iso.substring(8,  10).toInt();
  t.tm_hour = iso.substring(11, 13).toInt();
  t.tm_min  = iso.substring(14, 16).toInt();
  t.tm_sec  = iso.substring(17, 19).toInt();
  int y = t.tm_year + 1900; int m = t.tm_mon + 1;
  if (m < 3) { m += 12; y--; }
  int k = y % 100; int j = y / 100;
  int h = (t.tm_mday + (13*(m+1))/5 + k + k/4 + j/4 + 5*j) % 7;
  t.tm_wday = (h + 6) % 7;
  return true;
}




// ================== [HW] HARDWARE AUTO-DETECTION ==================
//
// Detection order: INA226 → AS5600 → PCF8563
// Each device is validated beyond a bare ACK to avoid false positives
// when two devices share an address range or a bus glitch causes a ghost ACK.
//
// After detection, addresses are cached in NVS "hw_profile" namespace.
// On subsequent boots the cached addresses are loaded and verified with a
// single ACK ping. If the ping fails the full scan runs again.
//
// Returns true if all three devices were found (cached or freshly scanned).
// Sets inaAddr, encAddr, rtcAddr as side effects.
// Sets i2cFault = true if any device cannot be found.

// ── INA226 validator ──
// Reads manufacturer ID register 0xFE. Texas Instruments INA226 always
// returns 0x5449 ("TI"). Any other value means a false-positive ACK.
bool validateINA226(uint8_t addr) {
  Wire.beginTransmission(addr);
  Wire.write(0xFE);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(addr, (uint8_t)2);
  if (Wire.available() < 2) return false;
  uint16_t mfr = ((uint16_t)Wire.read() << 8) | Wire.read();
  return (mfr == 0x5449);
}

// ── AS5600 validator ──
// STATUS register 0x0B: bit5=MH (too strong), bit4=ML (too weak), bit3=MD (detected).
// At least one of MH/ML/MD must be set to confirm a real AS5600 is present.
// A bare I2C ACK at 0x36 from another device would not pass this check.
bool validateAS5600(uint8_t addr) {
  Wire.beginTransmission(addr);
  Wire.write(0x0B);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(addr, (uint8_t)1);
  if (!Wire.available()) return false;
  uint8_t status = Wire.read();
  return (status & 0x38) != 0;   // bits 5,4,3 — any magnet flag set
}

// ── PCF8563 validator ──
// The CLKOUT register (0x0D) has a known fixed bit pattern on reset:
// bit7 = FE (clock output enable, default 1), bits [2:0] = FD (frequency, default 0b011 = 1Hz)
// We read 0x0D and check that reserved bits [6:3] are zero, and bit7 is readable.
// This safely confirms PCF8563 / HYM8563 / compatible without disturbing time registers.
bool validatePCF8563(uint8_t addr) {
  Wire.beginTransmission(addr);
  Wire.write(0x0D);
  if (Wire.endTransmission(false) != 0) return false;
  Wire.requestFrom(addr, (uint8_t)1);
  if (!Wire.available()) return false;
  uint8_t clkout = Wire.read();
  // Reserved bits [6:3] must be 0 on a real PCF8563
  return (clkout & 0x78) == 0x00;
}

// ── NVS save / load for hw_profile ──
void saveHWProfile() {
  prefs.begin("hw_profile", false);
  prefs.putUChar("ina_addr", inaAddr);
  prefs.putUChar("enc_addr", encAddr);
  prefs.putUChar("rtc_addr", rtcAddr);
  prefs.end();
  Serial.printf("💾 HW PROFILE SAVED — INA:0x%02X ENC:0x%02X RTC:0x%02X\n",
                inaAddr, encAddr, rtcAddr);
}

void loadHWProfile() {
  prefs.begin("hw_profile", true);
  inaAddr = prefs.getUChar("ina_addr", 0x00);
  encAddr = prefs.getUChar("enc_addr", 0x00);
  rtcAddr = prefs.getUChar("rtc_addr", 0x00);
  prefs.end();
}

// ── Quick ACK ping ──
bool i2cAck(uint8_t addr) {
  Wire.beginTransmission(addr);
  return Wire.endTransmission() == 0;
}

// ── Publish hardware profile to AWS ──
void publishHWProfile() {
  if (!mqtt.connected()) return;
  StaticJsonDocument<192> doc;
  doc["device_id"] = DEVICE_ID;
  doc["event"]     = "HW_PROFILE";
  char buf[8];
  JsonObject hw = doc.createNestedObject("hw_profile");
  snprintf(buf, sizeof(buf), "0x%02X", inaAddr); hw["ina_addr"] = String(buf);
  snprintf(buf, sizeof(buf), "0x%02X", encAddr); hw["enc_addr"] = String(buf);
  snprintf(buf, sizeof(buf), "0x%02X", rtcAddr); hw["rtc_addr"] = String(buf);
  doc["ts"] = getTimestamp();
  String out; serializeJson(doc, out);
  mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);
  Serial.print("📤 HW PROFILE: "); Serial.println(out);
}

// ── Main detection function ──
// Call once in setup() after Wire.begin(). Sets inaAddr/encAddr/rtcAddr.
// Returns true only if all three devices are confirmed.
bool detectHardware() {
  Serial.println("🔍 HW DETECT — loading NVS cache...");
  loadHWProfile();

  bool inaOK = false, encOK = false, rtcOK = false;

  // ── Try cached addresses first (fast path — no full scan) ──
  if (inaAddr != 0x00 && i2cAck(inaAddr) && validateINA226(inaAddr)) {
    Serial.printf("✅ INA226 @ 0x%02X (cached)\n", inaAddr);
    inaOK = true;
  }
  if (encAddr != 0x00 && i2cAck(encAddr) && validateAS5600(encAddr)) {
    Serial.printf("✅ AS5600 @ 0x%02X (cached)\n", encAddr);
    encOK = true;
  }
  if (rtcAddr != 0x00 && i2cAck(rtcAddr) && validatePCF8563(rtcAddr)) {
    Serial.printf("✅ PCF8563 @ 0x%02X (cached)\n", rtcAddr);
    rtcOK = true;
  }

  // ── Full scan for any device that failed its cache check ──
  if (!inaOK || !encOK || !rtcOK) {
    Serial.println("🔍 HW DETECT — scanning I2C bus...");

    // INA226: scan 0x40–0x4F
    if (!inaOK) {
      inaAddr = 0x00;
      for (uint8_t addr = 0x40; addr <= 0x4F; addr++) {
        if (i2cAck(addr) && validateINA226(addr)) {
          inaAddr = addr;
          Serial.printf("✅ INA226 found @ 0x%02X\n", addr);
          inaOK = true;
          break;
        }
      }
      if (!inaOK) Serial.println("❌ INA226 NOT FOUND (scanned 0x40–0x4F)");
    }

    // AS5600: fixed at 0x36
    if (!encOK) {
      encAddr = 0x00;
      if (i2cAck(0x36) && validateAS5600(0x36)) {
        encAddr = 0x36;
        Serial.println("✅ AS5600 found @ 0x36");
        encOK = true;
      } else {
        Serial.println("❌ AS5600 NOT FOUND (0x36)");
      }
    }

    // PCF8563 and compatible clones: fixed at 0x51
    if (!rtcOK) {
      rtcAddr = 0x00;
      if (i2cAck(0x51) && validatePCF8563(0x51)) {
        rtcAddr = 0x51;
        Serial.printf("✅ PCF8563 found @ 0x51\n");
        rtcOK = true;
      } else {
        Serial.println("❌ PCF8563 NOT FOUND (0x51)");
      }
    }

    // Save updated profile to NVS whenever any address changed
    if (inaOK && encOK && rtcOK) {
      saveHWProfile();
    }
  }

  bool allOK = inaOK && encOK && rtcOK;
  if (!allOK) {
    Serial.println("🔴 HW DETECT FAILED — one or more I2C devices missing");
    Serial.printf("   INA226: %s  AS5600: %s  PCF8563: %s\n",
                  inaOK ? "OK" : "MISSING",
                  encOK ? "OK" : "MISSING",
                  rtcOK ? "OK" : "MISSING");
  } else {
    Serial.println("✅ HW DETECT COMPLETE — all devices confirmed");
  }
  return allOK;
}




// ================== [SCHED] SCHEDULE ENGINE ==================
#define SCHED_SLOTS 8

struct SchedSlot {
  bool    enabled;
  uint8_t action;   // 0=OPEN, 1=CLOSE
  uint8_t hour;
  uint8_t minute;
  char    days[8];  // "0100101\0"
};

SchedSlot schedSlots[SCHED_SLOTS];

void saveSchedule() {
  prefs.begin("schedule", false);
  for (int i = 0; i < SCHED_SLOTS; i++) {
    String key = "slot" + String(i);
    uint8_t buf[12];
    buf[0] = schedSlots[i].enabled ? 1 : 0;
    buf[1] = schedSlots[i].action;
    buf[2] = schedSlots[i].hour;
    buf[3] = schedSlots[i].minute;
    memcpy(buf + 4, schedSlots[i].days, 7);
    buf[11] = 0;
    prefs.putBytes(key.c_str(), buf, 12);
  }
  prefs.end();
  Serial.println("💾 SCHEDULE SAVED");
}

void loadSchedule() {
  prefs.begin("schedule", true);
  for (int i = 0; i < SCHED_SLOTS; i++) {
    String key = "slot" + String(i);
    uint8_t buf[12] = {0};
    size_t len = prefs.getBytes(key.c_str(), buf, 12);
    if (len == 12) {
      schedSlots[i].enabled = buf[0];
      schedSlots[i].action  = buf[1];
      schedSlots[i].hour    = buf[2];
      schedSlots[i].minute  = buf[3];
      memcpy(schedSlots[i].days, buf + 4, 7);
      schedSlots[i].days[7] = '\0';
    } else {
      schedSlots[i].enabled = false;
      schedSlots[i].action  = 0;
      schedSlots[i].hour    = 0;
      schedSlots[i].minute  = 0;
      memcpy(schedSlots[i].days, "0000000", 7);
      schedSlots[i].days[7] = '\0';
    }
  }
  prefs.end();
  Serial.println("📂 SCHEDULE LOADED");
}

bool slotActiveToday(const SchedSlot &slot, int wday) {
  return slot.days[wday] == '1';
}

void armAlarm1(uint8_t hour, uint8_t minute) {
  Wire.beginTransmission(rtcAddr);
  Wire.write(0x01);
  if (Wire.endTransmission(false) == 0) {
    Wire.requestFrom(rtcAddr, (uint8_t)1);
    uint8_t ctrl2 = Wire.available() ? Wire.read() : 0;
    ctrl2 &= ~0x08;
    Wire.beginTransmission(rtcAddr);
    Wire.write(0x01);
    Wire.write(ctrl2);
    Wire.endTransmission();
  }
  Wire.beginTransmission(rtcAddr);
  Wire.write(0x09);
  Wire.write(decToBcd(minute) & 0x7F);
  Wire.write(decToBcd(hour)   & 0x3F);
  Wire.write(0x80);
  Wire.write(0x80);
  Wire.endTransmission();
  Wire.beginTransmission(rtcAddr);
  Wire.write(0x01);
  if (Wire.endTransmission(false) == 0) {
    Wire.requestFrom(rtcAddr, (uint8_t)1);
    uint8_t ctrl2 = Wire.available() ? Wire.read() : 0;
    ctrl2 |= 0x02;
    Wire.beginTransmission(rtcAddr);
    Wire.write(0x01);
    Wire.write(ctrl2);
    Wire.endTransmission();
  }
  Serial.printf("⏰ ALARM ARMED: %02d:%02d\n", hour, minute);
}

void clearAlarm1Flag() {
  Wire.beginTransmission(rtcAddr);
  Wire.write(0x01);
  if (Wire.endTransmission(false) != 0) return;
  Wire.requestFrom(rtcAddr, (uint8_t)1);
  uint8_t ctrl2 = Wire.available() ? Wire.read() : 0;
  ctrl2 &= ~0x08;
  Wire.beginTransmission(rtcAddr);
  Wire.write(0x01);
  Wire.write(ctrl2);
  Wire.endTransmission();
}

void armNextAlarm() {
  if (!rtcIsValid()) { Serial.println("⚠️ RTC invalid — cannot arm scheduler"); return; }
  struct tm now;
  if (!rtcGetTime(now)) return;

  int bestSlot = -1, bestMinutes = 9999;
  int nowMinutes = now.tm_hour * 60 + now.tm_min;

  for (int i = 0; i < SCHED_SLOTS; i++) {
    if (!schedSlots[i].enabled) continue;
    for (int dayOffset = 0; dayOffset <= 7; dayOffset++) {
      int checkWday = (now.tm_wday + dayOffset) % 7;
      if (!slotActiveToday(schedSlots[i], checkWday)) continue;
      int slotMinutes = schedSlots[i].hour * 60 + schedSlots[i].minute;
      int diff;
      if (dayOffset == 0) { diff = slotMinutes - nowMinutes; if (diff <= 0) continue; }
      else                { diff = dayOffset * 1440 + slotMinutes - nowMinutes; }
      if (diff < bestMinutes) { bestMinutes = diff; bestSlot = i; }
      break;
    }
  }

  if (bestSlot == -1) { Serial.println("📅 No active schedule slots"); return; }
  armAlarm1(schedSlots[bestSlot].hour, schedSlots[bestSlot].minute);
  Serial.printf("📅 Next: slot %d → %s at %02d:%02d\n",
                bestSlot,
                schedSlots[bestSlot].action == 0 ? "OPEN" : "CLOSE",
                schedSlots[bestSlot].hour,
                schedSlots[bestSlot].minute);
}

void handleScheduledAlarms() {
  if (!rtcIsValid()) return;
  struct tm now;
  if (!rtcGetTime(now)) return;

  for (int i = 0; i < SCHED_SLOTS; i++) {
    if (!schedSlots[i].enabled) continue;
    if (!slotActiveToday(schedSlots[i], now.tm_wday)) continue;
    if (schedSlots[i].hour   != (uint8_t)now.tm_hour) continue;
    if (schedSlots[i].minute != (uint8_t)now.tm_min)  continue;
    Serial.printf("📅 SCHEDULED ACTION: slot %d → %s\n", i,
                  schedSlots[i].action == 0 ? "OPEN (FORWARD)" : "CLOSE (REVERSE)");
    if (schedSlots[i].action == 0) startMotor(FORWARD_RUN);
    else                           startMotor(REVERSE_RUN);
    if (mqtt.connected()) {
      StaticJsonDocument<192> doc;
      doc["device_id"]   = DEVICE_ID;
      doc["sched_event"] = (schedSlots[i].action == 0) ? "SCHED_OPEN" : "SCHED_CLOSE";
      doc["slot"]        = i;
      doc["ts"]          = getTimestamp();
      String out; serializeJson(doc, out);
      mqtt.publish(pubEventTopic.c_str(), out.c_str(), false, 1);
    }
  }
  clearAlarm1Flag();
  armNextAlarm();
}

void publishSchedule() {
  StaticJsonDocument<512> doc;
  doc["device_id"] = DEVICE_ID;
  doc["ts"]        = getTimestamp();
  JsonArray arr    = doc.createNestedArray("schedule");
  for (int i = 0; i < SCHED_SLOTS; i++) {
    JsonObject s = arr.createNestedObject();
