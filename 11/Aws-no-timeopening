// Loads PEM strings from NVS and configures TinyGsmClientSecure.
// Called once in FW_TLS_INIT state.
bool loadAndApplyTLSCredentials() {
  Serial.println("🔐 Loading TLS credentials from NVS...");

  prefs.begin("aws_creds", true);
  awsEndpoint = prefs.getString("endpoint", "");
  awsCert     = prefs.getString("cert",     "");
  awsPkey     = prefs.getString("pkey",     "");
  awsRootCA   = prefs.getString("rootca",   "");
  prefs.end();

  if (awsEndpoint.length() == 0) { Serial.println("❌ TLS: endpoint missing");  return false; }
  if (awsCert.length()     == 0) { Serial.println("❌ TLS: cert missing");      return false; }
  if (awsPkey.length()     == 0) { Serial.println("❌ TLS: private key missing"); return false; }
  if (awsRootCA.length()   == 0) { Serial.println("❌ TLS: root CA missing");   return false; }

  // Apply to both MQTT and OTA secure clients
  gsmClient.setCACert(awsRootCA.c_str());
  gsmClient.setCertificate(awsCert.c_str());
  gsmClient.setPrivateKey(awsPkey.c_str());

  otaClient.setCACert(awsRootCA.c_str());
  otaClient.setCertificate(awsCert.c_str());
  otaClient.setPrivateKey(awsPkey.c_str());

  Serial.println("✅ TLS credentials applied");
  Serial.print("🌐 AWS Endpoint: "); Serial.println(awsEndpoint);
  return true;
}




// ================== [I2C-REC] BUS RECOVERY ==================
void recoverI2C() {
  Serial.println("🔧 I2C RECOVERY — bit-bang clock pulses");
  pinMode(SDA_PIN, INPUT_PULLUP);
  pinMode(SCL_PIN, OUTPUT);
  for (int i = 0; i < 9; i++) {
    digitalWrite(SCL_PIN, HIGH); delayMicroseconds(5);
    digitalWrite(SCL_PIN, LOW);  delayMicroseconds(5);
    if (digitalRead(SDA_PIN) == HIGH) {
      Serial.print("✅ SDA released after "); Serial.print(i + 1); Serial.println(" pulses");
      break;
    }
  }
  pinMode(SDA_PIN, OUTPUT);
  digitalWrite(SDA_PIN, LOW);  delayMicroseconds(5);
  digitalWrite(SCL_PIN, HIGH); delayMicroseconds(5);
  digitalWrite(SDA_PIN, HIGH); delayMicroseconds(5);
  Wire.begin(SDA_PIN, SCL_PIN);
  Serial.println("🔧 I2C Wire reinitialised");
}




// ================== [SENSOR] HEALTH CHECK ==================
String checkINA226() {
  Wire.beginTransmission(INA_ADDR);
  if (Wire.endTransmission() != 0) return "NO_ACK";
  Wire.beginTransmission(INA_ADDR);
  Wire.write(0xFE);
  if (Wire.endTransmission(false) != 0) return "NO_ACK";
  Wire.requestFrom(INA_ADDR, 2);
  if (Wire.available() < 2) return "NO_ACK";
  uint16_t mfr = ((uint16_t)Wire.read() << 8) | Wire.read();
  if (mfr != 0x5449) return "BAD_ID";
  return "OK";
}

String checkAS5600() {
  Wire.beginTransmission(AS5600_ADDR);
  if (Wire.endTransmission() != 0) return "NO_ACK";
  Wire.beginTransmission(AS5600_ADDR);
  Wire.write(0x0B);
  if (Wire.endTransmission(false) != 0) return "NO_ACK";
  Wire.requestFrom(AS5600_ADDR, 1);
  if (!Wire.available()) return "NO_ACK";
  uint8_t status = Wire.read();
  if (!(status & 0x20)) return "NO_MAGNET";
  Wire.beginTransmission(AS5600_ADDR);
  Wire.write(0x1A);
  if (Wire.endTransmission(false) != 0) return "NO_ACK";
  Wire.requestFrom(AS5600_ADDR, 1);
  if (!Wire.available()) return "NO_ACK";
  uint8_t agc = Wire.read();
  if (agc == 0 || agc == 255) return "AGC_SATURATED";
  return "OK";
}

bool checkSensors() {
  String inaResult = checkINA226();
  String encResult = checkAS5600();

  Serial.print("🔬 INA226: "); Serial.println(inaResult);
  Serial.print("🔬 AS5600: "); Serial.println(encResult);

  bool inaNoAck = (inaResult == "NO_ACK");
  bool encNoAck = (encResult == "NO_ACK");
  if (inaNoAck) inaFailCount++; else inaFailCount = 0;
  if (encNoAck) encFailCount++; else encFailCount = 0;

  if (inaFailCount >= 2 || encFailCount >= 2) {
    Serial.println("⚠️ CONSECUTIVE NO_ACK — attempting I2C recovery");
    recoverI2C();
    inaResult = checkINA226();
    encResult = checkAS5600();
    inaFailCount = 0; encFailCount = 0;

    bool recovered = (inaResult == "OK" && encResult == "OK");
    if (!recovered) {
      if (!i2cFault) {
        i2cFault = true;
        Serial.println("🔴 I2C RECOVERY FAILED — motor blocked");
        if (mqtt.connected()) {
          StaticJsonDocument<128> doc;
          doc["device_id"] = DEVICE_ID;
          doc["i2c_event"] = "I2C_RECOVERY_FAIL";
          doc["ina226"]    = inaResult;
          doc["as5600"]    = encResult;
          String out; serializeJson(doc, out);
          mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);  // [QOS1]
        }
      }
    } else {
      if (i2cFault) {
        i2cFault = false;
        Serial.println("✅ I2C RECOVERED");
        if (mqtt.connected()) {
          StaticJsonDocument<96> doc;
          doc["device_id"] = DEVICE_ID;
          doc["i2c_event"] = "I2C_RECOVERED";
          String out; serializeJson(doc, out);
          mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);  // [QOS1]
        }
      }
    }
  } else {
    if (i2cFault && inaResult == "OK" && encResult == "OK") {
      i2cFault = false;
      Serial.println("✅ I2C RECOVERED");
      if (mqtt.connected()) {
        StaticJsonDocument<96> doc;
        doc["device_id"] = DEVICE_ID;
        doc["i2c_event"] = "I2C_RECOVERED";
        String out; serializeJson(doc, out);
        mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);   // [QOS1]
      }
    }
  }

  if (mqtt.connected()) {
    StaticJsonDocument<160> doc;
    doc["device_id"] = DEVICE_ID;
    doc["ina226"]    = inaResult;
    doc["as5600"]    = encResult;
    String out; serializeJson(doc, out);
    mqtt.publish(pubStatusTopic.c_str(), out.c_str(), false, 1);       // [QOS1]
  }

  return (inaResult == "OK" && encResult == "OK");
}




// ================== [INA ALERT] CONFIGURE HARDWARE ALERT ==================
// Sets INA226 Alert pin to trigger on shunt over-limit (overcurrent).
// Alert fires when current exceeds CURRENT_OFF threshold.
// Called once after ina226.init() in setup().
void configureINAAlert() {
  // INA226 shunt voltage at threshold = CURRENT_OFF * R_shunt
  // Assuming 10 mΩ shunt resistor (adjust to your PCB value)
  // Alert Limit register = threshold_mV * 1000 / 2.5 uV per LSB
  // For 1.5A * 0.010 Ω = 15 mV → 15000 uV / 2.5 = 6000 LSB
  uint16_t alertLimit = (uint16_t)((CURRENT_OFF * 1000.0 * 10.0) / 2.5);

  // Write Alert Limit register (0x07)
  Wire.beginTransmission(INA_ADDR);
  Wire.write(0x07);
  Wire.write((alertLimit >> 8) & 0xFF);
  Wire.write(alertLimit & 0xFF);
  Wire.endTransmission();

  // Write Mask/Enable register (0x06): enable SOL (Shunt Over-Limit) bit 15
  Wire.beginTransmission(INA_ADDR);
  Wire.write(0x06);
  Wire.write(0x80);   // SOL bit
  Wire.write(0x00);
  Wire.endTransmission();

  Serial.print("⚡ INA226 ALERT configured: ");
  Serial.print(CURRENT_OFF, 2); Serial.println("A threshold");
}




