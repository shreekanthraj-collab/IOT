// ================== LTE ==================
void handleLTE() { while (SerialAT.available()) Serial.write(SerialAT.read()); }

void handleLTEInit() {
  unsigned long now = millis();
  switch (lteState) {
    case LTE_AT:     SerialAT.println("AT"); lteTimer = now; lteState = LTE_CPIN; break;
    case LTE_CPIN:   if (now - lteTimer < LTE_STEP_MS)  { handleLTE(); break; } SerialAT.println("AT+CPIN?"); lteTimer = now; lteState = LTE_CSQ; break;
    case LTE_CSQ:    if (now - lteTimer < LTE_STEP_MS)  { handleLTE(); break; } SerialAT.println("AT+CSQ"); lteTimer = now; lteState = LTE_CREG; lteRegTries = 0; break;
    case LTE_CREG:
      if (now - lteTimer < LTE_REG_MS) { handleLTE(); break; }
      lteTimer = now; SerialAT.println("AT+CREG?");
      { unsigned long ps = millis(); String r = ""; while (millis()-ps < 500) { while (SerialAT.available()) r += char(SerialAT.read()); }
        Serial.println(r);
        if (r.indexOf("0,1") != -1 || r.indexOf("0,5") != -1) { Serial.println("✅ REGISTERED"); lteState = LTE_CGATT; }
        else { lteRegTries++; if (lteRegTries >= 20) { Serial.println("❌ NETWORK FAILED"); lteReady = false; lteState = LTE_DONE; } } }
      break;
    case LTE_CGATT:  SerialAT.println("AT+CGATT=1"); lteTimer = now; lteState = LTE_CGDCONT; break;
    case LTE_CGDCONT: if (now - lteTimer < LTE_LONG_MS)  { handleLTE(); break; } SerialAT.println("AT+CGDCONT=1,\"IP\",\"iot.com\""); lteTimer = now; lteState = LTE_CGACT; break;
    case LTE_CGACT:  if (now - lteTimer < LTE_REG_MS)   { handleLTE(); break; } SerialAT.println("AT+CGACT=1,1"); lteTimer = now; lteState = LTE_CGPADDR; break;
    case LTE_CGPADDR: if (now - lteTimer < LTE_XLONG_MS) { handleLTE(); break; } SerialAT.println("AT+CGPADDR=1"); lteTimer = now; lteState = LTE_PING; break;
    case LTE_PING:   if (now - lteTimer < LTE_REG_MS)   { handleLTE(); break; } SerialAT.println("AT+QPING=1,\"8.8.8.8\""); lteTimer = now; lteState = LTE_DONE; break;
    case LTE_DONE:   if (now - lteTimer < LTE_XLONG_MS)  { handleLTE(); break; } lteReady = true; Serial.println("✅ LTE READY"); fwState = FW_TLS_INIT; break;
  }
}




// ================== MQTT ==================
void mqttCallback(char* topic, byte* payload, unsigned int length) {
  String msg = ""; for (unsigned int i = 0; i < length; i++) msg += (char)payload[i];
  Serial.println("📩 MQTT:"); Serial.println(msg);
  String t = String(topic);
  if (t == subUpdateTopic) handleUpdatePayload(msg);
  else                     handleJSONCommand(msg);
}

void connectMQTT() {
  if (mqtt.connected()) return;
  if (!tlsReady) { Serial.println("⚠️ TLS not ready — MQTT connect skipped"); return; }
  if (millis() - mqttRetryTimer < 5000) return;
  mqttRetryTimer = millis();
  Serial.println("🌐 AWS MQTT CONNECTING...");
  mqtt.setServer(awsEndpoint.c_str(), awsPort);
  mqtt.setCallback(mqttCallback);
  mqtt.setBufferSize(512);
  if (mqtt.connect(DEVICE_ID.c_str())) {
    Serial.println("✅ AWS MQTT CONNECTED");
    mqtt.subscribe(subCmdTopic.c_str(), 1);         // QoS 1
    mqtt.subscribe(subUpdateTopic.c_str(), 1);      // QoS 1
    mqtt.subscribe(shadowAcceptedTopic.c_str(), 1); // QoS 1 — Session 5
    Serial.print("📡 CMD:    "); Serial.println(subCmdTopic);
    Serial.print("📡 UPDATE: "); Serial.println(subUpdateTopic);
    publishFullStatus();
  } else {
    Serial.print("❌ AWS MQTT FAILED rc="); Serial.println(mqtt.state());
  }
}




// ================== SETUP ==================
void setup() {
  Serial.begin(115200);
  delay(1500);   // USB CDC enumerate on S3

  DEVICE_ID = getDeviceID();

  // Build topic strings
  pubStatusTopic     = "actuator/" + DEVICE_ID + "/status";
  pubEventTopic      = "actuator/" + DEVICE_ID + "/events";
  subCmdTopic        = "actuator/" + DEVICE_ID + "/cmd";
  subUpdateTopic     = "actuator/" + DEVICE_ID + "/update";
  shadowUpdateTopic  = "$aws/things/" + DEVICE_ID + "/shadow/update";
  shadowAcceptedTopic= "$aws/things/" + DEVICE_ID + "/shadow/update/accepted";

  Serial.print("📌 DEVICE ID: "); Serial.println(DEVICE_ID);
  Serial.print("📌 FW VER:    "); Serial.println(FW_VERSION);
  Serial.print("📌 FW TYPE:   "); Serial.println(FW_TYPE);

  Wire.begin(SDA_PIN, SCL_PIN);

  // Relay + IO pins
  pinMode(RELAY_PWR,        OUTPUT);
  pinMode(RELAY_FWD,        OUTPUT);
  pinMode(RELAY_REV,        OUTPUT);
  pinMode(LIMIT_SWITCH_PIN, INPUT_PULLUP);
  pinMode(INA_ALERT_PIN,    INPUT_PULLUP);  // [INA ALERT]
  pinMode(BUZZER_PIN,       OUTPUT);        // [BUZZ]
  pinMode(VBAT_ADC_PIN,     INPUT);         // [VBAT] ADC input
  pinMode(RTC_INT_PIN,      INPUT_PULLUP);  // [RTC] Session 3
  // Reserved inputs
  pinMode(20, INPUT);   // Flow pulse

  digitalWrite(RELAY_PWR, RELAY_OFF);
  digitalWrite(RELAY_FWD, RELAY_OFF);
  digitalWrite(RELAY_REV, RELAY_OFF);
  digitalWrite(BUZZER_PIN, HIGH);           // [BUZZ] silent at boot
  analogReadResolution(12);                 // [VBAT] 12-bit ADC on S3
  vbatMV = readVBAT_mV();                   // [VBAT] initial reading

  // [INA ALERT] attach interrupt
  attachInterrupt(digitalPinToInterrupt(INA_ALERT_PIN), inaAlertISR, FALLING);

  ledcAttach(PWM_PIN, PWM_FREQ, PWM_RES);
  ledcWrite(PWM_PIN, 0);
  Serial.println("✅ PWM READY (GPIO36)");   // [PINS] corrected from GPIO22

  ina226.init();
  configureINAAlert();   // [INA ALERT] set hardware OC threshold

  prefs.begin("device_cfg", true);
  CURRENT_OFF = prefs.getFloat("oc_thresh",  1.0);
  MAX_TURNS   = prefs.getFloat("max_turns",  10.0);
  String bootCheck = prefs.getString("boot_check", "OK");
  prefs.end();

  Serial.print("⚡ OC THRESHOLD: "); Serial.print(CURRENT_OFF, 2); Serial.println("A");
  Serial.print("🔄 MAX TURNS:    "); Serial.println(MAX_TURNS, 2);

  prefs.begin("encoder", true); loadPosition(); prefs.end();
  checkSensors();   // boot-time sensor check

  // [LTE-NB] start modem UART — init runs in FW_LTE_INIT state
  SerialAT.begin(115200, SERIAL_8N1, 44, 43);   // [PINS] S3 GPIO44 RX, GPIO43 TX
  lteTimer = millis() + 5000;
  lteState = LTE_AT;

  // [ROLLBACK] route post-OTA boots to validation
  if (bootCheck == "PENDING") {
    Serial.println("⚠️ POST-OTA BOOT — validation pending");
    prefs.begin("device_cfg", false); prefs.putString("boot_check", "VALIDATING"); prefs.end();
  }

  fwState = FW_LTE_INIT;
  Serial.println("✅ SYSTEM READY — entering LTE init");
}




// ================== LOOP ==================
void loop() {
  handleSimOp();   // [SIM-NB] advance SIM settle timer every tick

  switch (fwState) {

    // ── [LTE-NB] Non-blocking LTE bring-up ──
    case FW_LTE_INIT:
      if (millis() < lteTimer && lteState == LTE_AT) { handleLTE(); break; }
      handleLTEInit();
      break;

    // ── [TLS] Load credentials and configure TinyGsmClientSecure ──
    case FW_TLS_INIT:
      tlsReady = loadAndApplyTLSCredentials();
      if (!tlsReady) {
        Serial.println("❌ TLS INIT FAILED — check provisioning sketch");
        // Continue to FW_INIT without TLS — MQTT connect will be blocked
      }
      fwState = FW_INIT;
      break;

    // ── FW_INIT ──
    case FW_INIT:
      Serial.println("🚀 FW INIT");
      connectMQTT();
      {
        prefs.begin("device_cfg", true);
        String bc = prefs.getString("boot_check", "OK");
        prefs.end();
        fwState = (bc == "VALIDATING") ? FW_BOOT_VALIDATE : FW_ACTIVE;
      }
      break;

    // ── [ROLLBACK] Post-OTA boot validation ──
    case FW_BOOT_VALIDATE:
      connectMQTT(); mqtt.loop();
      if (bootValidateTimer == 0) bootValidateTimer = millis();
      if (mqtt.connected() && !bootValidateDone) {
        bool ok = checkSensors();
        if (ok) {
          Serial.println("✅ BOOT VALIDATION PASSED");
          prefs.begin("device_cfg", false); prefs.putString("boot_check", "OK"); prefs.end();
          bootValidateDone = true;
          StaticJsonDocument<96> v; v["device_id"]=DEVICE_ID; v["ota_event"]="OTA_VALIDATED"; v["fw_version"]=FW_VERSION;
          String o; serializeJson(v,o); mqttPublish(pubStatusTopic.c_str(),o);
          publishFullStatus(); fwState = FW_ACTIVE;
        }
      }
      if (!bootValidateDone && millis() - bootValidateTimer > BOOT_VALIDATE_MS) {
        Serial.println("❌ BOOT VALIDATION TIMEOUT — rolling back");
        prefs.begin("device_cfg", false); prefs.putString("boot_check", "OK"); prefs.end();
        if (mqtt.connected()) {
          StaticJsonDocument<96> rb; rb["device_id"]=DEVICE_ID; rb["ota_event"]="OTA_ROLLBACK"; rb["reason"]="VALIDATION_TIMEOUT";
          String o; serializeJson(rb,o); mqttPublish(pubStatusTopic.c_str(),o); delay(300);
        }
        if (Update.canRollback()) Update.rollback();
        ESP.restart();
      }
      break;

    // ── FW_ACTIVE ──
    case FW_ACTIVE:

      if (bypassSleepPending && millis() - bypassSleepTimer >= 30000) {
        bypassSleepPending = false;
        if (safeToSleep()) { sleepMode = true; sleepSub = SLEEP_ENTER; fwState = FW_SLEEP; }
      }

      if (safeToSleep()) {
        if (!idleTracking) { idleTracking = true; idleStart = millis(); }
        if (!sleepMode && millis() - idleStart > 10000) {
          savePosition(); sleepMode = true; sleepSub = SLEEP_ENTER;
          Serial.println("💾 PRE-SLEEP SAVE");
        }
      } else { idleTracking = false; }

      if (sleepMode) { fwState = FW_SLEEP; break; }

      if (Serial.available()) {
        String input = Serial.readStringUntil('\n'); input.trim();
        if (input.startsWith("{")) { handleJSONCommand(input); }
        else {
          input.toUpperCase();
          if      (input == "F") startMotor(FORWARD_RUN);
          else if (input == "R") startMotor(REVERSE_RUN);
          else if (input == "S") stopMotor();
          else if (vState == WAIT_BYPASS) {
            if (input == "Y") {
              vState = BYPASS_ACTIVE; publishVoltageEvent("BYPASS", getVoltage());
              if (resumePending) { startMotor(resumeDirection); resumePending = false; }
            } else { vState = WARNING; resumePending = false; }
          }
        }
      }

      connectMQTT();
      mqtt.loop();
      handleMotorRamp();
      handleEncoder();
      handleLimit();
      handleCurrent();
      handleVoltageSafety();
      handleBuzzer();      // [BUZZ]
      printDashboard();

      // [VBAT] read raw battery ADC every 2s
      if (millis() - vbatReadTimer >= 2000) {
        vbatReadTimer = millis();
        vbatMV = readVBAT_mV();
      }

      if (millis() - sensorCheckTimer >= 30000) {
        sensorCheckTimer = millis(); checkSensors();
      }

      handleLTE();
      break;

    // ── FW_SLEEP non-blocking state machine ──
    case FW_SLEEP:
      handleSimOp();
      switch (sleepSub) {

        case SLEEP_ENTER:
          if (!simOpDone()) break;
          mqttSleepCheckTimer = millis();
          simEnterSleep();
          Serial.println("😴 SLEEP MODE");
          sleepSub = SLEEP_IDLE;
          break;

        case SLEEP_IDLE:
          if (!simOpDone()) break;
          if (digitalRead(LIMIT_SWITCH_PIN) == LOW) {
            Serial.println("⚡ LIMIT WAKE"); limitOverride = true; sleepSub = SLEEP_LIMIT; break;
          }
          if (millis() - mqttSleepCheckTimer >= MQTT_SLEEP_CHECK_MS) {
            mqttSleepCheckTimer = millis();
            Serial.println("⏰ SLEEP CHECK");
            simWake(); mqttRetryTimer = 0; sleepCommandReceived = false;
            mqttChkStart = millis(); sleepSub = SLEEP_MQTTCHK;
          }
          break;

        case SLEEP_LIMIT:
          mqtt.loop(); handleEncoder();
          if (millis() - saveTimer > 2000) { saveTimer = millis(); savePosition(); }
          if (digitalRead(LIMIT_SWITCH_PIN) == HIGH) {
            Serial.println("✅ LIMIT RELEASED");
            savePosition(); limitOverride = false;
            simWake(); mqttRetryTimer = 0; connectMQTT(); publishFullStatus();
            sleepMode = false; idleTracking = false; idleStart = millis();
            sleepSub = SLEEP_ENTER; fwState = FW_ACTIVE;
          }
          break;

        case SLEEP_MQTTCHK:
          if (!simOpDone()) break;
          connectMQTT(); mqtt.loop();
          if (sleepCommandReceived) {
            Serial.println("🟢 WAKE — command received");
            sleepMode = false; idleTracking = false; idleStart = millis();
            sleepSub = SLEEP_ENTER; fwState = FW_ACTIVE; break;
          }
          if (millis() - mqttChkStart >= 3000) {
            if (!safeToSleep()) {
              sleepMode = false; idleTracking = false; idleStart = millis();
              sleepSub = SLEEP_ENTER; fwState = FW_ACTIVE;
            } else {
              Serial.println("😴 NO COMMAND — back to sleep");
              simEnterSleep(); sleepSub = SLEEP_IDLE;
            }
          }
          break;
      }
      break;

    // ── OTA wait for ramp idle ──
    case FW_OTA_WAIT:
      handleMotorRamp();
      if (rampState == RAMP_IDLE && motorState == IDLE) {
        Serial.println("🚀 MOTOR IDLE — flashing");
        fwState = FW_OTA_FLASH;
      }
      break;

    // ── OTA flash ──
    case FW_OTA_FLASH:
      performOTA();
      break;
  }
}
