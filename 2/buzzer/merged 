#include <Wire.h>
#include <INA226_WE.h>
#include <Preferences.h>


// ================== PINS ==================
#define RELAY_PWR 5
#define RELAY_FWD 18
#define RELAY_REV 19
#define LIMIT_SWITCH_PIN 27
#define BUZZER_PIN 23


#define SDA_PIN 21
#define SCL_PIN 22


// ================== RELAY ==================
#define RELAY_ON  LOW
#define RELAY_OFF HIGH


// ================== I2C ==================
#define INA_ADDR 0x40
#define AS5600_ADDR 0x36


INA226_WE ina226 = INA226_WE(INA_ADDR);
Preferences prefs;


// ================== LIMITS ==================
#define CURRENT_OFF 1
#define MAX_TURNS 10.0
#define MIN_TURNS 1.0


// ================== VOLTAGE ==================
#define WARN_V     10.0
#define CUT_V      10.5
#define CRITICAL_V  9.5
#define RESET_V    11.0


// ================== STATES ==================
enum State { IDLE, FORWARD_RUN, REVERSE_RUN };
State motorState = IDLE;
State lastDirection = FORWARD_RUN;


State resumeDirection = IDLE;
bool resumePending = false;


// ================== VOLTAGE STATE ==================
enum VoltageState { NORMAL, WARNING, WAIT_BYPASS, BYPASS_ACTIVE, LOCKED };
VoltageState vState = NORMAL;


// ================== CURRENT ==================
int retryCount = 0;
bool ocFault = false;
bool lockFault = false;
unsigned long ocTripTime = 0;
#define RETRY_DELAY 30000


// ================== ENCODER ==================
int16_t angle = 0, prevAngle = 0;
long rotationCount = 0;
float totalTurns = 0;


// ================== BUZZER ==================
enum BuzzerMode { BUZZ_OFF, BUZZ_SINGLE, BUZZ_DOUBLE, BUZZ_TRIPLE };
BuzzerMode buzzerMode = BUZZ_OFF;


unsigned long buzzerTimer = 0;
unsigned long buzzerStartTime = 0;
int stepIndex = 0;


#define ON_TIME 150
#define OFF_TIME 150
#define GAP_TIME 500


// ================== TIMERS ==================
unsigned long dashboardTimer = 0;
unsigned long lowVoltStart = 0;
bool lowVoltDetected = false;


// ================== CLEAN FLAGS ==================
bool lastLimitState = HIGH;
bool lastOvercurrent = false;
VoltageState lastVState = NORMAL;


float lastV = -1, lastI = -1, lastTurns = -1;
State lastPrintedState = IDLE;
int lastRetry = -1;
bool lastLockFault = false;


// ================== HELPERS ==================
float getVoltage() { return ina226.getBusVoltage_V(); }
float getCurrent() { return abs(ina226.getCurrent_mA()) / 1000.0; }


// ================== COMMAND ==================
void handleCommand() {
  if (!Serial.available()) return;


  String cmd = Serial.readStringUntil('\n');
  cmd.trim();
  cmd.toUpperCase();


  if (cmd == "F") startMotor(FORWARD_RUN);
  else if (cmd == "R") startMotor(REVERSE_RUN);
  else if (cmd == "S") stopMotor();
}


// ================== STORAGE ==================
void savePosition() {
  prefs.putLong("rot", rotationCount);
  prefs.putInt("angle", angle);
}


void loadPosition() {
  rotationCount = prefs.getLong("rot", 0);
  angle = prefs.getInt("angle", 0);
  prevAngle = angle;
  totalTurns = rotationCount + (angle / 4096.0);
}


// ================== ENCODER ==================
int readAngle() {
  Wire.beginTransmission(AS5600_ADDR);
  Wire.write(0x0E);
  Wire.endTransmission(false);
  Wire.requestFrom(AS5600_ADDR, 2);


  if (Wire.available() == 2) {
    int high = Wire.read();
    int low = Wire.read();
    return ((high << 8) | low) & 0x0FFF;
  }
  return -1;
}


void handleEncoder() {
  int a = readAngle();
  if (a == -1) return;


  int diff = a - prevAngle;
  if (diff > 3000) rotationCount--;
  if (diff < -3000) rotationCount++;


  prevAngle = a;
  angle = a;
  totalTurns = rotationCount + (angle / 4096.0);


  if (motorState == FORWARD_RUN && totalTurns >= MAX_TURNS) {
    Serial.println("🛑 FORWARD LIMIT");
    stopMotor();
    savePosition();
  }


  if (motorState == REVERSE_RUN && totalTurns <= MIN_TURNS) {
    Serial.println("🛑 REVERSE LIMIT");
    stopMotor();
    savePosition();
  }
}


// ================== MOTOR ==================
void stopMotor() {
  if (motorState != IDLE) {
    resumeDirection = motorState;
    resumePending = true;
  }


  digitalWrite(RELAY_PWR, RELAY_OFF);
  digitalWrite(RELAY_FWD, RELAY_OFF);
  digitalWrite(RELAY_REV, RELAY_OFF);
  motorState = IDLE;
}


void startMotor(State dir) {
  float v = getVoltage();


  if (vState == LOCKED) {
    Serial.println("🔒 BATTERY LOCKED");
    return;
  }


  if (lockFault) {
    Serial.println("🔒 CURRENT LOCKED");
    return;
  }


  if (totalTurns <= 1.0 && v < RESET_V) {
    Serial.println("🛑 START BLOCKED (LOW BATTERY)");
    return;
  }


  stopMotor();
  delay(200);


  if (dir == FORWARD_RUN) digitalWrite(RELAY_FWD, RELAY_ON);
  else digitalWrite(RELAY_REV, RELAY_ON);


  delay(200);
  digitalWrite(RELAY_PWR, RELAY_ON);


  motorState = dir;
  lastDirection = dir;
}


// ================== LIMIT ==================
void handleLimit() {
  bool currentState = digitalRead(LIMIT_SWITCH_PIN);


  if (lastLimitState == HIGH && currentState == LOW) {
    Serial.println("🔴 LIMIT SWITCH");
    stopMotor();
  }


  lastLimitState = currentState;
}


// ================== CURRENT ==================
void handleCurrent() {
  float current = getCurrent();
  bool isOver = current > CURRENT_OFF;


  if (motorState != IDLE && isOver && !lastOvercurrent) {
    Serial.println("⚠️ OVERCURRENT");


    stopMotor();


    ocFault = true;
    retryCount++;
    ocTripTime = millis();


    Serial.print("Attempt: ");
    Serial.println(retryCount);


    if (retryCount >= 3) {
      Serial.println("🔒 CURRENT LOCKED");
      lockFault = true;
    }
  }


  lastOvercurrent = isOver;


  if (ocFault && !lockFault && millis() - ocTripTime > RETRY_DELAY) {
    Serial.println("🔁 RETRYING");
    startMotor(lastDirection);
    ocFault = false;
  }
}


// ================== VOLTAGE ==================
void handleVoltageSafety() {
  float v = getVoltage();


  switch (vState) {


    case NORMAL:
      if (v < WARN_V && lastVState != WARNING) {
        Serial.println("⚠️ VOLTAGE WARNING");
        vState = WARNING;
      }
      break;


    case WARNING:
      if (v >= WARN_V) {
        vState = NORMAL;
      }
      else if (motorState != IDLE && v < CUT_V) {
        if (!lowVoltDetected) {
          lowVoltDetected = true;
          lowVoltStart = millis();
        }


        if (millis() - lowVoltStart > 300) {
          Serial.println("🛑 LOW VOLTAGE CUT");
          stopMotor();
          Serial.println("BYPASS? Y/N");
          vState = WAIT_BYPASS;
        }
      } else {
        lowVoltDetected = false;
      }
      break;


    case WAIT_BYPASS:
      if (Serial.available()) {
        String cmd = Serial.readStringUntil('\n');
        cmd.trim();
        cmd.toUpperCase();


        if (cmd == "Y") {
          Serial.println("⚠️ BYPASS ENABLED");
          vState = BYPASS_ACTIVE;


          delay(200);


          if (resumePending && resumeDirection != IDLE) {
            Serial.println("🔁 RESUMING");
            startMotor(resumeDirection);
            resumePending = false;
          }
        } else {
          Serial.println("❌ BYPASS DENIED");
          vState = WARNING;
        }
      }
      break;


    case BYPASS_ACTIVE:
      if (v <= CRITICAL_V) {
        Serial.println("🛑 CRITICAL VOLTAGE → LOCK");
        stopMotor();
        vState = LOCKED;
      }
      break;


    case LOCKED:
      if (v >= RESET_V) {
        Serial.println("🔄 BATTERY RESET");
        vState = NORMAL;
      }
      break;
  }


  lastVState = vState;
}


// ================== BUZZER ==================
void setBuzzer(BuzzerMode mode) {
  if (buzzerMode != mode) {
    buzzerMode = mode;
    stepIndex = 0;
    buzzerTimer = millis();
    buzzerStartTime = millis();
    digitalWrite(BUZZER_PIN, HIGH);
  }
}


void handleBuzzer() {
  bool limitActive = (digitalRead(LIMIT_SWITCH_PIN) == LOW);


  if (!limitActive) {
    buzzerMode = BUZZ_OFF;
    stepIndex = 0;
    digitalWrite(BUZZER_PIN, HIGH);
    return;
  }


  if (totalTurns <= 1.0) setBuzzer(BUZZ_DOUBLE);
  else if (totalTurns >= 10.0) setBuzzer(BUZZ_TRIPLE);
  else setBuzzer(BUZZ_SINGLE);


  if ((buzzerMode == BUZZ_DOUBLE || buzzerMode == BUZZ_TRIPLE) &&
      millis() - buzzerStartTime > 60000) {
    setBuzzer(BUZZ_OFF);
    digitalWrite(BUZZER_PIN, LOW);
    return;
  }


  unsigned long now = millis();


  switch (buzzerMode) {


    case BUZZ_SINGLE:
      if (now - buzzerTimer > ON_TIME) {
        buzzerTimer = now;
        digitalWrite(BUZZER_PIN, !digitalRead(BUZZER_PIN));
      }
      break;


    case BUZZ_DOUBLE:
      if (stepIndex == 0 || stepIndex == 2) {
        digitalWrite(BUZZER_PIN, HIGH);
        if (now - buzzerTimer > ON_TIME) { buzzerTimer = now; stepIndex++; }
      }
      else if (stepIndex == 1 || stepIndex == 3) {
        digitalWrite(BUZZER_PIN, LOW);
        if (now - buzzerTimer > OFF_TIME) { buzzerTimer = now; stepIndex++; }
      }
      else {
        digitalWrite(BUZZER_PIN, LOW);
        if (now - buzzerTimer > GAP_TIME) { stepIndex = 0; buzzerTimer = now; }
      }
      break;


    case BUZZ_TRIPLE:
      if (stepIndex == 0 || stepIndex == 2 || stepIndex == 4) {
        digitalWrite(BUZZER_PIN, HIGH);
        if (now - buzzerTimer > ON_TIME) { buzzerTimer = now; stepIndex++; }
      }
      else if (stepIndex == 1 || stepIndex == 3 || stepIndex == 5) {
        digitalWrite(BUZZER_PIN, LOW);
        if (now - buzzerTimer > OFF_TIME) { buzzerTimer = now; stepIndex++; }
      }
      else {
        digitalWrite(BUZZER_PIN, LOW);
        if (now - buzzerTimer > GAP_TIME) { stepIndex = 0; buzzerTimer = now; }
      }
      break;


    case BUZZ_OFF:
      digitalWrite(BUZZER_PIN, LOW);
      break;
  }
}


// ================== DASHBOARD ==================
void printDashboard() {
  if (millis() - dashboardTimer < 500) return;
  dashboardTimer = millis();


  float v = getVoltage();
  float i = getCurrent();


  if (abs(v - lastV) < 0.01 &&
      abs(i - lastI) < 0.01 &&
      abs(totalTurns - lastTurns) < 0.01 &&
      motorState == lastPrintedState &&
      retryCount == lastRetry &&
      lockFault == lastLockFault &&
      vState == lastVState) return;


  Serial.println("================================");
  Serial.print("V: "); Serial.print(v, 2);
  Serial.print(" | I: "); Serial.print(i, 3);
  Serial.print(" | Turns: "); Serial.print(totalTurns, 2);
  Serial.println();


  Serial.print("State: ");
  if (motorState == IDLE) Serial.print("IDLE");
  else if (motorState == FORWARD_RUN) Serial.print("FWD");
  else Serial.print("REV");


  Serial.print(" | Retry: "); Serial.print(retryCount);


  Serial.print(" | Fault: ");
  if (lockFault) Serial.print("OC_LOCK");
  else if (vState == LOCKED) Serial.print("UV_LOCK");
  else Serial.print("OK");


  Serial.println();
  Serial.println("================================");


  lastV = v;
  lastI = i;
  lastTurns = totalTurns;
  lastPrintedState = motorState;
  lastRetry = retryCount;
  lastLockFault = lockFault;
  lastVState = vState;
}


// ================== SETUP ==================
void setup() {
  Serial.begin(115200);
  Wire.begin(SDA_PIN, SCL_PIN);


  pinMode(RELAY_PWR, OUTPUT);
  pinMode(RELAY_FWD, OUTPUT);
  pinMode(RELAY_REV, OUTPUT);
  pinMode(LIMIT_SWITCH_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN, OUTPUT);


  digitalWrite(RELAY_PWR, RELAY_OFF);
  digitalWrite(RELAY_FWD, RELAY_OFF);
  digitalWrite(RELAY_REV, RELAY_OFF);
  digitalWrite(BUZZER_PIN, HIGH);


  prefs.begin("encoder", false);
  loadPosition();


  ina226.init();


  Serial.println("✅ SYSTEM READY");
}


// ================== LOOP ==================
void loop() {
  handleVoltageSafety();
  handleCommand();
  handleEncoder();
  handleLimit();
  handleCurrent();
  handleBuzzer();
  printDashboard();


  delay(20);
}

