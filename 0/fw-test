//  TEST 17: NETWORK TIME  (AT+CCLK?)
// ─────────────────────────────────────────────────────────────

static void testCCLK() {
  separator('=');
  Serial.println("TEST: Network Time (AT+CCLK?)");
  separator();

  String resp = sendAT("AT+CCLK?");
  Serial.printf("  >> AT+CCLK?\n  << %s\n", resp.c_str());

  R.cclk = (resp.indexOf("+CCLK:") >= 0 && resp.indexOf("OK") >= 0) ? PASS : FAIL;
  Serial.printf("  CCLK : %s\n", resultStr(R.cclk));
}

