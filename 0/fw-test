// ─────────────────────────────────────────────────────────────
//  TEST 13: SIM DETECTION
// ─────────────────────────────────────────────────────────────

static void testSIM() {
  separator('=');
  Serial.println("TEST: SIM Detection (AT+CPIN?)");
  separator();

  String resp = sendAT("AT+CPIN?", 5000);
  Serial.printf("  >> AT+CPIN?\n  << %s\n", resp.c_str());

  if (resp.indexOf("READY") >= 0) {
    R.sim = PASS;
    Serial.println("  SIM : PASS  (CPIN READY)");
  } else if (resp.indexOf("NOT INSERTED") >= 0) {
    R.sim = FAIL;
    Serial.println("  SIM : FAIL  (not inserted)");
  } else {
    R.sim = FAIL;
    Serial.println("  SIM : FAIL  (unexpected response)");
  }
}

// ─────────────────────────────────────────────────────────────
//  TEST 14: LTE REGISTRATION  (AT+CREG?, wait up to 30 s)
// ─────────────────────────────────────────────────────────────

static void testLTE() {
  separator('=');
  Serial.println("TEST: LTE Registration (AT+CREG?)");
  separator();
  Serial.println("  Waiting for registration (up to 30 s)...");

  R.network = FAIL;
  for (int i = 0; i < 30; i++) {
    String resp = sendAT("AT+CREG?", 2000);
    Serial.printf("  [%2d] %s\n", i + 1, resp.c_str());
    // Stat 1 = registered home, 5 = registered roaming
    if (resp.indexOf(",1")  >= 0 || resp.indexOf(",5")  >= 0 ||
        resp.indexOf(": 1") >= 0 || resp.indexOf(": 5") >= 0) {
      R.network = PASS;
      break;
    }
    delay(1000);
  }
  Serial.printf("  Network : %s\n", resultStr(R.network));
}

// ─────────────────────────────────────────────────────────────
//  TEST 15: SIGNAL STRENGTH  (AT+CSQ)
// ─────────────────────────────────────────────────────────────

static void testSignal() {
  separator('=');
  Serial.println("TEST: Signal Strength (AT+CSQ)");
  separator();

  String resp = sendAT("AT+CSQ");
  Serial.printf("  >> AT+CSQ\n  << %s\n", resp.c_str());

  int csq = -1;
  int idx = resp.indexOf("+CSQ:");
  if (idx >= 0) csq = resp.substring(idx + 5).toInt();

  const char* quality =
    (csq >=  0 && csq <=  9) ? "Poor"      :
    (csq >= 10 && csq <= 14) ? "Fair"      :
    (csq >= 15 && csq <= 20) ? "Good"      :
    (csq >= 21 && csq <= 31) ? "Excellent" : "Unknown";

  Serial.printf("  CSQ = %d  (%s)\n", csq, quality);

  //  CSQ 99 = not detectable
  R.signal = (csq >= CSQ_MIN && csq < 99) ? PASS : FAIL;
  Serial.printf("  Signal : %s  (minimum %d required for deployment)\n",
                resultStr(R.signal), CSQ_MIN);
}

