// ─────────────────────────────────────────────────────────────
//  FULL TEST SEQUENCE
// ─────────────────────────────────────────────────────────────

static void runAllTests() {
  R = Results(); // reset all to PENDING

  Serial.println();
  separator('=', 42);
  Serial.println("  COMMISSIONING FIRMWARE  v1.0.0");
  Serial.println("  ESP32-S3 Linear Actuator Controller");
  separator('=', 42);
  Serial.println();
  Serial.println("  Keep Serial Monitor open at 115200 baud.");
  Serial.println("  Respond to prompts with y/n + Enter.");
  Serial.println("  AS5600 and limit-switch tests are automatic.");
  Serial.println();

  // ── Hardware tests (automatic) ───────────────────────────
  testChipAndFlash();
  testI2CScan();
  testDS3231();   // sets rtcBatt as a side-effect
  testINA226();
  testAS5600();

  // ── Interactive hardware tests ───────────────────────────
  R.relayK1    = testRelay(PIN_RELAY_K1, "K1");
  R.relayK2    = testRelay(PIN_RELAY_K2, "K2");
  R.relayK3    = testRelay(PIN_RELAY_K3, "K3");
  testBuzzer();
  R.limitOpen  = testLimitSwitch(PIN_LIMIT_OPEN,  "OPEN");
  R.limitClose = testLimitSwitch(PIN_LIMIT_CLOSE, "CLOSE");

  // ── Modem tests (skip sub-tests if modem unresponsive) ───
  testModem();
  if (R.modem == PASS) {
    testSIM();
    testLTE();
    testSignal();
    testCGATT();
    testCCLK();
  } else {
    Serial.println();
    Serial.println("  Modem unresponsive – skipping SIM / LTE tests.");
    R.sim = R.network = R.signal = R.cgatt = R.cclk = SKIP;
  }

  printReport();
}

// ─────────────────────────────────────────────────────────────
//  SETUP
// ─────────────────────────────────────────────────────────────

void setup() {
  Serial.begin(115200);
  delay(2000); // wait for Serial to settle after reset

  // I²C
  Wire.begin(PIN_I2C_SDA, PIN_I2C_SCL);
  Wire.setClock(100000); // 100 kHz – safe for all three devices

  // GPIO outputs
  pinMode(PIN_RELAY_K1, OUTPUT); digitalWrite(PIN_RELAY_K1, RELAY_OFF);
  pinMode(PIN_RELAY_K2, OUTPUT); digitalWrite(PIN_RELAY_K2, RELAY_OFF);
  pinMode(PIN_RELAY_K3, OUTPUT); digitalWrite(PIN_RELAY_K3, RELAY_OFF);
  pinMode(PIN_BUZZER,   OUTPUT); digitalWrite(PIN_BUZZER,   BUZZER_OFF);

  // GPIO inputs
  pinMode(PIN_LIMIT_OPEN,  INPUT_PULLUP);
  pinMode(PIN_LIMIT_CLOSE, INPUT_PULLUP);

  // Modem serial
  modemSerial.begin(MODEM_BAUD, SERIAL_8N1, PIN_MODEM_RX, PIN_MODEM_TX);

  // Power on modem via PWRKEY if pin is defined
  if (PIN_MODEM_PWRKEY >= 0) {
    pinMode(PIN_MODEM_PWRKEY, OUTPUT);
    digitalWrite(PIN_MODEM_PWRKEY, HIGH);   // ensure defined state
    delay(200);
    digitalWrite(PIN_MODEM_PWRKEY, LOW);    // pull low to trigger power-on
    delay(1500);                            // A7670C: hold ~1.5 s
    digitalWrite(PIN_MODEM_PWRKEY, HIGH);   // release
    delay(5000);                            // wait for modem boot
    Serial.println("  Modem power-on sequence complete.");
  }

  runAllTests();
}

// ─────────────────────────────────────────────────────────────
//  LOOP  –  re-run on 'r'
// ─────────────────────────────────────────────────────────────

void loop() {
  if (Serial.available()) {
    char c = (char)Serial.read();
    while (Serial.available()) Serial.read(); // flush rest of line
    if (c == 'r' || c == 'R') runAllTests();
  }
}
