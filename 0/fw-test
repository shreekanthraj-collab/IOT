/*
 * ============================================================
 *  COMMISSIONING / TEST FIRMWARE  v1.0.0
 *  ESP32-S3 Linear Actuator Controller
 * ============================================================
 *  Run ONCE before flashing production AWS firmware.
 *  Validates every critical subsystem and prints a PASS/FAIL
 *  report to the Serial Monitor at 115200 baud.
 *
 *  Subsystems tested (in order):
 *    1.  ESP32-S3 Chip ID + Flash size (16 MB)
 *    2.  I²C Bus Scan  (AS5600 / INA226 / DS3231)
 *    3.  DS3231 RTC     – year validity
 *    4.  INA226         – bus voltage / current
 *    5.  AS5600         – interactive rotation test
 *    6.  Relay K1       – audible click confirmation
 *    7.  Relay K2
 *    8.  Relay K3
 *    9.  Buzzer         – audible tone confirmation
 *   10.  Open Limit Switch
 *   11.  Close Limit Switch
 *   12.  RTC Backup Battery  (inferred from DS3231 year)
 *   13.  A7670C Modem AT     – response within 2 s
 *   14.  SIM Detection       – AT+CPIN?
 *   15.  LTE Registration    – AT+CREG? (wait up to 30 s)
 *   16.  Signal Strength     – AT+CSQ  (CSQ >= 10 required)
 *   17.  Data Attachment     – AT+CGATT?
 *   18.  Network Time        – AT+CCLK?
 *
 *  Interactive steps (relay, buzzer, limits):
 *    The firmware prints a prompt and waits up to 5 s for
 *    y/n confirmation from the serial terminal, then times
 *    out to FAIL if no response.  AS5600 and limit-switch
 *    tests are purely GPIO-based (no confirmation needed).
 *
 *  To re-run after the initial report, send 'r' on Serial.
 * ============================================================
 */

// ─────────────────────────────────────────────────────────────
//  !!!  CONFIGURE THESE BEFORE FLASHING  !!!
// ─────────────────────────────────────────────────────────────

// I²C
#define PIN_I2C_SDA       8
#define PIN_I2C_SCL       9

// Relays (HIGH = energise coil; set LOW if your board uses
// active-low relay modules)
#define PIN_RELAY_K1     10
#define PIN_RELAY_K2     11
#define PIN_RELAY_K3     12
#define RELAY_ON        HIGH
#define RELAY_OFF        LOW

// Buzzer (HIGH = on; flip if active-low)
#define PIN_BUZZER       13
#define BUZZER_ON       HIGH
#define BUZZER_OFF       LOW

// Limit switches (INPUT_PULLUP assumed → LOW when pressed)
#define PIN_LIMIT_OPEN   14
#define PIN_LIMIT_CLOSE  15
#define LIMIT_ACTIVE     LOW

// A7670C modem  –  HardwareSerial 1
#define PIN_MODEM_RX     16   // ESP32 RX ← Modem TX
#define PIN_MODEM_TX     17   // ESP32 TX → Modem RX
#define PIN_MODEM_PWRKEY 21   // PWRKEY: pull LOW ~1.5 s to power on
                              // Set to -1 if modem is always powered
#define MODEM_BAUD    115200

// INA226 shunt  –  match your hardware
#define R_SHUNT_OHMS   0.1f   // Ω  (typical: 10 mΩ, 50 mΩ, 100 mΩ)
#define CURRENT_LSB_A  0.001f // A per LSB  (1 mA resolution)

// ─────────────────────────────────────────────────────────────
//  PASS / FAIL thresholds
// ─────────────────────────────────────────────────────────────
#define FLASH_EXPECTED_MB    16
#define VOLTAGE_MIN_V        5.0f
#define VOLTAGE_BATT_MIN_V  11.0f
#define VOLTAGE_BATT_MAX_V  14.6f
#define CSQ_MIN             10
#define RTC_YEAR_MIN        2025
#define MODEM_AT_TIMEOUT_MS 2000
#define AS5600_DELTA_MIN    10    // raw counts; any less = magnet not moving

// ─────────────────────────────────────────────────────────────
//  INCLUDES
// ─────────────────────────────────────────────────────────────
#include <Arduino.h>
#include <Wire.h>
#include "esp_chip_info.h"
#include "esp_flash.h"

// ─────────────────────────────────────────────────────────────
//  I²C DEVICE ADDRESSES
// ─────────────────────────────────────────────────────────────
#define ADDR_AS5600  0x36
#define ADDR_INA226  0x40
#define ADDR_DS3231  0x68

// ─────────────────────────────────────────────────────────────
//  TEST RESULT TYPE
// ─────────────────────────────────────────────────────────────
enum TestResult : uint8_t { PENDING, PASS, FAIL, SKIP };

struct Results {
  TestResult chip       = PENDING;
  TestResult flash      = PENDING;
  TestResult i2c        = PENDING;
  TestResult ds3231     = PENDING;
  TestResult ina226     = PENDING;
  TestResult as5600     = PENDING;
  TestResult relayK1    = PENDING;
  TestResult relayK2    = PENDING;
  TestResult relayK3    = PENDING;
  TestResult buzzer     = PENDING;
  TestResult limitOpen  = PENDING;
  TestResult limitClose = PENDING;
  TestResult rtcBatt    = PENDING;
  TestResult modem      = PENDING;
  TestResult sim        = PENDING;
  TestResult network    = PENDING;
  TestResult signal     = PENDING;
  TestResult cgatt      = PENDING;
  TestResult cclk       = PENDING;
} R;

HardwareSerial modemSerial(1);

// ─────────────────────────────────────────────────────────────
//  UTILITY
// ─────────────────────────────────────────────────────────────

static const char* resultStr(TestResult r) {
  switch (r) {
    case PASS:  return "PASS";
    case FAIL:  return "FAIL";
    case SKIP:  return "SKIP";
    default:    return "----";
  }
}

static void separator(char c = '-', int n = 42) {
  for (int i = 0; i < n; i++) Serial.print(c);
  Serial.println();
}

static uint8_t bcd2dec(uint8_t bcd) {
  return (bcd >> 4) * 10 + (bcd & 0x0F);
}

// Wait for a single y/n character on Serial; default 'n' on timeout.
static char promptYN(uint32_t timeoutMs = 5000) {
  uint32_t start = millis();
  while (!Serial.available() && (millis() - start < timeoutMs)) delay(50);
  char c = Serial.available() ? (char)Serial.read() : 'n';
  while (Serial.available()) Serial.read(); // flush remainder
  Serial.println(c);
  return (char)tolower(c);
}

static bool overallPass(const Results& r) {
  auto ok = [](TestResult t) { return t == PASS || t == SKIP; };
  return ok(r.chip) && ok(r.flash) && ok(r.i2c) && ok(r.ds3231) &&
         ok(r.ina226) && ok(r.as5600) && ok(r.relayK1) && ok(r.relayK2) &&
         ok(r.relayK3) && ok(r.buzzer) && ok(r.limitOpen) && ok(r.limitClose) &&
         ok(r.rtcBatt) && ok(r.modem) && ok(r.sim) && ok(r.network) &&
         ok(r.signal) && ok(r.cgatt) && ok(r.cclk);
}

// ─────────────────────────────────────────────────────────────
//  I²C REGISTER HELPERS
// ─────────────────────────────────────────────────────────────

static bool i2cPing(uint8_t addr) {
  Wire.beginTransmission(addr);
  return Wire.endTransmission() == 0;
}

static uint16_t i2cRead16(uint8_t addr, uint8_t reg) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.endTransmission(false);
  Wire.requestFrom(addr, (uint8_t)2);
  if (Wire.available() < 2) return 0xFFFF;
  uint8_t hi = Wire.read();
  uint8_t lo = Wire.read();
  return ((uint16_t)hi << 8) | lo;
}

static int16_t i2cRead16s(uint8_t addr, uint8_t reg) {
  return (int16_t)i2cRead16(addr, reg);
}

static bool i2cWrite16(uint8_t addr, uint8_t reg, uint16_t val) {
  Wire.beginTransmission(addr);
  Wire.write(reg);
  Wire.write((val >> 8) & 0xFF);
  Wire.write(val & 0xFF);
  return Wire.endTransmission() == 0;
}

// ─────────────────────────────────────────────────────────────
//  MODEM AT HELPER
// ─────────────────────────────────────────────────────────────

static String sendAT(const char* cmd, uint32_t timeoutMs = 3000) {
  while (modemSerial.available()) modemSerial.read(); // flush Rx
  modemSerial.println(cmd);
  uint32_t start = millis();
  String resp = "";
  while (millis() - start < timeoutMs) {
    while (modemSerial.available()) resp += (char)modemSerial.read();
    if (resp.indexOf("OK")    >= 0 ||
        resp.indexOf("ERROR") >= 0 ||
        resp.indexOf("+CME")  >= 0 ||
        resp.indexOf("READY") >= 0) break;
    delay(10);
  }
  resp.trim();
  return resp;
}

// ─────────────────────────────────────────────────────────────
//  TEST 1: ESP32-S3 CHIP + FLASH SIZE
// ─────────────────────────────────────────────────────────────

static void testChipAndFlash() {
  separator('=');
  Serial.println("TEST 1/2: ESP32-S3 Chip + Flash");
  separator();

  // Chip model
  esp_chip_info_t info;
  esp_chip_info(&info);
  bool isS3 = (info.model == CHIP_ESP32S3);
  Serial.printf("  Model      : %s\n", isS3 ? "ESP32-S3" : "?? (expected ESP32-S3)");
  Serial.printf("  Cores      : %d\n", info.cores);
  R.chip = isS3 ? PASS : FAIL;
  Serial.printf("  Chip       : %s\n", resultStr(R.chip));

  // Flash size
  uint32_t flashBytes = 0;
  esp_flash_get_size(NULL, &flashBytes);
  uint32_t flashMB = flashBytes / (1024 * 1024);
  Serial.printf("  Flash Size : %u MB\n", flashMB);
  R.flash = (flashMB == (uint32_t)FLASH_EXPECTED_MB) ? PASS : FAIL;
  Serial.printf("  Flash      : %s  (expected %d MB)\n",
                resultStr(R.flash), FLASH_EXPECTED_MB);
}

// ─────────────────────────────────────────────────────────────
//  TEST 2: I²C BUS SCAN
// ─────────────────────────────────────────────────────────────

static void testI2CScan() {
  separator('=');
  Serial.println("TEST 3: I²C Bus Scan");
  separator();

  bool foundAS5600 = false, foundINA226 = false, foundDS3231 = false;

  for (uint8_t addr = 1; addr < 127; addr++) {
    Wire.beginTransmission(addr);
    if (Wire.endTransmission() == 0) {
      const char* tag = "";
      if (addr == ADDR_AS5600) { tag = "  ← AS5600";  foundAS5600 = true; }
      if (addr == ADDR_INA226) { tag = "  ← INA226";  foundINA226 = true; }
      if (addr == ADDR_DS3231) { tag = "  ← DS3231";  foundDS3231 = true; }
      Serial.printf("  0x%02X%s\n", addr, tag);
    }
  }

  Serial.println();
  Serial.printf("  AS5600 0x36 : %s\n", foundAS5600 ? "FOUND" : "MISSING");
  Serial.printf("  INA226 0x40 : %s\n", foundINA226 ? "FOUND" : "MISSING");
  Serial.printf("  DS3231 0x68 : %s\n", foundDS3231 ? "FOUND" : "MISSING");

  R.i2c = (foundAS5600 && foundINA226 && foundDS3231) ? PASS : FAIL;
  Serial.printf("  I2C Scan    : %s\n", resultStr(R.i2c));
}

// ─────────────────────────────────────────────────────────────
//  TEST 3: DS3231 RTC  +  RTC BACKUP BATTERY  (inferred)
// ─────────────────────────────────────────────────────────────

static void testDS3231() {
  separator('=');
  Serial.println("TEST 4: DS3231 RTC (+ Backup Battery)");
  separator();

  // Point to register 0x00 (seconds)
  Wire.beginTransmission(ADDR_DS3231);
  Wire.write(0x00);
  if (Wire.endTransmission() != 0) {
    Serial.println("  ERROR: DS3231 not responding");
    R.ds3231 = R.rtcBatt = FAIL;
    return;
  }

  Wire.requestFrom(ADDR_DS3231, (uint8_t)7);
  if (Wire.available() < 7) {
    Serial.println("  ERROR: Incomplete read from DS3231");
    R.ds3231 = R.rtcBatt = FAIL;
    return;
  }

  uint8_t sec   = bcd2dec(Wire.read() & 0x7F);
  uint8_t mn    = bcd2dec(Wire.read() & 0x7F);
  uint8_t hr    = bcd2dec(Wire.read() & 0x3F);
  /* dow */       Wire.read();
  uint8_t day   = bcd2dec(Wire.read());
  uint8_t mo    = bcd2dec(Wire.read() & 0x1F);
  uint8_t yr    = bcd2dec(Wire.read());         // 0–99
  uint16_t fullYear = 2000 + yr;

  Serial.printf("  RTC Time : %04u-%02u-%02u %02u:%02u:%02u\n",
                fullYear, mo, day, hr, mn, sec);

  if (fullYear >= RTC_YEAR_MIN) {
    R.ds3231  = PASS;
    R.rtcBatt = PASS;
    Serial.printf("  DS3231   : PASS\n");
    Serial.printf("  RTC Batt : PASS  (year valid → battery maintained time)\n");
  } else {
    R.ds3231  = FAIL;
    R.rtcBatt = FAIL;
    Serial.printf("  DS3231   : FAIL  (year=%u < %u — set RTC or replace battery)\n",
                  fullYear, RTC_YEAR_MIN);
    Serial.printf("  RTC Batt : FAIL\n");
  }
}

// ─────────────────────────────────────────────────────────────
//  TEST 4: INA226  –  voltage + current
// ─────────────────────────────────────────────────────────────
//
//  INA226 register map:
//    0x00  Configuration
//    0x02  Bus Voltage   (1.25 mV / LSB, signed 16-bit)
//    0x04  Current       (CURRENT_LSB_A / LSB, signed 16-bit)
//    0x05  Calibration   = 0.00512 / (CURRENT_LSB_A × R_SHUNT)
//
//  Config 0x4527:
//    Bits 15-13: AVG = 011 → 64 samples
//    Bits 12-10: VBUS_CT = 001 → 1.1 ms
//    Bits  9-7:  VSH_CT  = 001 → 1.1 ms
//    Bits  6-4:  reserved
//    Bits  2-0:  MODE    = 111 → shunt + bus, continuous
// ─────────────────────────────────────────────────────────────

static void testINA226() {
  separator('=');
  Serial.println("TEST 5: INA226 Voltage / Current");
  separator();

  if (!i2cPing(ADDR_INA226)) {
    Serial.println("  ERROR: INA226 not responding");
    R.ina226 = FAIL;
    return;
  }

  // Configuration register
  if (!i2cWrite16(ADDR_INA226, 0x00, 0x4527)) {
    Serial.println("  ERROR: INA226 config write failed");
    R.ina226 = FAIL;
    return;
  }

  // Calibration register
  uint16_t cal = (uint16_t)(0.00512f / (CURRENT_LSB_A * R_SHUNT_OHMS));
  i2cWrite16(ADDR_INA226, 0x05, cal);
  Serial.printf("  Cal register : %u  (R_shunt=%.3fΩ, LSB=%.1f mA)\n",
                cal, R_SHUNT_OHMS, CURRENT_LSB_A * 1000.0f);

  delay(200); // wait for first conversion

  // Bus voltage: 1.25 mV per LSB
  int16_t busRaw = i2cRead16s(ADDR_INA226, 0x02);
  float busV = busRaw * 0.00125f;

  // Current
  int16_t curRaw = i2cRead16s(ADDR_INA226, 0x04);
  float curA = curRaw * CURRENT_LSB_A;

  Serial.printf("  Bus Voltage  : %.3f V\n", busV);
  Serial.printf("  Current      : %.3f A\n", curA);

  if (busV > VOLTAGE_MIN_V) {
    R.ina226 = PASS;
    if (busV >= VOLTAGE_BATT_MIN_V && busV <= VOLTAGE_BATT_MAX_V)
      Serial.printf("  INA226       : PASS  (%.2f V – within 4S range %.1f–%.1f V)\n",
                    busV, VOLTAGE_BATT_MIN_V, VOLTAGE_BATT_MAX_V);
    else
      Serial.printf("  INA226       : PASS  (%.2f V – outside 4S range, check charger)\n",
                    busV);
  } else {
    R.ina226 = FAIL;
    Serial.printf("  INA226       : FAIL  (%.2f V < %.1f V minimum)\n",
                  busV, VOLTAGE_MIN_V);
  }
}

// ─────────────────────────────────────────────────────────────
//  TEST 5: AS5600  –  static read + interactive rotation
// ─────────────────────────────────────────────────────────────
//
//  AS5600 registers 0x0E/0x0F → 12-bit filtered output angle
//  0x0C/0x0D → raw angle (before filtering)
// ─────────────────────────────────────────────────────────────

static uint16_t as5600Read() {
  return i2cRead16(ADDR_AS5600, 0x0E) & 0x0FFF;
}

static void testAS5600() {
  separator('=');
  Serial.println("TEST 6: AS5600 Magnetic Encoder");
  separator();

  if (!i2cPing(ADDR_AS5600)) {
    Serial.println("  ERROR: AS5600 not responding");
    R.as5600 = FAIL;
    return;
  }

  uint16_t initial = as5600Read();
  Serial.printf("  Initial Angle : %u\n", initial);

  Serial.println();
  Serial.println("  >>> Rotate valve shaft now (5 s)...");
  Serial.println("  (watching for magnet movement)");
  Serial.println();

  uint16_t minA = initial, maxA = initial;
  uint32_t start   = millis();
  uint32_t lastPrt = 0;

  while (millis() - start < 5000) {
    uint16_t a = as5600Read();
    if (a < minA) minA = a;
    if (a > maxA) maxA = a;
    if (millis() - lastPrt >= 250) {
      Serial.printf("  Angle: %4u\n", a);
      lastPrt = millis();
    }
    delay(50);
  }

  // Handle 0/4095 wrap
  uint16_t delta = maxA - minA;
  if (delta > 2048) delta = 4096 - delta;

  Serial.println();
  Serial.printf("  Min: %u  Max: %u  Delta: %u counts\n", minA, maxA, delta);

  if (delta >= AS5600_DELTA_MIN) {
    R.as5600 = PASS;
    Serial.println("  AS5600 : PASS  (angle changed – magnet OK)");
  } else {
    R.as5600 = FAIL;
    Serial.println("  AS5600 : FAIL  (no movement detected – check magnet, gap, and wiring)");
  }
}

// ─────────────────────────────────────────────────────────────
//  TEST 6–8: RELAY  K1 / K2 / K3
// ─────────────────────────────────────────────────────────────

static TestResult testRelay(int pin, const char* label) {
  separator('=');
  Serial.printf("TEST: Relay %s (GPIO %d)\n", label, pin);
  separator();

  Serial.printf("  %s ON\n", label);
  digitalWrite(pin, RELAY_ON);
  delay(400);
  Serial.println("  --- listen for CLICK ---");
  delay(400);
  Serial.printf("  %s OFF\n", label);
  digitalWrite(pin, RELAY_OFF);
  delay(300);

  Serial.printf("  Did relay %s click? [y/n] > ", label);
  char c = promptYN(5000);

  TestResult res = (c == 'y') ? PASS : FAIL;
  Serial.printf("  %s : %s\n", label, resultStr(res));
  return res;
}

