// ─────────────────────────────────────────────────────────────
//  TEST 10/11: LIMIT SWITCHES
// ─────────────────────────────────────────────────────────────

static TestResult testLimitSwitch(int pin, const char* label) {
  separator('=');
  Serial.printf("TEST: %s Limit Switch (GPIO %d)\n", label, pin);
  separator();

  Serial.printf("  >>> Press the %s limit switch now (5 s)...\n", label);

  bool triggered = false;
  uint32_t start = millis();
  while (millis() - start < 5000) {
    if (digitalRead(pin) == LIMIT_ACTIVE) {
      triggered = true;
      Serial.printf("  %s Limit : TRIGGERED\n", label);
      delay(200); // debounce
      break;
    }
    delay(50);
  }

  if (!triggered) Serial.printf("  %s Limit : TIMEOUT (not pressed)\n", label);
  TestResult res = triggered ? PASS : FAIL;
  Serial.printf("  %s : %s\n", label, resultStr(res));
  return res;
}

