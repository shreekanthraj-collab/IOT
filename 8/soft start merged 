void publishFullStatus() {
  StaticJsonDocument<256> doc;
  doc["device_id"] = DEVICE_ID;

  if      (motorState == IDLE)        doc["state"] = "IDLE";
  else if (motorState == FORWARD_RUN) doc["state"] = "FORWARD";
  else                                doc["state"] = "REVERSE";

  doc["turns"]        = totalTurns;
  doc["fw_version"]   = FW_VERSION;

  switch (vState) {
    case NORMAL:        doc["voltage_status"] = "NORMAL";        break;
    case WARNING:       doc["voltage_status"] = "WARNING";       break;
    case WAIT_BYPASS:   doc["voltage_status"] = "LOW_VOLTAGE_CUT"; break;
    case BYPASS_ACTIVE: doc["voltage_status"] = "BYPASS_ACTIVE"; break;
    case LOCKED:        doc["voltage_status"] = "CRITICAL_LOCK"; break;
  }

  doc["oc_threshold"] = CURRENT_OFF;
  doc["retry"]        = retryCount;

  if      (lockFault)        doc["fault"] = "CURRENT_LOCK";
  else if (vState == LOCKED) doc["fault"] = "VOLTAGE_LOCK";
  else                       doc["fault"] = "OK";

  if (updateAvailable) {
    doc["update_available"] = true;
    doc["update_version"]   = pendingUpdateVer;
  }

  String out;
  serializeJson(doc, out);
  if (mqtt.connected()) {                              // FIX-09
    mqtt.publish(pubTopic.c_str(), out.c_str());
  } else {
    Serial.println("⚠️ MQTT not connected — status publish skipped");
  }
  Serial.print("📤 STATUS: "); Serial.println(out);
}




// ================== ENCODER ==================
int readAngle() {
  Wire.beginTransmission(AS5600_ADDR);
  Wire.write(0x0E);
  Wire.endTransmission(false);
  Wire.requestFrom(AS5600_ADDR, 2);
  if (Wire.available() == 2) {
    int high = Wire.read();
    int low  = Wire.read();
    return ((high << 8) | low) & 0x0FFF;
  }
  return -1;
}




// [NEW-2] Encoder update tracks locally only; no MQTT publish here.
void handleEncoder() {
  int a = readAngle();
  if (a == -1) return;

  int diff = a - prevAngle;
  if (diff >  3000) rotationCount--;
  if (diff < -3000) rotationCount++;

  prevAngle  = a;
  angle      = a;
  totalTurns = rotationCount + (angle / 4096.0);

  if (motorState == FORWARD_RUN && totalTurns >= MAX_TURNS) {
    Serial.println("🛑 FORWARD LIMIT REACHED");
    stopMotor();
  }
  if (motorState == REVERSE_RUN && totalTurns <= MIN_TURNS) {
    Serial.println("🛑 REVERSE LIMIT REACHED");
    stopMotor();
  }
}




// ================== LIMIT SWITCH ==================
void handleLimit() {
  bool limitNow = (digitalRead(LIMIT_SWITCH_PIN) == LOW);
  if (!limitOverride &&
    limitNow &&
    lastLimitState == HIGH) {  // FIX-02: rising edge only
    Serial.println("🔴 LIMIT SWITCH");
    stopMotor();
  }
  lastLimitState = limitNow;   // FIX-02
}




// ================== CURRENT ==================
void handleCurrent() {
  float current = getCurrent();
  bool  over    = current > CURRENT_OFF;

  if (motorState != IDLE && over && !lastOvercurrent) {
    Serial.println("⚠️ OVERCURRENT");
    stopMotor();
    retryCount++;
    ocTripTime = millis();
    ocFault    = true;
    Serial.print("🔁 ATTEMPT: "); Serial.println(retryCount);
    publishCurrentEvent("OC_TRIP", current);

    if (retryCount >= 3) {
      Serial.println("🔒 CURRENT LOCKED");
      lockFault = true;
      publishCurrentEvent("LOCKED", current);
    }
  }

  lastOvercurrent = over;

  if (ocFault && !lockFault && millis() - ocTripTime > RETRY_DELAY) {
    Serial.println("🔁 RETRYING");
    publishCurrentEvent("OC_RETRY", current);
    startMotor(lastDirection);
    ocFault = false;
  }

  // FIX-04: guard with !lockFault
  static bool ocEventActive = false;
  if (ocEventActive && !over && !ocFault && !lockFault) {
    publishCurrentEvent("OC_RESET", current);
    ocEventActive = false;
  }
  if (ocFault && !lockFault) ocEventActive = true;   // FIX-04
}




// ================== VOLTAGE ==================
void handleVoltageSafety() {
  float v = getVoltage();

  if (v <= CRITICAL_V && vState != LOCKED) {
    Serial.print("🛑 CRITICAL VOLTAGE: "); Serial.print(v, 2); Serial.println("V → LOCK");
    stopMotor();
    vState = LOCKED;
    publishVoltageEvent("LOCKED", v);
    return;
  }

  if (vState == LOCKED) {
    if (v >= RESET_V) {
      Serial.println("🔄 VOLTAGE RESTORED");
      vState = NORMAL;
      publishVoltageEvent("NORMAL", v);
    }
    return;
  }

  if (vState == BYPASS_ACTIVE) {
    if (v <= CRITICAL_V) {
      Serial.print("🛑 BYPASS STOPPED AT "); Serial.print(v, 2); Serial.println("V");
      stopMotor();
      vState = LOCKED;
      publishVoltageEvent("LOCKED", v);
      return;
    }
    if (v >= RESET_V) {
      Serial.println("🔄 VOLTAGE RECOVERED");
      vState = NORMAL;
      publishVoltageEvent("NORMAL", v);
    }
    return;
  }

  if (vState == WAIT_BYPASS) return;

  if (v < WARN_V_LOW) {
    if (vState == NORMAL) {
      vState = WARNING;
      warnPrintTimer = 0;
      publishVoltageEvent("WARNING", v);
    }
    if (millis() - warnPrintTimer > 5000) {
      warnPrintTimer = millis();
      Serial.print("⚠️ VOLTAGE WARNING: "); Serial.print(v, 2); Serial.println("V");
    }
  } else if (v > WARN_V_HIGH && vState == WARNING) {
    Serial.print("✅ VOLTAGE NORMAL: "); Serial.print(v, 2); Serial.println("V");
    vState = NORMAL;
    publishVoltageEvent("NORMAL", v);
  }

  if (v < CUT_V && motorState != IDLE && vState != WAIT_BYPASS) {
    Serial.print("🛑 LOW VOLTAGE CUT: "); Serial.print(v, 2); Serial.println("V");
    stopMotor();
    Serial.println("BYPASS? Y/N");
    vState = WAIT_BYPASS;
    publishVoltageEvent("CUT", v);
  }
}




// ================== BUZZER (UNCHANGED) ==================
void handleBuzzer() {

  bool limitActive = (digitalRead(LIMIT_SWITCH_PIN) == LOW);

  if (!limitActive) {
    digitalWrite(BUZZER_PIN, HIGH);
    buzzerTimer = millis();
    return;
  }

  int mode = 1;

  if      (totalTurns <= MIN_TURNS) mode = 2;
  else if (totalTurns >= MAX_TURNS) mode = 3;

  unsigned long now     = millis();
  unsigned long elapsed = now - buzzerTimer;

  // ── SINGLE BEEP ──
  if (mode == 1) {
    if      (elapsed < 150) digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 600) digitalWrite(BUZZER_PIN, HIGH);
    else                    buzzerTimer = now;
  }

  // ── DOUBLE BEEP ──
  else if (mode == 2) {
    if      (elapsed < 150)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 300)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed < 450)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 600)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed >= 1100) b