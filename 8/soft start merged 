void handleSleepMode() {
  mqttSleepCheckTimer = millis();   // FIX-10
  simEnterSleep();
  Serial.println("😴 SLEEP MODE — MQTT check every 60s, SIM radio off");




  while (true) {




    // ── Limit switch hard-wake ──
    if (digitalRead(LIMIT_SWITCH_PIN) == LOW) {

      Serial.println("⚡ LIMIT WAKE");
      limitOverride = true;

      while (digitalRead(LIMIT_SWITCH_PIN) == LOW) {
        mqtt.loop();
        handleEncoder();

        if (millis() - saveTimer > 2000) {
          saveTimer = millis();
          savePosition();
        }

        handleBuzzer();
        delay(100);
      }

      Serial.println("✅ LIMIT RELEASED");
      savePosition();
      limitOverride = false;

      simWake();
      mqttRetryTimer = 0;
      connectMQTT();
      publishFullStatus();
      return;
    }




    // ── 60s MQTT check ──
    if (millis() - mqttSleepCheckTimer >= MQTT_SLEEP_CHECK_MS) {
      mqttSleepCheckTimer = millis();
      Serial.println("⏰ SLEEP CHECK — waking SIM for MQTT");

      simWake();
      mqttRetryTimer = 0;           // FIX-05
      connectMQTT();

      sleepCommandReceived = false;
      unsigned long checkStart = millis();
      while (millis() - checkStart < 3000) {
        mqtt.loop();
        delay(50);
      }

      if (sleepCommandReceived) {
        Serial.println("🟢 COMMAND RECEIVED — WAKING");
        return;                     // FIX-06
      }

      Serial.println("😴 NO COMMAND — SIM back to sleep");
      simEnterSleep();
    }




    delay(100);
  }
  // FIX-06: state transitions owned by loop()'s FW_SLEEP case
}




// ================== SOFT START / STOP ==================
// Ramps PWM 0 → 255 over ~2.5 s then closes bypass relay (RELAY_PWR).
// Called only from startMotor() after direction relay is already set.
void softStart() {
  Serial.println("🔼 SOFT START — ramping PWM");
  for (int duty = 0; duty <= 255; duty += 3) {
    ledcWrite(PWM_PIN, duty);
    delay(30);                        // ~2.55 s total ramp
  }
  delay(1000);                        // settle before bypass
  Serial.println("⚡ BYPASS RELAY ON");
  digitalWrite(RELAY_PWR, RELAY_ON); // K3 closes — transistor bypassed
  ledcWrite(PWM_PIN, 255);            // keep transistor saturated as redundancy
}

// Ramps PWM 255 → 0 over ~2.5 s.
// Called only from stopMotor() after bypass relay is already off.
void softStop() {
  Serial.println("🔽 SOFT STOP — ramping PWM down");
  for (int duty = 255; duty >= 0; duty -= 3) {
    ledcWrite(PWM_PIN, duty);
    delay(30);                        // ~2.55 s total ramp
  }
  ledcWrite(PWM_PIN, 0);
}




// ================== MOTOR ==================

// FIX-01: clearRelays() — kills relay power with NO side effects.
// MERGED: also zeros PWM so transistor is off before any relay change.
void clearRelays() {
  ledcWrite(PWM_PIN, 0);              // MERGED: transistor off first
  digitalWrite(RELAY_PWR, RELAY_OFF);
  digitalWrite(RELAY_FWD, RELAY_OFF);
  digitalWrite(RELAY_REV, RELAY_OFF);
}

void stopMotor() {
  State stoppedFrom = motorState;   // FIX-03: capture direction BEFORE clearing

  if (motorState != IDLE) {
    resumeDirection = motorState;
    resumePending   = true;

    // ── MERGED: soft stop before killing direction relays ──
    digitalWrite(RELAY_PWR, RELAY_OFF);  // drop bypass relay first
    delay(100);
    softStop();                          // ramp PWM 255 → 0
  }

  digitalWrite(RELAY_PWR, RELAY_OFF);
  digitalWrite(RELAY_FWD, RELAY_OFF);
  digitalWrite(RELAY_REV, RELAY_OFF);
  ledcWrite(PWM_PIN, 0);                 // MERGED: ensure PWM is 0 after stop
  motorState = IDLE;
  savePosition();
  publishPosition(stoppedFrom);         // FIX-03
}




void startMotor(State dir) {
  if (vState == LOCKED) { Serial.println("🔒 BATTERY LOCKED"); return; }
  if (lockFault)        { Serial.println("🔒 CURRENT LOCKED"); return; }
  if (!limitOverride &&
    dir == REVERSE_RUN &&
    totalTurns <= MIN_TURNS){ Serial.println("⛔ REVERSE BLOCKED"); return; }
  if (!limitOverride &&
    dir == FORWARD_RUN &&
    totalTurns >= MAX_TURNS){ Serial.println("⛔ FORWARD BLOCKED"); return; }

  // FIX-01: shoot-through protection — clearRelays() also zeros PWM now
  clearRelays();
  delay(200);

  // ── MERGED: set direction relay; bypass relay (RELAY_PWR) stays OFF ──
  // softStart() will close RELAY_PWR only after PWM has fully ramped up.
  if (dir == FORWARD_RUN) {
    digitalWrite(RELAY_REV, RELAY_OFF); // ensure reverse off
    digitalWrite(RELAY_FWD, RELAY_ON);  // K1 on
  } else {
    digitalWrite(RELAY_FWD, RELAY_OFF); // ensure forward off
    digitalWrite(RELAY_REV, RELAY_ON);  // K2 on
  }
  delay(100);                           // relay settle before PWM ramp

  // ── MERGED: ramp current up through transistor, then close bypass ──
  softStart();                          // PWM 0→255 → RELAY_PWR ON

  motorState    = dir;
  lastDirection = dir;
}




