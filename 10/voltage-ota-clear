// ================== LTE ==================
void handleLTE() {
  while (SerialAT.available()) Serial.write(SerialAT.read());
}

// [LTE-NB] Called every tick in FW_LTE_INIT — advances one step per timer expiry
void handleLTEInit() {
  unsigned long now = millis();

  switch (lteState) {

    case LTE_AT:
      SerialAT.println("AT");
      lteTimer = now; lteState = LTE_CPIN;
      break;

    case LTE_CPIN:
      if (now - lteTimer < LTE_STEP_MS) { handleLTE(); break; }
      SerialAT.println("AT+CPIN?");
      lteTimer = now; lteState = LTE_CSQ;
      break;

    case LTE_CSQ:
      if (now - lteTimer < LTE_STEP_MS) { handleLTE(); break; }
      SerialAT.println("AT+CSQ");
      lteTimer = now; lteState = LTE_CREG;
      lteRegTries = 0;
      break;

    case LTE_CREG:
      if (now - lteTimer < LTE_REG_MS) { handleLTE(); break; }
      lteTimer = now;
      SerialAT.println("AT+CREG?");
      {
        unsigned long pollStart = millis();
        String resp = "";
        while (millis() - pollStart < 500) {
          while (SerialAT.available()) resp += char(SerialAT.read());
        }
        Serial.println(resp);
        if (resp.indexOf("0,1") != -1 || resp.indexOf("0,5") != -1) {
          Serial.println("✅ NETWORK REGISTERED");
          lteState = LTE_CGATT;
        } else {
          lteRegTries++;
          Serial.print("⏳ CREG attempt "); Serial.print(lteRegTries); Serial.println("/20");
          if (lteRegTries >= 20) {
            Serial.println("❌ NETWORK FAILED — continuing without LTE");
            lteReady = false; lteState = LTE_DONE;
          }
          // else stay in LTE_CREG for next tick
        }
      }
      break;

    case LTE_CGATT:
      SerialAT.println("AT+CGATT=1");
      lteTimer = now; lteState = LTE_CGDCONT;
      break;

    case LTE_CGDCONT:
      if (now - lteTimer < LTE_LONG_MS) { handleLTE(); break; }
      SerialAT.println("AT+CGDCONT=1,\"IP\",\"iot.com\"");
      lteTimer = now; lteState = LTE_CGACT;
      break;

    case LTE_CGACT:
      if (now - lteTimer < LTE_REG_MS) { handleLTE(); break; }
      SerialAT.println("AT+CGACT=1,1");
      lteTimer = now; lteState = LTE_CGPADDR;
      break;

    case LTE_CGPADDR:
      if (now - lteTimer < LTE_XLONG_MS) { handleLTE(); break; }
      SerialAT.println("AT+CGPADDR=1");
      lteTimer = now; lteState = LTE_PING;
      break;

    case LTE_PING:
      if (now - lteTimer < LTE_REG_MS) { handleLTE(); break; }
      Serial.println("🌐 TESTING INTERNET...");
      SerialAT.println("AT+QPING=1,\"8.8.8.8\"");
      lteTimer = now; lteState = LTE_DONE;
      break;

    case LTE_DONE:
      if (now - lteTimer < LTE_XLONG_MS) { handleLTE(); break; }
      lteReady = true;
      Serial.println("✅ LTE READY");
      // Transition to boot validation or normal init
      fwState = FW_INIT;
      break;
  }
}




// ================== MQTT ==================
void mqttCallback(char* topic, byte* payload, unsigned int length) {
  String msg = "";
  for (unsigned int i = 0; i < length; i++) msg += (char)payload[i];
  Serial.println("📩 MQTT MSG:"); Serial.println(msg);
  String t = String(topic);
  if (t == updateTopic) handleUpdatePayload(msg);
  else                  handleJSONCommand(msg);
}

void connectMQTT() {
  if (mqtt.connected()) return;
  if (millis() - mqttRetryTimer < 5000) return;
  mqttRetryTimer = millis();
  Serial.println("🌐 MQTT CONNECTING...");
  mqtt.setServer(mqttServer, mqttPort);
  mqtt.setCallback(mqttCallback);
  if (mqtt.connect(DEVICE_ID.c_str())) {
    Serial.println("✅ MQTT CONNECTED");
    mqtt.subscribe(subTopic.c_str());
    mqtt.subscribe(updateTopic.c_str());
    Serial.print("📡 SUBSCRIBED CMD:    "); Serial.println(subTopic);
    Serial.print("📡 SUBSCRIBED UPDATE: "); Serial.println(updateTopic);
    publishFullStatus();
  } else {
    Serial.print("❌ MQTT FAILED: "); Serial.println(mqtt.state());
  }
}




// ================== SETUP ==================
void setup() {
  Serial.begin(115200);
  DEVICE_ID   = getDeviceID();
  pubTopic    = "actuator/" + DEVICE_ID + "/status";
  subTopic    = "actuator/" + DEVICE_ID + "/cmd";
  updateTopic = "actuator/" + DEVICE_ID + "/update";

  Serial.print("📌 DEVICE ID: "); Serial.println(DEVICE_ID);
  Serial.print("📌 FW VER:    "); Serial.println(FW_VERSION);

  Wire.begin(SDA_PIN, SCL_PIN);

  pinMode(RELAY_PWR,        OUTPUT);
  pinMode(RELAY_FWD,        OUTPUT);
  pinMode(RELAY_REV,        OUTPUT);
  pinMode(LIMIT_SWITCH_PIN, INPUT_PULLUP);
  pinMode(BUZZER_PIN,       OUTPUT);

  digitalWrite(RELAY_PWR,  RELAY_OFF);
  digitalWrite(RELAY_FWD,  RELAY_OFF);
  digitalWrite(RELAY_REV,  RELAY_OFF);
  digitalWrite(BUZZER_PIN, HIGH);

  ledcAttach(PWM_PIN, PWM_FREQ, PWM_RES);
  ledcWrite(PWM_PIN, 0);
  Serial.println("✅ SOFT START PWM READY (GPIO25)");

  ina226.init();
  prefs.begin("encoder", false);
  loadPosition();

  CURRENT_OFF = prefs.getFloat("oc_thresh", 1.0);
  Serial.print("⚡ OC THRESHOLD: "); Serial.print(CURRENT_OFF, 2); Serial.println("A");

  MAX_TURNS = prefs.getFloat("max_turns", 10.0);
  Serial.print("🔄 MAX TURNS: "); Serial.println(MAX_TURNS, 2);

  // [LTE-NB] Start modem UART — LTE init runs in FW_LTE_INIT state
  SerialAT.begin(115200, SERIAL_8N1, 16, 17);
  lteTimer = millis() + 5000;   // 5 s modem power-on settle before first AT
  lteState = LTE_AT;

  // [ROLLBACK] Check if this is a post-OTA boot
  String bootCheck = prefs.getString("boot_check", "OK");
  if (bootCheck == "PENDING") {
    Serial.println("⚠️ POST-OTA BOOT — entering validation");
    fwState           = FW_LTE_INIT;   // LTE first, then FW_BOOT_VALIDATE via FW_INIT
    bootValidateTimer = 0;             // armed after LTE+MQTT ready (set in FW_BOOT_VALIDATE)
    bootValidateDone  = false;
    // Signal FW_INIT to route to FW_BOOT_VALIDATE instead of FW_ACTIVE
    prefs.putString("boot_check", "VALIDATING");
  } else {
    fwState = FW_LTE_INIT;
  }

  Serial.println("✅ SYSTEM READY");
}




// ================== LOOP ==================
void loop() {
  handleSimOp();   // [SIM-NB] advance SIM settle timer every tick

  switch (fwState) {

    // ──────────────────────────────────────────────
    // [LTE-NB] Non-blocking LTE bring-up
    case FW_LTE_INIT:
      if (millis() < lteTimer && lteState == LTE_AT) {
        handleLTE(); break;   // wait for modem power-on settle
      }
      handleLTEInit();
      break;

    // ──────────────────────────────────────────────
    // [ROLLBACK] Post-OTA boot validation
    case FW_BOOT_VALIDATE:
      connectMQTT();
      mqtt.loop();

      // Arm timer on first entry (bootValidateTimer == 0)
      if (bootValidateTimer == 0) bootValidateTimer = millis();

      // Wait for MQTT then run sensor check
      if (mqtt.connected() && !bootValidateDone) {
        bool sensorsOK = checkSensors();
        if (sensorsOK) {
          Serial.println("✅ BOOT VALIDATION PASSED");
          prefs.putString("boot_check", "OK");
          bootValidateDone = true;
          StaticJsonDocument<96> v;
          v["device_id"]  = DEVICE_ID;
          v["ota_event"]  = "OTA_VALIDATED";
          v["fw_version"] = FW_VERSION;
          String out; serializeJson(v, out);
          mqtt.publish(pubTopic.c_str(), out.c_str());
          publishFullStatus();
          fwState = FW_ACTIVE;
        }
      }

      // Timeout — rollback
      if (!bootValidateDone && millis() - bootValidateTimer > BOOT_VALIDATE_MS) {
        Serial.println("❌ BOOT VALIDATION TIMEOUT — rolling back");
        prefs.putString("boot_check", "OK");   // clear flag before rollback restart
        if (mqtt.connected()) {
          StaticJsonDocument<96> rb;
          rb["device_id"] = DEVICE_ID;
          rb["ota_event"] = "OTA_ROLLBACK";
          rb["reason"]    = "VALIDATION_TIMEOUT";
          String out; serializeJson(rb, out);
          mqtt.publish(pubTopic.c_str(), out.c_str());
          delay(300);
        }
        if (Update.canRollback()) {
          Update.rollback();
        }
        ESP.restart();
      }
      break;

    // ──────────────────────────────────────────────
    case FW_INIT:
      Serial.println("🚀 FW INIT → ACTIVE");
      connectMQTT();
      checkSensors();   // boot-time sensor check
      // [ROLLBACK] if VALIDATING flag present, go to validation instead
      if (prefs.getString("boot_check", "OK") == "VALIDATING") {
        fwState = FW_BOOT_VALIDATE;
      } else {
        fwState = FW_ACTIVE;
      }
      break;

    // ──────────────────────────────────────────────
    case FW_ACTIVE:

      // 🔴 BYPASS DELAY SLEEP
      if (bypassSleepPending) {
        if (millis() - bypassSleepTimer >= 30000) {
          bypassSleepPending = false;
          if (safeToSleep()) {
            Serial.println("😴 ENTERING SLEEP");
            sleepMode = true; sleepSub = SLEEP_ENTER;
            fwState   = FW_SLEEP;
          }
        }
      }

      // ── IDLE TIMEOUT → SLEEP ──
      if (safeToSleep()) {
        if (!idleTracking) { idleTracking = true; idleStart = millis(); }
        if (!sleepMode && millis() - idleStart > 10000) {
          Serial.println("💾 PRE-SLEEP SAVE");
          savePosition();
          sleepMode = true; sleepSub = SLEEP_ENTER;
        }
      } else {
        idleTracking = false;
      }

      if (sleepMode) { fwState = FW_SLEEP; break; }

      // ── SERIAL INPUT ──
      if (Serial.available()) {
        String input = Serial.readStringUntil('\n');
        input.trim();
        if (input.startsWith("{")) {
          handleJSONCommand(input);
        } else {
          input.toUpperCase();
          Serial.print("📩 CMD: "); Serial.println(input);
          if      (input == "F") startMotor(FORWARD_RUN);
          else if (input == "R") startMotor(REVERSE_RUN);
          else if (input == "S") stopMotor();
          else if (vState == WAIT_BYPASS) {
            if (input == "Y") {
              vState = BYPASS_ACTIVE;
              publishVoltageEvent("BYPASS", getVoltage());
              if (resumePending) { startMotor(resumeDirection); resumePending = false; }
            } else {
              vState = WARNING; resumePending = false;   // [FIX-D]
            }
          }
        }
      }

      connectMQTT();
      mqtt.loop();
      handleMotorRamp();
      handleEncoder();
      handleLimit();
      handleCurrent();
      handleVoltageSafety();
      handleBuzzer();      // [UNCHANGED]
      printDashboard();

      // [SENSOR] + [I2C-REC] periodic check every 30 s
      if (millis() - sensorCheckTimer >= 30000) {
        sensorCheckTimer = millis();
        checkSensors();
      }

      handleLTE();
      break;

    // ──────────────────────────────────────────────
    // [FIX-B] FW_SLEEP: fully non-blocking sleep state machine
    case FW_SLEEP:

      handleSimOp();   // keep SIM settle advancing during sleep ticks

      switch (sleepSub) {

        case SLEEP_ENTER:
          // Gate on SIM op completing before we consider ourselves asleep
          if (!simOpDone()) break;
          mqttSleepCheckTimer = millis();
          simEnterSleep();
          Serial.println("😴 SLEEP MODE — MQTT check every 60s");
          sleepSub = SLEEP_IDLE;
          break;

        case SLEEP_IDLE:
          if (!simOpDone()) break;   // wait for SIM to finish entering sleep

          if (digitalRead(LIMIT_SWITCH_PIN) == LOW) {
            Serial.println("⚡ LIMIT WAKE");
            limitOverride = true;
            sleepSub      = SLEEP_LIMIT;
            break;
          }

          if (millis() - mqttSleepCheckTimer >= MQTT_SLEEP_CHECK_MS) {
            mqttSleepCheckTimer = millis();
            Serial.println("⏰ SLEEP CHECK — waking SIM");
            simWake();
            mqttRetryTimer       = 0;   // FIX-05
            sleepCommandReceived = false;
            mqttChkStart         = millis();
            sleepSub             = SLEEP_MQTTCHK;
          }
          break;

        case SLEEP_LIMIT:
          mqtt.loop();
          handleEncoder();
          if (millis() - saveTimer > 2000) { saveTimer = millis(); savePosition(); }
          handleBuzzer();

          if (digitalRead(LIMIT_SWITCH_PIN) == HIGH) {
            Serial.println("✅ LIMIT RELEASED");
            savePosition();
            limitOverride = false;
            simWake();
            mqttRetryTimer = 0;
            connectMQTT();
            publishFullStatus();
            sleepMode    = false;
            idleTracking = false;
            idleStart    = millis();
            sleepSub     = SLEEP_ENTER;
            fwState      = FW_ACTIVE;
          }
          break;

        case SLEEP_MQTTCHK:
          if (!simOpDone()) break;   // wait for SIM wake settle

          // Connect and pump MQTT once SIM is awake
          connectMQTT();
          mqtt.loop();

          if (sleepCommandReceived) {
            Serial.println("🟢 COMMAND RECEIVED — WAKING");
            sleepMode    = false;
            idleTracking = false;
            idleStart    = millis();
            sleepSub     = SLEEP_ENTER;
            fwState      = FW_ACTIVE;
            break;
          }

          if (millis() - mqttChkStart >= 3000) {
            if (!safeToSleep()) {
              Serial.println("🟢 MOTOR ACTIVE — staying awake");
              sleepMode    = false;
              idleTracking = false;
              idleStart    = millis();
              sleepSub     = SLEEP_ENTER;
              fwState      = FW_ACTIVE;
            } else {
              Serial.println("😴 NO COMMAND — SIM back to sleep");
              simEnterSleep();
              sleepSub = SLEEP_IDLE;
            }
          }
          break;
      }
      break;

    // ──────────────────────────────────────────────
    // [FIX-A] FW_OTA_WAIT: drain ramp before flashing
    case FW_OTA_WAIT:
      handleMotorRamp();
      if (rampState == RAMP_IDLE && motorState == IDLE) {
        Serial.println("🚀 MOTOR IDLE — starting OTA flash");
        fwState = FW_OTA_FLASH;
      }
      break;

    // ──────────────────────────────────────────────
    // [FIX-A] FW_OTA_FLASH: motor guaranteed idle
    case FW_OTA_FLASH:
      performOTA();
      // performOTA() reboots on success; sets fwState=FW_ACTIVE on any failure
      break;
  }
}
