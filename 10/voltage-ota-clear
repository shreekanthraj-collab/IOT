// ================== [RAMP] NON-BLOCKING RAMP HANDLER ==================
void handleMotorRamp() {
  if (rampState == RAMP_IDLE || rampState == RAMP_RUNNING) return;
  unsigned long now = millis();

  switch (rampState) {

    case RAMP_UP:
      if (now - rampTimer >= RAMP_STEP_MS) {
        rampTimer = now;
        rampDuty += 3;
        if (rampDuty > 255) rampDuty = 255;
        ledcWrite(PWM_PIN, rampDuty);
        if (rampDuty >= 255) {
          rampSettle = now;
          rampState  = RAMP_BYPASS;
          Serial.println("⏳ RAMP UP DONE — settling before bypass");
        }
      }
      break;

    case RAMP_BYPASS:
      if (now - rampSettle >= RAMP_SETTLE_MS) {
        digitalWrite(RELAY_PWR, RELAY_ON);
        ledcWrite(PWM_PIN, 255);
        motorState    = rampDir;
        lastDirection = rampDir;
        rampState     = RAMP_RUNNING;
        Serial.println("⚡ BYPASS RELAY ON — MOTOR RUNNING");
      }
      break;

    case RAMP_DOWN_INIT:
      digitalWrite(RELAY_PWR, RELAY_OFF);
      rampDuty  = 255;
      ledcWrite(PWM_PIN, rampDuty);
      rampTimer = now;
      rampState = RAMP_DOWN;
      Serial.println("🔽 SOFT STOP — ramping PWM down");
      break;

    case RAMP_DOWN:
      if (now - rampTimer >= RAMP_STEP_MS) {
        rampTimer = now;
        rampDuty -= 3;
        if (rampDuty < 0) rampDuty = 0;
        ledcWrite(PWM_PIN, rampDuty);
        if (rampDuty <= 0) {
          ledcWrite(PWM_PIN, 0);
          rampState = RAMP_DONE;
        }
      }
      break;

    case RAMP_DONE:
      digitalWrite(RELAY_FWD, RELAY_OFF);
      digitalWrite(RELAY_REV, RELAY_OFF);
      ledcWrite(PWM_PIN, 0);
      rampState  = RAMP_IDLE;
      motorState = IDLE;
      savePosition();
      publishPosition(resumeDirection);   // FIX-03
      Serial.println("🛑 MOTOR STOPPED — IDLE");
      break;

    default: break;
  }
}




// ================== MOTOR ==================

// FIX-01: clearRelays() — kills relay power with NO side effects.
void clearRelays() {
  ledcWrite(PWM_PIN, 0);
  digitalWrite(RELAY_PWR, RELAY_OFF);
  digitalWrite(RELAY_FWD, RELAY_OFF);
  digitalWrite(RELAY_REV, RELAY_OFF);
}

void stopMotor() {
  State stoppedFrom = motorState;   // FIX-03

  if (motorState != IDLE) {
    resumeDirection = motorState;
    resumePending   = true;

    if (rampState == RAMP_UP || rampState == RAMP_BYPASS) {
      clearRelays();
      rampState  = RAMP_IDLE;
      motorState = IDLE;
      savePosition();
      publishPosition(stoppedFrom);   // FIX-03
      return;
    }

    rampState = RAMP_DOWN_INIT;
    return;
  }

  clearRelays();
  rampState = RAMP_IDLE;
}

void startMotor(State dir) {
  if (vState   == LOCKED) { Serial.println("🔒 BATTERY LOCKED");  return; }
  if (lockFault)           { Serial.println("🔒 CURRENT LOCKED");  return; }
  if (i2cFault)            { Serial.println("🔒 I2C FAULT — BLOCKED"); return; }  // [I2C-REC]
  if (!limitOverride && dir == REVERSE_RUN && totalTurns <= MIN_TURNS)
                           { Serial.println("⛔ REVERSE BLOCKED"); return; }
  if (!limitOverride && dir == FORWARD_RUN && totalTurns >= MAX_TURNS)
                           { Serial.println("⛔ FORWARD BLOCKED"); return; }

  clearRelays();   // FIX-01
  rampDuty  = 0;
  rampDir   = dir;
  rampTimer = millis() + 200;

  if (dir == FORWARD_RUN) {
    digitalWrite(RELAY_REV, RELAY_OFF);
    digitalWrite(RELAY_FWD, RELAY_ON);
  } else {
    digitalWrite(RELAY_FWD, RELAY_OFF);
    digitalWrite(RELAY_REV, RELAY_ON);
  }

  rampState = RAMP_UP;
  Serial.println("🔼 SOFT START — non-blocking ramp initiated");
}




