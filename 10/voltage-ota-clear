// ================== [SIM-NB] NON-BLOCKING SIM OPERATION ==================
enum SimOp { SIM_IDLE, SIM_ENTERING_SLEEP, SIM_WAKING };
SimOp         simOp      = SIM_IDLE;
unsigned long simOpTimer = 0;
bool          simSleeping = false;

#define SIM_SLEEP_SETTLE_MS  2000UL
#define SIM_WAKE_SETTLE_MS   5000UL

// Returns true when no SIM operation is in progress
bool simOpDone() { return simOp == SIM_IDLE; }

// Called every loop tick — advances SIM settle timers non-blocking
void handleSimOp() {
  if (simOp == SIM_IDLE) return;
  if (millis() - simOpTimer < (simOp == SIM_ENTERING_SLEEP
                                ? SIM_SLEEP_SETTLE_MS
                                : SIM_WAKE_SETTLE_MS)) return;
  if (simOp == SIM_ENTERING_SLEEP) {
    simSleeping = true;
    Serial.println("📴 SIM SLEEP SETTLED");
  } else {
    simSleeping = false;
    Serial.println("📶 SIM WAKE SETTLED");
  }
  simOp = SIM_IDLE;
}

// Fire AT command and return — settle handled by handleSimOp() each tick
void simEnterSleep() {
  if (simSleeping || simOp != SIM_IDLE) return;
  if (!safeToSleep()) {
    Serial.println("⚠️ SIM SLEEP BLOCKED — motor or resume pending");
    return;
  }
  Serial.println("📴 SIM ENTERING LOW POWER...");
  SerialAT.println("AT+CFUN=4");
  simOpTimer = millis();
  simOp      = SIM_ENTERING_SLEEP;
}

void simWake() {
  if (!simSleeping && simOp == SIM_IDLE) return;
  Serial.println("📶 SIM WAKING...");
  SerialAT.println("AT+CFUN=1");
  simOpTimer  = millis();
  simOp       = SIM_WAKING;
  simSleeping = false;   // treat as awake immediately for routing; settled by handleSimOp
}




