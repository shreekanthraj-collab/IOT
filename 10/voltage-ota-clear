void publishFullStatus() {
  StaticJsonDocument<256> doc;
  doc["device_id"] = DEVICE_ID;
  if      (motorState == IDLE)        doc["state"] = "IDLE";
  else if (motorState == FORWARD_RUN) doc["state"] = "FORWARD";
  else                                doc["state"] = "REVERSE";
  doc["turns"]        = totalTurns;
  doc["max_turns"]    = MAX_TURNS;
  doc["fw_version"]   = FW_VERSION;
  switch (vState) {
    case NORMAL:        doc["voltage_status"] = "NORMAL";          break;
    case WARNING:       doc["voltage_status"] = "WARNING";         break;
    case WAIT_BYPASS:   doc["voltage_status"] = "LOW_VOLTAGE_CUT"; break;
    case BYPASS_ACTIVE: doc["voltage_status"] = "BYPASS_ACTIVE";   break;
    case LOCKED:        doc["voltage_status"] = "CRITICAL_LOCK";   break;
  }
  doc["oc_threshold"] = CURRENT_OFF;
  doc["retry"]        = retryCount;
  if      (lockFault)        doc["fault"] = "CURRENT_LOCK";
  else if (vState == LOCKED) doc["fault"] = "VOLTAGE_LOCK";
  else if (i2cFault)         doc["fault"] = "I2C_FAULT";          // [I2C-REC]
  else                       doc["fault"] = "OK";
  if (updateAvailable) {
    doc["update_available"] = true;
    doc["update_version"]   = pendingUpdateVer;
  }
  String out; serializeJson(doc, out);
  if (mqtt.connected()) mqtt.publish(pubTopic.c_str(), out.c_str());   // FIX-09
  else Serial.println("⚠️ MQTT not connected — status publish skipped");
  Serial.print("📤 STATUS: "); Serial.println(out);
}




// ================== ENCODER ==================
int readAngle() {
  Wire.beginTransmission(AS5600_ADDR);
  Wire.write(0x0E);
  Wire.endTransmission(false);
  Wire.requestFrom(AS5600_ADDR, 2);
  if (Wire.available() == 2) {
    int high = Wire.read();
    int low  = Wire.read();
    return ((high << 8) | low) & 0x0FFF;
  }
  return -1;
}

void handleEncoder() {
  int a = readAngle();
  if (a == -1) return;
  int diff = a - prevAngle;
  if (diff >  3000) rotationCount--;
  if (diff < -3000) rotationCount++;
  prevAngle  = a;
  angle      = a;
  totalTurns = rotationCount + (angle / 4096.0);
  if (motorState == FORWARD_RUN && totalTurns >= MAX_TURNS) {
    Serial.println("🛑 FORWARD LIMIT REACHED"); stopMotor();
  }
  if (motorState == REVERSE_RUN && totalTurns <= MIN_TURNS) {
    Serial.println("🛑 REVERSE LIMIT REACHED"); stopMotor();
  }
}




// ================== LIMIT SWITCH ==================
void handleLimit() {
  bool limitNow = (digitalRead(LIMIT_SWITCH_PIN) == LOW);
  if (!limitOverride && limitNow && lastLimitState == HIGH) {  // FIX-02
    Serial.println("🔴 LIMIT SWITCH");
    stopMotor();
  }
  lastLimitState = limitNow;   // FIX-02
}




// ================== CURRENT ==================
void handleCurrent() {
  float current = getCurrent();
  bool  over    = current > CURRENT_OFF;

  if (motorState != IDLE && over && !lastOvercurrent) {
    Serial.println("⚠️ OVERCURRENT");
    stopMotor();
    retryCount++;
    ocTripTime = millis();
    ocFault    = true;
    Serial.print("🔁 ATTEMPT: "); Serial.println(retryCount);
    publishCurrentEvent("OC_TRIP", current);
    if (retryCount >= 3) {
      Serial.println("🔒 CURRENT LOCKED");
      lockFault = true;
      publishCurrentEvent("LOCKED", current);
    }
  }
  lastOvercurrent = over;

  if (ocFault && !lockFault && millis() - ocTripTime > RETRY_DELAY) {
    Serial.println("🔁 RETRYING");
    publishCurrentEvent("OC_RETRY", current);
    startMotor(lastDirection);
    ocFault = false;
  }

  static bool ocEventActive = false;   // FIX-04
  if (ocEventActive && !over && !ocFault && !lockFault) {
    publishCurrentEvent("OC_RESET", current);
    ocEventActive = false;
  }
  if (ocFault && !lockFault) ocEventActive = true;   // FIX-04
}




// ================== VOLTAGE ==================
void handleVoltageSafety() {
  float v = getVoltage();

  if (v <= CRITICAL_V && vState != LOCKED) {
    Serial.print("🛑 CRITICAL VOLTAGE: "); Serial.print(v, 2); Serial.println("V → LOCK");
    stopMotor(); vState = LOCKED;
    publishVoltageEvent("LOCKED", v); return;
  }

  if (vState == LOCKED) {
    if (v >= RESET_V) {
      Serial.println("🔄 VOLTAGE RESTORED");
      vState = NORMAL; publishVoltageEvent("NORMAL", v);
    }
    return;
  }

  if (vState == BYPASS_ACTIVE) {
    if (v <= CRITICAL_V) {
      Serial.print("🛑 BYPASS STOPPED AT "); Serial.print(v, 2); Serial.println("V");
      stopMotor(); vState = LOCKED;
      publishVoltageEvent("LOCKED", v); return;
    }
    if (v >= RESET_V) {
      Serial.println("🔄 VOLTAGE RECOVERED");
      vState = NORMAL; publishVoltageEvent("NORMAL", v);
    }
    return;
  }

  if (vState == WAIT_BYPASS) return;

  if (v < WARN_V_LOW) {
    if (vState == NORMAL) {
      vState = WARNING; warnPrintTimer = 0;
      publishVoltageEvent("WARNING", v);
    }
    if (millis() - warnPrintTimer > 5000) {
      warnPrintTimer = millis();
      Serial.print("⚠️ VOLTAGE WARNING: "); Serial.print(v, 2); Serial.println("V");
    }
  } else if (v > WARN_V_HIGH && vState == WARNING) {
    Serial.print("✅ VOLTAGE NORMAL: "); Serial.print(v, 2); Serial.println("V");
    vState = NORMAL; publishVoltageEvent("NORMAL", v);
  }

  if (v < CUT_V && motorState != IDLE && vState != WAIT_BYPASS) {
    Serial.print("🛑 LOW VOLTAGE CUT: "); Serial.print(v, 2); Serial.println("V");
    stopMotor();
    Serial.println("BYPASS? Y/N");
    vState = WAIT_BYPASS;
    publishVoltageEvent("CUT", v);
  }
}




// ================== BUZZER (UNCHANGED) ==================
void handleBuzzer() {
  bool limitActive = (digitalRead(LIMIT_SWITCH_PIN) == LOW);
  if (!limitActive) { digitalWrite(BUZZER_PIN, HIGH); buzzerTimer = millis(); return; }

  int mode = 1;
  if      (totalTurns <= MIN_TURNS) mode = 2;
  else if (totalTurns >= MAX_TURNS) mode = 3;

  unsigned long now     = millis();
  unsigned long elapsed = now - buzzerTimer;

  if (mode == 1) {
    if      (elapsed < 150) digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 600) digitalWrite(BUZZER_PIN, HIGH);
    else                    buzzerTimer = now;
  } else if (mode == 2) {
    if      (elapsed < 150)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 300)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed < 450)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 600)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed >= 1100) buzzerTimer = now;
  } else if (mode == 3) {
    if      (elapsed < 150)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 300)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed < 450)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 600)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed < 750)  digitalWrite(BUZZER_PIN, LOW);
    else if (elapsed < 900)  digitalWrite(BUZZER_PIN, HIGH);
    else if (elapsed >= 1400) buzzerTimer = now;
  }
}




// ================== JSON COMMAND HANDLER ==================
bool sleepCommandReceived = false;

void handleJSONCommand(String input) {
  StaticJsonDocument<256> doc;
  if (deserializeJson(doc, input)) { Serial.println("❌ JSON ERROR"); return; }

  String id = doc["device_id"];
  if (id != DEVICE_ID) return;

  String cmd = doc["cmd"];

  // [FIX-C] F and R set sleepCommandReceived = true
  if (cmd == "F") {
    startMotor(FORWARD_RUN);
    sleepCommandReceived = true;
  }
  else if (cmd == "R") {
    startMotor(REVERSE_RUN);
    sleepCommandReceived = true;
  }
  else if (cmd == "S") stopMotor();

  else if (vState == WAIT_BYPASS) {
    if (cmd == "Y") {
      Serial.println("⚠️ BYPASS ENABLED");
      vState = BYPASS_ACTIVE;
      publishVoltageEvent("BYPASS", getVoltage());
      if (resumePending) {
        Serial.println("🔁 RESUMING");
        startMotor(resumeDirection);
        resumePending = false;
      }
      sleepCommandReceived = true;
    } else if (cmd == "N") {
      Serial.println("❌ BYPASS DENIED");
      vState        = WARNING;
      resumePending = false;   // [FIX-D]
      sleepCommandReceived = true;
    }
  }

  else if (cmd == "SET_CURRENT") {
    float newVal = doc["value"] | CURRENT_OFF;
    if (newVal > 0.1 && newVal < 10.0) {
      CURRENT_OFF = newVal;
      prefs.putFloat("oc_thresh", CURRENT_OFF);
      lockFault = false; ocFault = false; retryCount = 0;
      Serial.print("⚡ OC THRESHOLD SET: "); Serial.print(CURRENT_OFF, 2); Serial.println("A");
      Serial.println("🔓 CURRENT LOCK CLEARED");
      publishCurrentEvent("THRESHOLD_SET", getCurrent());
    } else { Serial.println("❌ INVALID CURRENT VALUE"); }
    sleepCommandReceived = true;
  }

  else if (cmd == "SET_TURNS") {
    float newTurns = doc["value"] | MAX_TURNS;
    if (newTurns >= 2.0 && newTurns <= 20.0) {
      MAX_TURNS = newTurns;
      prefs.putFloat("max_turns", MAX_TURNS);
      Serial.print("🔄 MAX TURNS SET: "); Serial.println(MAX_TURNS, 2);
      publishFullStatus();
    } else { Serial.println("❌ INVALID TURNS VALUE (range: 2.0–20.0)"); }
    sleepCommandReceived = true;
  }

  else if (cmd == "GET_STATUS") {
    publishFullStatus();
    sleepCommandReceived = true;
  }

  else if (cmd == "GET_SENSORS") {
    checkSensors();
    sleepCommandReceived = true;
  }

  else if (cmd == "CHECK_UPDATE") {
    if (updateAvailable) {
      StaticJsonDocument<128> upd;
      upd["device_id"]        = DEVICE_ID;
      upd["update_available"] = true;
      upd["update_version"]   = pendingUpdateVer;
      upd["current_version"]  = FW_VERSION;
      String out; serializeJson(upd, out);
      if (mqtt.connected()) mqtt.publish(pubTopic.c_str(), out.c_str());  // FIX-09
    } else {
      StaticJsonDocument<96> upd;
      upd["device_id"]        = DEVICE_ID;
      upd["update_available"] = false;
      upd["current_version"]  = FW_VERSION;
      String out; serializeJson(upd, out);
      if (mqtt.connected()) mqtt.publish(pubTopic.c_str(), out.c_str());  // FIX-09
    }
    sleepCommandReceived = true;
  }

  // [FIX-A] DO_UPDATE → FW_OTA_WAIT
  else if (cmd == "DO_UPDATE") {
    if (updateAvailable && pendingUpdateURL.length() > 0) {
      Serial.println("🚀 OTA UPDATE ACCEPTED — waiting for motor idle");
      stopMotor();
      fwState = FW_OTA_WAIT;
    } else { Serial.println("❌ NO UPDATE PENDING"); }
    sleepCommandReceived = true;
  }

  else { sleepCommandReceived = true; }
}




// ================== UPDATE TOPIC HANDLER ==================
void handleUpdatePayload(String payload) {
  StaticJsonDocument<256> doc;
  if (deserializeJson(doc, payload)) return;

  String version = doc["version"] | "";
  String url     = doc["url"]     | "";
  String sha256  = doc["sha256"]  | "";   // [CHECKSUM] optional field

  if (version.length() == 0) return;

  if (version != FW_VERSION) {
    updateAvailable  = true;
    pendingUpdateVer = version;
    pendingUpdateURL = url;
    pendingUpdateSHA = sha256;   // [CHECKSUM] may be empty string

    Serial.print("🆕 UPDATE AVAILABLE: v"); Serial.print(version);
    Serial.print(" (current: v"); Serial.print(FW_VERSION); Serial.println(")");
    if (sha256.length() == 0) Serial.println("⚠️ No SHA-256 provided — integrity check skipped");

    StaticJsonDocument<160> notif;
    notif["device_id"]        = DEVICE_ID;
    notif["update_available"] = true;
    notif["update_version"]   = version;
    notif["current_version"]  = FW_VERSION;
    notif["note"]             = "Send DO_UPDATE to install";
    String out; serializeJson(notif, out);
    if (mqtt.connected()) mqtt.publish(pubTopic.c_str(), out.c_str());  // FIX-09
    sleepCommandReceived = true;
  } else {
    Serial.println("✅ FIRMWARE UP TO DATE");
    updateAvailable = false;
  }
}




// ================== [OTA] FULL OTA WITH CHECKSUM + ROLLBACK FLAG ==================
void performOTA() {
  Serial.println("🚀 OTA START");
  Serial.print("🔗 URL: "); Serial.println(pendingUpdateURL);

  // ── Parse URL ──
  String url  = pendingUpdateURL;
  String host = "";
  String path = "/";
  int    port = 80;
  if (url.startsWith("http://")) url = url.substring(7);
  int slashIdx = url.indexOf('/');
  if (slashIdx == -1) { host = url; }
  else { host = url.substring(0, slashIdx); path = url.substring(slashIdx); }
  int colonIdx = host.indexOf(':');
  if (colonIdx != -1) { port = host.substring(colonIdx + 1).toInt(); host = host.substring(0, colonIdx); }

  Serial.print("🌐 HOST: "); Serial.print(host);
  Serial.print("  PORT: "); Serial.print(port);
  Serial.print("  PATH: "); Serial.println(path);

  if (!otaClient.connect(host.c_str(), port)) {
    Serial.println("❌ OTA: TCP connect failed");
    if (mqtt.connected()) {
      StaticJsonDocument<96> err;
      err["device_id"] = DEVICE_ID; err["ota_event"] = "OTA_FAIL"; err["reason"] = "TCP_CONNECT";
      String out; serializeJson(err, out); mqtt.publish(pubTopic.c_str(), out.c_str());
    }
    fwState = FW_ACTIVE; return;
  }

  otaClient.print(String("GET ") + path + " HTTP/1.1\r\n" +
                  "Host: " + host + "\r\n" +
                  "Connection: close\r\n\r\n");

  // ── Parse headers ──
  unsigned long hdrTimeout = millis();
  int  contentLength = -1;
  bool headersDone   = false;
  while (!headersDone && millis() - hdrTimeout < 10000) {
    if (otaClient.available()) {
      String line = otaClient.readStringUntil('\n');
      line.trim();
      if (line.startsWith("Content-Length:") || line.startsWith("content-length:")) {
        contentLength = line.substring(line.indexOf(':') + 1).toInt();
        Serial.print("📦 Content-Length: "); Serial.println(contentLength);
      }
      if (line.length() == 0) headersDone = true;
    }
  }

  if (contentLength <= 0) {
    Serial.println("❌ OTA: bad Content-Length");
    otaClient.stop();
    if (mqtt.connected()) {
      StaticJsonDocument<96> err;
      err["device_id"] = DEVICE_ID; err["ota_event"] = "OTA_FAIL"; err["reason"] = "BAD_CONTENT_LENGTH";
      String out; serializeJson(err, out); mqtt.publish(pubTopic.c_str(), out.c_str());
    }
    fwState = FW_ACTIVE; return;
  }

  if (!Update.begin(contentLength)) {
    Serial.println("❌ OTA: Update.begin failed");
    otaClient.stop();
    if (mqtt.connected()) {
      StaticJsonDocument<96> err;
      err["device_id"] = DEVICE_ID; err["ota_event"] = "OTA_FAIL"; err["reason"] = "UPDATE_BEGIN";
      String out; serializeJson(err, out); mqtt.publish(pubTopic.c_str(), out.c_str());
    }
    fwState = FW_ACTIVE; return;
  }

  // ── [CHECKSUM] Initialise SHA-256 context ──
  bool        doChecksum = (pendingUpdateSHA.length() == 64);
  mbedtls_sha256_context sha256ctx;
  if (doChecksum) mbedtls_sha256_init(&sha256ctx);
  if (doChecksum) mbedtls_sha256_starts(&sha256ctx, 0);   // 0 = SHA-256 (not SHA-224)

  // ── Stream binary in 256-byte chunks ──
  uint8_t       buf[256];
  int           written     = 0;
  int           lastPct     = -1;
  unsigned long dataTimeout = millis();

  while (written < contentLength) {
    if (!otaClient.connected() && !otaClient.available()) {
      Serial.println("❌ OTA: connection dropped"); break;
    }
    int toRead = min((int)sizeof(buf), contentLength - written);
    int rd     = otaClient.readBytes(buf, toRead);
    if (rd > 0) {
      Update.write(buf, rd);
      if (doChecksum) mbedtls_sha256_update(&sha256ctx, buf, rd);   // [CHECKSUM]
      written    += rd;
      dataTimeout = millis();
      int pct       = (written * 100) / contentLength;
      int pctBucket = pct / 10;
      if (pctBucket != lastPct) {
        lastPct = pctBucket;
        Serial.print("📶 OTA PROGRESS: "); Serial.print(pct); Serial.println("%");
        if (mqtt.connected()) {
          StaticJsonDocument<96> prog;
          prog["device_id"]    = DEVICE_ID;
          prog["ota_event"]    = "OTA_PROGRESS";
          prog["progress_pct"] = pct;
          String out; serializeJson(prog, out);
          mqtt.publish(pubTopic.c_str(), out.c_str());
        }
      }
    } else if (millis() - dataTimeout > 10000) {
      Serial.println("❌ OTA: data timeout"); break;
    }
  }

  otaClient.stop();

  if (written != contentLength) {
    Update.abort();
    if (doChecksum) mbedtls_sha256_free(&sha256ctx);
    if (mqtt.connected()) {
      StaticJsonDocument<96> err;
      err["device_id"] = DEVICE_ID; err["ota_event"] = "OTA_FAIL"; err["reason"] = "INCOMPLETE_WRITE";
      String out; serializeJson(err, out); mqtt.publish(pubTopic.c_str(), out.c_str());
    }
    fwState = FW_ACTIVE; return;
  }

  // ── [CHECKSUM] Verify digest before Update.end() ──
  if (doChecksum) {
    uint8_t digest[32];
    mbedtls_sha256_finish(&sha256ctx, digest);
    mbedtls_sha256_free(&sha256ctx);

    // Convert digest to hex string
    char hexDigest[65];
    for (int i = 0; i < 32; i++) sprintf(hexDigest + i * 2, "%02x", digest[i]);
    hexDigest[64] = '\0';

    Serial.print("🔐 SHA-256 computed:  "); Serial.println(hexDigest);
    Serial.print("🔐 SHA-256 expected:  "); Serial.println(pendingUpdateSHA);

    if (String(hexDigest) != pendingUpdateSHA) {
      Serial.println("❌ OTA: CHECKSUM MISMATCH — aborting");
      Update.abort();
      if (mqtt.connected()) {
        StaticJsonDocument<96> err;
        err["device_id"] = DEVICE_ID; err["ota_event"] = "OTA_FAIL"; err["reason"] = "CHECKSUM_MISMATCH";
        String out; serializeJson(err, out); mqtt.publish(pubTopic.c_str(), out.c_str());
      }
      fwState = FW_ACTIVE; return;
    }
    Serial.println("✅ CHECKSUM VERIFIED");
  }

  if (!Update.end()) {
    if (mqtt.connected()) {
      StaticJsonDocument<96> err;
      err["device_id"] = DEVICE_ID; err["ota_event"] = "OTA_FAIL"; err["reason"] = "UPDATE_END";
      String out; serializeJson(err, out); mqtt.publish(pubTopic.c_str(), out.c_str());
    }
    fwState = FW_ACTIVE; return;
  }

  // ── [ROLLBACK] Write PENDING flag before reboot ──
  prefs.putString("boot_check", "PENDING");
  Serial.println("🔖 boot_check = PENDING");

  // ── Success — flush MQTT then reboot ──
  Serial.println("✅ OTA WRITTEN — rebooting");
  if (mqtt.connected()) {
    StaticJsonDocument<96> done;
    done["device_id"]      = DEVICE_ID;
    done["ota_event"]      = "OTA_DONE";
    done["update_version"] = pendingUpdateVer;
    String out; serializeJson(done, out);
    mqtt.publish(pubTopic.c_str(), out.c_str());
    delay(500);   // only delay in firmware — flush OTA_DONE before reboot
  }
  ESP.restart();
}




